---
import BaseLayout from '../layouts/BaseLayout.astro';
import StrategyLoop from '../components/StrategyLoop.astro';
import frameworkData from '../data/lean-cs-data.json';

const contextParams = frameworkData.context_parameters.parameters;
const domains = frameworkData.assessment_domains.domains;
const stages = frameworkData.maturity_stages.stages;
---

<BaseLayout title="Customer Success Maturity Assessment" description="A 5-minute assessment of your customer success operation across 8 domains. Returns a stage rating, priority actions, and recommended playbooks.">

  <div class="container">
  <div class="assess-page">

    <!-- Strategy Loop wayfinding -->
    <div class="assess-loop-indicator">
      <StrategyLoop activePhase="assess" size="sm" />
    </div>

    <!-- Resume banner — revealed by JS only when an in-progress draft exists -->
    <div class="resume-banner" id="resume-banner" style="display:none;" role="status">
      <div class="resume-banner-text">
        <strong>You have an assessment in progress.</strong>
        <span class="resume-progress" id="resume-progress-text"></span>
      </div>
      <div class="resume-banner-actions">
        <button class="btn btn-primary" id="resume-btn" type="button">Resume</button>
        <button class="resume-discard-btn" id="resume-discard-btn" type="button">Start over</button>
      </div>
    </div>

    <!-- Static crawlable intro (hidden once user has completed the assessment) -->
    <section class="assess-intro" data-hide-if-assessed aria-label="About the assessment">
      <h1 class="assess-intro-headline">Customer Success Maturity Assessment</h1>
      <p class="assess-intro-lede">
        Find out where your customer success team stands on a three-stage maturity model, and get a prioritized set of actions to move up. It just takes five minutes, and no signup is required.
      </p>

      <div class="assess-intro-cta">
        <button type="button" class="btn btn-primary assess-start-btn" id="assess-start-btn">
          Start the Assessment
        </button>
        <span class="assess-intro-cta-hint">Or scroll for more details about how it works.</span>
      </div>

      <div class="assess-intro-body">
        <h2>What the assessment measures</h2>
        <p>
          The assessment covers eight capability domains: segmentation, customer journey, proactive engagement, measurement, retention and expansion, cross-functional partnership, AI leverage, and team structure. Each domain has three questions scored from 1 to 4. Scores are averaged across domains to produce your overall maturity stage.
        </p>

        <h2>How scoring works</h2>
        <p>
          Each response option is a calibrated description of what a team at that level actually does, not a subjective self-rating. Picking option 2 on a segmentation question means "we segment by ARR but not much else." The stages map to score ranges:
        </p>
        <ul class="assess-intro-stages">
          <li><strong>Crawl</strong> (2.5–5.0) — foundation building; reactive, inconsistent, founder-led.</li>
          <li><strong>Walk</strong> (5.0–7.5) — an operating system is forming; segmented, measured, repeatable.</li>
          <li><strong>Run</strong> (7.5–10.0) — scaled and predictable; outcomes tracked, plays automated.</li>
        </ul>

        <h2>What the profile questions do</h2>
        <p>
          The seven questions at the start (ARR, customer segment, team size, and others) do not affect your score. They set the lens for benchmarks and recommendations, so a fifty-person enterprise team gets different guidance than a two-person SMB team working on the same weakness.
        </p>

        <h2>What you get back</h2>
        <p>
          After submission you go straight to your <a href="/cs-maturity-report/">CS Maturity Report</a> — a personalised view of your stage, domain-by-domain scores, executive summary, strengths, priority actions, recommended playbooks, and stage-specific metric priorities. Everything is stored in your browser, not on a server, so re-assessing later lets you track movement over time.
        </p>

        <h2>Who this is for</h2>
        <p>
          CS leaders, CS operations teams, and founders who want a stage-referenced read on where their customer success function stands. The output is most useful when paired with the framework's <a href="/customer-success-principles/">principles</a>, <a href="/customer-success-playbooks/">playbooks</a>, and <a href="/customer-success-metrics/">metrics</a>. The assessment is free, open-source, and vendor-neutral.
        </p>
      </div>
    </section>

    <!-- Progress Bar -->
    <div class="progress-bar-wrap" id="progress-bar-wrap">
      <div class="progress-bar" id="progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="Assessment progress"></div>
      <span class="progress-label" id="progress-label" aria-live="polite"></span>
    </div>

    <!-- Phase 1: Context Profile -->
    <section class="phase" id="phase-profile">
      <h2 class="phase-title">First, tell us about your company and team</h2>
      <p class="phase-subtitle">These don't affect your maturity score — they help us tailor benchmarks and recommendations to your context.</p>

      <div class="update-flow-bar" id="update-flow-bar" style="display:none;">
        <span class="update-flow-hint">Updating your previous answers — change only what's different.</span>
        <button class="btn-start-fresh" id="start-fresh-btn" type="button">Start Fresh Instead</button>
      </div>

      <div class="profile-form" id="profile-form">
        <div class="profile-question company-name-field">
          <h2 class="question-label" id="label-company-name">What's your company name?</h2>
          <p class="company-name-hint">Optional — this personalizes your report and recommendations.</p>
          <input
            type="text"
            id="company-name-input"
            class="company-name-input"
            placeholder="e.g. Acme Corp"
            maxlength="100"
            autocomplete="organization"
            aria-labelledby="label-company-name"
          />
        </div>

        {contextParams.map((param, idx) => (
          <div class="profile-question" data-param-id={param.id} data-index={idx}>
            <h2 class="question-label" id={`label-${param.id}`}>{param.question}</h2>
            <div class="options-grid" role="radiogroup" aria-labelledby={`label-${param.id}`}>
              {param.options.sort((a, b) => a.sort - b.sort).map(opt => (
                <button
                  class="option-card"
                  data-param={param.id}
                  data-value={opt.id}
                  type="button"
                  role="radio"
                  aria-checked="false"
                >
                  {opt.label}
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="phase-nav">
        <button class="btn btn-primary" id="profile-next" disabled>Continue to Assessment</button>
        <button class="btn btn-secondary save-finish-btn" type="button" style="display:none;">Save & Finish</button>
      </div>
    </section>

    <!-- Phase 2: Capability Assessment -->
    <section class="phase" id="phase-assessment" style="display:none;">
      <div id="assessment-domains">
        {domains.map((domain, dIdx) => (
          <div class="domain-block" data-domain={domain.id} data-domain-index={dIdx} style={dIdx > 0 ? 'display:none;' : ''}>
            <div class="domain-header">
              <span class="domain-icon">{
                domain.icon === 'layers' ? '◈' :
                domain.icon === 'map' ? '◇' :
                domain.icon === 'activity' ? '◆' :
                domain.icon === 'bar-chart' ? '▦' :
                domain.icon === 'trending-up' ? '▲' :
                domain.icon === 'handshake' ? '⤝' :
                domain.icon === 'cpu' ? '▣' :
                domain.icon === 'users' ? '●' : '●'
              }</span>
              <div>
                <h2 class="domain-title">{domain.label}</h2>
                <p class="domain-desc">{domain.description}</p>
              </div>
            </div>

            {domain.questions.map((q, qIdx) => (
              <div class="assess-question" data-question-id={q.id}>
                <h3 class="question-text" id={`label-${q.id}`}>{q.question}</h3>
                <div class="options-stack" role="radiogroup" aria-labelledby={`label-${q.id}`}>
                  {q.options.map(opt => (
                    <button
                      class="option-card option-assess"
                      data-question={q.id}
                      data-score={opt.score}
                      type="button"
                      role="radio"
                      aria-checked="false"
                    >
                      {opt.label}
                    </button>
                  ))}
                </div>
              </div>
            ))}

            <div class="domain-nav">
              {dIdx > 0 && <button class="btn btn-secondary domain-prev" data-target={dIdx - 1} type="button">Back</button>}
              {dIdx < domains.length - 1
                ? <button class="btn btn-primary domain-next" data-target={dIdx + 1} type="button" disabled>Next Domain</button>
                : <button class="btn btn-primary" id="finish-assessment" type="button" disabled>See Your Results</button>
              }
              <button class="btn btn-secondary save-finish-btn" type="button" style="display:none;">Save & Finish</button>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Auto-save reassurance — revealed by JS only in the normal (non-update) flow -->
    <div class="autosave-hint" id="autosave-hint" style="display:none;" role="note">
      <svg class="autosave-hint-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
      <span>Your answers are saved automatically. You can close this tab and pick up where you left off.</span>
    </div>

  </div>
  </div>
</BaseLayout>

<style>
  .assess-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 52rem;
    margin-inline: auto;
  }

  .assess-loop-indicator {
    max-width: 48rem;
    margin-inline: auto;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  /* Static crawlable intro */
  .assess-intro {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .assess-intro-headline {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .assess-intro-lede {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 40rem;
    margin: 0 0 2rem;
  }

  .assess-intro-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin: 0 0 2.5rem;
  }

  .assess-start-btn {
    font-size: 1rem;
    padding: 0.875rem 1.75rem;
  }

  .assess-intro-cta-hint {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .assess-intro-body h2 {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: 1.375rem;
    letter-spacing: -0.01em;
    margin: 1.75rem 0 0.5rem;
    color: var(--color-text);
  }

  .assess-intro-body p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem;
  }

  .assess-intro-body a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .assess-intro-stages {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1rem;
    display: grid;
    gap: 0.5rem;
  }

  .assess-intro-stages li {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
  }

  .assess-intro-stages strong {
    color: var(--color-text);
  }

  /* Progress bar */
  .progress-bar-wrap {
    position: sticky;
    top: 4rem;
    z-index: 50;
    background: var(--color-bg);
    padding: 0.75rem 0;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .progress-bar {
    flex: 1;
    height: 4px;
    background: var(--color-surface);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .progress-bar::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: var(--progress, 0%);
    background: var(--color-accent);
    border-radius: 2px;
    transition: width 0.3s ease-out;
  }

  .progress-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    min-width: 5rem;
    text-align: right;
  }

  /* Phase titles */
  .phase-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .phase-subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin-bottom: 2.5rem;
    max-width: 32rem;
  }

  .update-flow-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.625rem 0.875rem;
    background: rgba(229, 57, 53, 0.06);
    border: 1px solid rgba(229, 57, 53, 0.2);
    border-radius: 6px;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .update-flow-hint {
    flex: 1;
  }

  .btn-start-fresh {
    flex-shrink: 0;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-danger);
    background: none;
    border: 1px solid var(--color-danger);
    border-radius: 4px;
    padding: 0.3rem 0.75rem;
    cursor: pointer;
    transition: background 0.15s ease;
    min-height: 0;
  }

  .btn-start-fresh:hover {
    background: rgba(229, 57, 53, 0.08);
  }

  /* Resume banner */
  .resume-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-accent);
    border-radius: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .resume-banner-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
  }

  .resume-progress {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .resume-banner-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .resume-discard-btn {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: none;
    border: none;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    min-height: 0;
  }

  .resume-discard-btn:hover {
    color: var(--color-text-primary);
  }

  /* Auto-save reassurance callout */
  .autosave-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    max-width: 100%;
    margin-top: 1.5rem;
    padding: 0.625rem 0.875rem;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .autosave-hint-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .resume-banner-actions {
      width: 100%;
    }

    .resume-banner-actions .btn {
      flex: 1;
    }
  }

  /* Company name field */
  .company-name-hint {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .company-name-input {
    width: 100%;
    max-width: 24rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-primary);
    font-size: 0.9375rem;
    font-family: var(--font-body);
    transition: border-color 0.2s ease-out;
  }

  .company-name-input::placeholder {
    color: var(--color-text-muted);
  }

  .company-name-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  /* Profile questions */
  .profile-question {
    margin-bottom: 2.5rem;
  }

  .question-label {
    font-size: 1.125rem;
    font-family: var(--font-body);
    font-weight: 500;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .options-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem;
  }

  @media (min-width: 640px) {
    .options-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Option cards */
  .option-card {
    padding: 0.875rem 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-family: var(--font-body);
    line-height: 1.5;
    text-align: left;
    cursor: pointer;
    transition: border-color 0.2s ease-out, background 0.2s ease-out, color 0.2s ease-out, transform 0.15s ease-out;
  }

  .option-card:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-hover);
    color: var(--color-text-primary);
  }

  .option-card.selected {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
    color: var(--color-text-primary);
  }

  /* Assessment options — full width stack */
  .options-stack {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .option-assess {
    /* inherits from .option-card */
  }

  /* Domain block */
  .domain-block {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .domain-header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .domain-icon {
    font-size: 1.5rem;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .domain-title {
    font-size: 1.375rem;
    margin-bottom: 0.375rem;
    font-family: var(--font-display);
  }

  .domain-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .assess-question {
    margin-bottom: 2.5rem;
  }

  .question-text {
    font-size: 1rem;
    font-family: var(--font-body);
    font-weight: 500;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  /* Navigation */
  .phase-nav, .domain-nav {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .domain-nav {
    justify-content: flex-end;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease-out;
  }

  .btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover:not(:disabled) {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-hover);
  }

  .btn-secondary:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Analyzing reveal ── */
</style>

<script>
  import { saveProfile, saveScores, setAssessmentCompleted, resetAll, isAssessmentCompleted, getScores, getProfile, savePreviousScores, saveDraft, getDraft, clearDraft } from '../scripts/context-manager.js';
  import { calculateAllDomainScores, calculateOverallScore, determineStage, toDisplayScore } from '../scripts/scoring-engine.js';
  import frameworkData from '../data/lean-cs-data.json';

  const contextParams = frameworkData.context_parameters.parameters;
  const domains = frameworkData.assessment_domains.domains;
  const stages = frameworkData.maturity_stages.stages;

  // State
  const profile: Record<string, string> = {};
  const responses: Record<string, number> = {};
  let currentDomainIdx = 0;
  let isUpdating = false;
  let inAssessmentPhase = false;

  const totalQuestions = contextParams.length + domains.reduce((s: number, d: any) => s + d.questions.length, 0);

  // Elements
  const progressBar = document.getElementById('progress-bar');
  const progressLabel = document.getElementById('progress-label');
  const progressBarWrap = document.getElementById('progress-bar-wrap');
  const phaseProfile = document.getElementById('phase-profile') as HTMLElement;
  const phaseAssessment = document.getElementById('phase-assessment') as HTMLElement;
  const profileNextBtn = document.getElementById('profile-next') as HTMLButtonElement;
  const finishBtn = document.getElementById('finish-assessment');
  const assessIntro = document.querySelector('.assess-intro') as HTMLElement | null;
  const assessStartBtn = document.getElementById('assess-start-btn');

  // Hide the static intro on click so the form takes over the viewport without a route change.
  // Crawlers still see the full intro in the initial HTML; this only affects the in-session view.
  assessStartBtn?.addEventListener('click', () => {
    if (assessIntro) assessIntro.style.display = 'none';
    const banner = document.getElementById('resume-banner');
    if (banner) banner.style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── In-progress draft persistence (resume support) ──
  // Save a lightweight snapshot of partial answers on every change, so a user
  // who leaves mid-assessment can pick up where they left off. Never runs during
  // the update flow (a completed assessment is already saved) or once completed.
  function persistDraft() {
    if (isUpdating || isAssessmentCompleted()) return;
    const companyInput = document.getElementById('company-name-input') as HTMLInputElement;
    const companyName = companyInput?.value.trim() || '';
    if (Object.keys(profile).length === 0 && Object.keys(responses).length === 0 && !companyName) {
      return;
    }
    saveDraft({
      profile: { ...profile },
      responses: { ...responses },
      companyName,
      phase: inAssessmentPhase ? 'assessment' : 'profile',
      domainIdx: currentDomainIdx,
      savedAt: new Date().toISOString(),
    });
  }

  // Apply saved profile/response values to the visible option cards.
  function applyProfileSelectionsToUI() {
    for (const [key, val] of Object.entries(profile)) {
      const btn = document.querySelector(`#profile-form .option-card[data-param="${key}"][data-value="${val}"]`) as HTMLElement | null;
      if (btn) {
        btn.closest('.profile-question')?.querySelectorAll('.option-card').forEach(b => {
          b.classList.remove('selected');
          b.setAttribute('aria-checked', 'false');
        });
        btn.classList.add('selected');
        btn.setAttribute('aria-checked', 'true');
      }
    }
  }

  function applyResponseSelectionsToUI() {
    for (const [qId, score] of Object.entries(responses)) {
      const btn = document.querySelector(`.option-assess[data-question="${qId}"][data-score="${score}"]`) as HTMLElement | null;
      if (btn) {
        btn.closest('.assess-question')?.querySelectorAll('.option-assess').forEach(b => {
          b.classList.remove('selected');
          b.setAttribute('aria-checked', 'false');
        });
        btn.classList.add('selected');
        btn.setAttribute('aria-checked', 'true');
      }
    }
  }

  // ── Restore an in-progress draft and continue where the user left off ──
  function resumeAssessment(draft: any) {
    // Restore company name
    if (draft.companyName) {
      const companyInput = document.getElementById('company-name-input') as HTMLInputElement;
      if (companyInput) companyInput.value = draft.companyName;
    }

    // Restore state
    if (draft.profile && typeof draft.profile === 'object') {
      for (const [key, val] of Object.entries(draft.profile)) profile[key] = val as string;
    }
    if (draft.responses && typeof draft.responses === 'object') {
      for (const [qId, score] of Object.entries(draft.responses)) responses[qId] = score as number;
    }

    applyProfileSelectionsToUI();
    applyResponseSelectionsToUI();

    if (contextParams.every((p: any) => profile[p.id] !== undefined)) {
      profileNextBtn.removeAttribute('disabled');
    }

    // Hide intro + resume banner
    document.querySelectorAll<HTMLElement>('[data-hide-if-assessed]').forEach(el => { el.style.display = 'none'; });
    if (assessIntro) assessIntro.style.display = 'none';
    const banner = document.getElementById('resume-banner');
    if (banner) banner.style.display = 'none';
    if (progressBarWrap) progressBarWrap.style.display = '';

    // Land them on the phase/domain they were on
    if (draft.phase === 'assessment') {
      inAssessmentPhase = true;
      phaseProfile.style.display = 'none';
      phaseAssessment.style.display = '';
      const idx = typeof draft.domainIdx === 'number' && draft.domainIdx >= 0 && draft.domainIdx < domains.length ? draft.domainIdx : 0;
      showDomain(idx);
    } else {
      phaseProfile.style.display = '';
      phaseAssessment.style.display = 'none';
    }

    updateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Pre-populate and start assessment with previous answers ──
  function startAssessmentWithPreviousAnswers() {
    const savedScores = getScores();
    const savedProfile = getProfile();
    const savedResponses = savedScores?.responses || {};

    // Pre-populate company name
    if (savedProfile?.company_name) {
      const companyInput = document.getElementById('company-name-input') as HTMLInputElement;
      if (companyInput) companyInput.value = savedProfile.company_name;
    }

    // Pre-populate profile state and UI
    if (savedProfile) {
      for (const [key, val] of Object.entries(savedProfile)) {
        profile[key] = val as string;
        const btn = document.querySelector(`#profile-form .option-card[data-param="${key}"][data-value="${val}"]`) as HTMLElement | null;
        if (btn) {
          btn.closest('.profile-question')?.querySelectorAll('.option-card').forEach(b => {
            b.classList.remove('selected');
            b.setAttribute('aria-checked', 'false');
          });
          btn.classList.add('selected');
          btn.setAttribute('aria-checked', 'true');
        }
      }
    }

    // Pre-populate responses state and UI
    for (const [qId, score] of Object.entries(savedResponses)) {
      responses[qId] = score as number;
      const btn = document.querySelector(`.option-assess[data-question="${qId}"][data-score="${score}"]`) as HTMLElement | null;
      if (btn) {
        btn.closest('.assess-question')?.querySelectorAll('.option-assess').forEach(b => {
          b.classList.remove('selected');
          b.setAttribute('aria-checked', 'false');
        });
        btn.classList.add('selected');
        btn.setAttribute('aria-checked', 'true');
      }
    }

    // Enable profile continue button if all context params answered
    if (contextParams.every((p: any) => profile[p.id] !== undefined)) {
      profileNextBtn.removeAttribute('disabled');
    }

    // Mark as update flow and reveal "Save & Finish" buttons
    isUpdating = true;
    document.querySelectorAll('.save-finish-btn').forEach(btn => {
      (btn as HTMLElement).style.display = '';
    });

    // Hide intro copy — returning users don't need it
    document.querySelectorAll<HTMLElement>('[data-hide-if-assessed]').forEach(el => { el.style.display = 'none'; });

    // Show the update-flow banner with "Start Fresh" option
    const updateBar = document.getElementById('update-flow-bar');
    if (updateBar) updateBar.style.display = '';

    // Show profile phase
    phaseProfile.style.display = '';
    phaseAssessment.style.display = 'none';
    if (progressBarWrap) progressBarWrap.style.display = '';
    updateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── Start Fresh button (update flow only) ──
  document.getElementById('start-fresh-btn')?.addEventListener('click', () => {
    if (confirm('This will clear all your answers and start from scratch. This cannot be undone. Continue?')) {
      resetAll();
      window.location.href = '/assess/';
    }
  });

  // ── Check if returning user → show results, or jump straight into update flow ──
  if (isAssessmentCompleted()) {
    const savedScores = getScores();
    if (savedScores && savedScores.domainScores && savedScores.overallScore && savedScores.stage) {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('mode') === 'update') {
        startAssessmentWithPreviousAnswers();
      } else {
        window.location.replace('/cs-maturity-report/');
      }
    }
  } else {
    // Not completed — surface a resume banner if an in-progress draft exists.
    maybeShowResumeBanner();
  }

  // ── Resume banner: reveal it when a draft with real progress is present ──
  function maybeShowResumeBanner() {
    const draft = getDraft();
    if (!draft) return;
    const profileCount = draft.profile ? Object.keys(draft.profile).length : 0;
    const responseCount = draft.responses ? Object.keys(draft.responses).length : 0;
    if (profileCount === 0 && responseCount === 0) {
      clearDraft();
      return;
    }
    const answered = profileCount + responseCount;
    const banner = document.getElementById('resume-banner');
    const progressText = document.getElementById('resume-progress-text');
    if (progressText) progressText.textContent = `You answered ${answered} of ${totalQuestions} questions. Pick up where you left off.`;
    if (banner) banner.style.display = '';

    document.getElementById('resume-btn')?.addEventListener('click', () => resumeAssessment(draft));
    document.getElementById('resume-discard-btn')?.addEventListener('click', () => {
      if (confirm('This will discard your in-progress answers and start over. Continue?')) {
        clearDraft();
        window.location.href = '/assess/';
      }
    });
  }

  function updateProgress() {
    const profileAnswered = contextParams.filter((p: any) => profile[p.id] !== undefined).length;
    const answered = profileAnswered + Object.keys(responses).length;
    const pct = Math.round((answered / totalQuestions) * 100);
    if (progressBar) {
      progressBar.style.setProperty('--progress', pct + '%');
      progressBar.setAttribute('aria-valuenow', String(pct));
    }
    if (progressLabel) progressLabel.textContent = `${answered} of ${totalQuestions}`;
  }

  // ── Profile option selection ──
  document.querySelectorAll('#profile-form .option-card').forEach(btn => {
    btn.addEventListener('click', () => {
      const paramId = btn.getAttribute('data-param')!;
      const value = btn.getAttribute('data-value')!;

      btn.closest('.profile-question')?.querySelectorAll('.option-card').forEach(b => {
        b.classList.remove('selected');
        b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('selected');
      btn.setAttribute('aria-checked', 'true');
      profile[paramId] = value;

      if (contextParams.every((p: any) => profile[p.id] !== undefined)) {
        profileNextBtn.removeAttribute('disabled');
      }
      updateProgress();
      persistDraft();
    });
  });

  // ── Company name → persist as part of the draft (debounced) ──
  let companyDraftTimer: ReturnType<typeof setTimeout> | undefined;
  document.getElementById('company-name-input')?.addEventListener('input', () => {
    clearTimeout(companyDraftTimer);
    companyDraftTimer = setTimeout(persistDraft, 400);
  });

  // ── Continue to assessment ──
  profileNextBtn?.addEventListener('click', () => {
    if (!contextParams.every((p: any) => profile[p.id] !== undefined)) return;
    // Hide the intro now if the user reached this point by scrolling past it
    // rather than clicking the Start button. Without this, scrollTo({top:0})
    // dumps subsequent domain transitions at the top of the explainer copy.
    if (assessIntro) assessIntro.style.display = 'none';
    inAssessmentPhase = true;
    phaseProfile.style.display = 'none';
    phaseAssessment.style.display = '';
    showDomain(0);
    window.scrollTo({ top: 0, behavior: 'smooth' });
    persistDraft();
  });

  // ── Assessment option selection ──
  document.querySelectorAll('.option-assess').forEach(btn => {
    btn.addEventListener('click', () => {
      const qId = btn.getAttribute('data-question')!;
      const score = parseInt(btn.getAttribute('data-score')!, 10);

      btn.closest('.assess-question')?.querySelectorAll('.option-assess').forEach(b => {
        b.classList.remove('selected');
        b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('selected');
      btn.setAttribute('aria-checked', 'true');
      responses[qId] = score;

      updateDomainNav();
      updateProgress();
      persistDraft();
    });
  });

  function showDomain(idx: number) {
    currentDomainIdx = idx;
    document.querySelectorAll('.domain-block').forEach((d, i) => {
      (d as HTMLElement).style.display = i === idx ? '' : 'none';
    });
    updateDomainNav();
    window.scrollTo({ top: 0, behavior: 'smooth' });
    persistDraft();
  }

  function updateDomainNav() {
    const domain = domains[currentDomainIdx];
    const allAnswered = domain.questions.every((q: any) => typeof responses[q.id] === 'number');
    const block = document.querySelector(`.domain-block[data-domain-index="${currentDomainIdx}"]`);
    const nextBtn = block?.querySelector('.domain-next') as HTMLButtonElement | null;
    const finBtn = block?.querySelector('#finish-assessment') as HTMLButtonElement | null;
    if (nextBtn) nextBtn.disabled = !allAnswered;
    if (finBtn) finBtn.disabled = !allAnswered;
  }

  // Domain navigation
  document.querySelectorAll('.domain-next').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = parseInt(btn.getAttribute('data-target')!, 10);
      showDomain(target);
    });
  });

  document.querySelectorAll('.domain-prev').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = parseInt(btn.getAttribute('data-target')!, 10);
      showDomain(target);
    });
  });

  // ── Shared finish logic ──
  function finishAndShowResults() {
    const domainScores = calculateAllDomainScores(responses);
    const overallScore = calculateOverallScore(domainScores);
    const stageId = determineStage(overallScore);

    // Save previous scores before overwriting (for re-assessment comparison)
    if (isAssessmentCompleted()) {
      savePreviousScores();
    }

    // Include company name in profile if provided
    const companyInput = document.getElementById('company-name-input') as HTMLInputElement;
    const companyName = companyInput?.value.trim();
    if (companyName) {
      profile['company_name'] = companyName;
    } else {
      delete profile['company_name'];
    }

    // Save to localStorage
    saveProfile(profile);
    saveScores({ domainScores, overallScore, stage: stageId, responses, timestamp: new Date().toISOString() });
    setAssessmentCompleted(true);
    clearDraft();

    const wasUpdating = isUpdating;
    isUpdating = false;

    sessionStorage.setItem('distilledcs_just_assessed', wasUpdating ? 'update' : 'new');
    window.dispatchEvent(new CustomEvent('distilledcs:updated'));
    window.location.replace('/cs-maturity-report/');
  }

  // ── Finish & show results ──
  finishBtn?.addEventListener('click', finishAndShowResults);

  // ── Save & Finish (update flow shortcut) ──
  document.querySelectorAll('.save-finish-btn').forEach(btn => {
    btn.addEventListener('click', finishAndShowResults);
  });

  // Init progress (only if not showing results)
  if (!isAssessmentCompleted()) {
    updateProgress();
    // Reveal the auto-save reassurance in the normal flow (it's misleading in the
    // update flow, where edits aren't drafted, so that path leaves it hidden).
    const autosaveHint = document.getElementById('autosave-hint');
    if (autosaveHint) autosaveHint.style.display = '';
  }
</script>
