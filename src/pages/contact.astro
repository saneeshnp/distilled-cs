---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="How to reach the Distilled CS team for questions, feedback, or contribution suggestions. The framework is open source and built in the open.">

  <div class="container contact-page">

    <header class="page-header">
      <h1 class="page-title">Contact</h1>
      <p class="page-subtitle">
        Have questions, feedback, or want to contribute? We'd love to hear from you.
      </p>
    </header>

    <div class="page-body">
      <section class="content-section">
        <h2>Get in touch</h2>
        <p>
          Distilled CS is an open-source project and we welcome contributions, feedback, and collaboration from the Customer Success community.
        </p>
        <ul class="contact-list">
          <li>
            <strong>GitHub</strong> — <a href="https://github.com/saneeshnp/distilled-cs" target="_blank" rel="noopener noreferrer">Open an issue or start a discussion</a>
          </li>
          <li>
            <strong>LinkedIn</strong> — <a href="https://www.linkedin.com/company/distilled-cs/" target="_blank" rel="noopener noreferrer">Distilled CS on LinkedIn</a>
          </li>
          <li>
            <strong>Email</strong> — coming soon
          </li>
        </ul>
      </section>

      <section class="content-section">
        <h2>Contributing</h2>
        <p>
          Whether it's improving the framework, suggesting new metrics, sharing benchmarks from your experience, or fixing a typo — every contribution matters. Check out our GitHub repository to get started.
        </p>
      </section>

    </div>

  </div>

</BaseLayout>

<style>
  .contact-page {
    padding-block: 3rem 5rem;
    max-width: 42rem;
    margin-inline: auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .page-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .page-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .content-section h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .content-section p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .content-section a {
    color: var(--color-accent);
  }

  .content-section a:hover {
    color: var(--color-accent-hover);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-list li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .contact-list strong {
    color: var(--color-text-primary);
  }

</style>
