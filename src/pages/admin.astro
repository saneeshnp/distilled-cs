---
import BaseLayout from '../layouts/BaseLayout.astro';

const storageKeys = [
  { key: 'distilledcs_profile', label: 'Profile', description: 'Company name, ARR, segment, team size, etc.' },
  { key: 'distilledcs_scores', label: 'Scores', description: 'Domain scores, overall score, stage, responses' },
  { key: 'distilledcs_completed', label: 'Completed', description: 'Whether assessment has been completed' },
  { key: 'distilledcs_checklist', label: 'Checklist', description: 'Execution checklist progress' },
  { key: 'distilledcs_previous_scores', label: 'Previous Scores', description: 'Saved before re-assessment for comparison' },
  { key: 'distilledcs_preview_seen', label: 'Preview Seen', description: 'Homepage preview modal dismissed' },
  { key: 'distilledcs_theme', label: 'Theme', description: 'Light or dark mode preference' },
];

const sessionKeys = [
  { key: 'distilledcs_bar_dismissed', label: 'Bar Dismissed', description: 'Context bar dismissed this session' },
  { key: 'distilledcs_banner_dismissed', label: 'Banner Dismissed', description: 'Preview banner dismissed this session' },
];
---

<BaseLayout title="Debug Tools" description="Developer tools for testing localStorage state." noindex>
  <div class="container debug-page">

    <div class="debug-header">
      <h1 class="debug-title">Debug Tools</h1>
      <p class="debug-subtitle">Note: This page/feature is not for end users. It is intended for developers and debugging only. Using this may break functionality and result in loss of any existing assessment data for this session.</p>
    </div>

    <!-- Locked state -->
    <div class="debug-locked" id="debug-locked">
      <p class="locked-message">Debug tools are not enabled. Add <code>?debug-enabled=true</code> to the URL to access.</p>
    </div>

    <!-- Unlocked content (hidden by default) -->
    <div id="debug-content" style="display:none;">

    <!-- Quick State Overview -->
    <section class="debug-section">
      <h2 class="section-heading">Current State</h2>
      <div class="state-grid" id="state-grid">
        <div class="state-card">
          <span class="state-label">Assessment</span>
          <span class="state-value" id="state-completed">—</span>
        </div>
        <div class="state-card">
          <span class="state-label">Stage</span>
          <span class="state-value" id="state-stage">—</span>
        </div>
        <div class="state-card">
          <span class="state-label">Score</span>
          <span class="state-value" id="state-score">—</span>
        </div>
        <div class="state-card">
          <span class="state-label">Company</span>
          <span class="state-value" id="state-company">—</span>
        </div>
        <div class="state-card">
          <span class="state-label">Profile</span>
          <span class="state-value" id="state-profile">—</span>
        </div>
        <div class="state-card">
          <span class="state-label">Checklist</span>
          <span class="state-value" id="state-checklist">—</span>
        </div>
      </div>
    </section>

    <!-- Quick Presets -->
    <section class="debug-section">
      <h2 class="section-heading">Quick Presets</h2>
      <p class="section-desc">One-click to set a test state. Page reloads after applying.</p>
      <div class="presets-grid">
        <button class="preset-btn preset-clear" id="preset-fresh" type="button">Fresh User</button>
        <button class="preset-btn preset-crawl" id="preset-crawl" type="button">Crawl Stage</button>
        <button class="preset-btn preset-walk" id="preset-walk" type="button">Walk Stage</button>
        <button class="preset-btn preset-run" id="preset-run" type="button">Run Stage</button>
        <button class="preset-btn preset-fly" id="preset-fly" type="button">Fly Stage</button>
        <button class="preset-btn" id="preset-no-company" type="button">Without Company Name</button>
      </div>
    </section>

    <!-- Raw Key Editor -->
    <section class="debug-section">
      <h2 class="section-heading">localStorage Keys</h2>
      <div class="keys-list" id="keys-list">
        {storageKeys.map(({ key, label, description }) => (
          <div class="key-row" data-key={key}>
            <div class="key-header">
              <div>
                <span class="key-name">{label}</span>
                <span class="key-code">{key}</span>
                <span class="key-desc">{description}</span>
              </div>
              <div class="key-actions">
                <button class="key-btn key-btn-edit" data-action="edit" data-key={key} type="button">Edit</button>
                <button class="key-btn key-btn-delete" data-action="delete" data-key={key} type="button">Delete</button>
              </div>
            </div>
            <div class="key-value-display" data-display={key}>
              <pre><code>—</code></pre>
            </div>
            <div class="key-editor" data-editor={key} style="display:none;">
              <textarea class="key-textarea" data-textarea={key} rows="6" spellcheck="false"></textarea>
              <div class="editor-actions">
                <button class="key-btn key-btn-save" data-action="save" data-key={key} type="button">Save</button>
                <button class="key-btn key-btn-cancel" data-action="cancel" data-key={key} type="button">Cancel</button>
              </div>
            </div>
          </div>
        ))}
      </div>

      <h2 class="section-heading" style="margin-top:2rem;">sessionStorage Keys</h2>
      <div class="keys-list" id="session-keys-list">
        {sessionKeys.map(({ key, label, description }) => (
          <div class="key-row" data-session-key={key}>
            <div class="key-header">
              <div>
                <span class="key-name">{label}</span>
                <span class="key-code">{key}</span>
                <span class="key-desc">{description}</span>
              </div>
              <div class="key-actions">
                <button class="key-btn key-btn-delete" data-action="delete-session" data-key={key} type="button">Delete</button>
              </div>
            </div>
            <div class="key-value-display" data-session-display={key}>
              <pre><code>—</code></pre>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Bulk Actions -->
    <section class="debug-section">
      <h2 class="section-heading">Bulk Actions</h2>
      <div class="bulk-actions">
        <button class="preset-btn preset-clear" id="action-clear-all" type="button">Clear All localStorage</button>
        <button class="preset-btn" id="action-export" type="button">Export State to Clipboard</button>
        <button class="preset-btn" id="action-import" type="button">Import State from Clipboard</button>
      </div>
    </section>

    </div><!-- /debug-content -->

  </div>
</BaseLayout>

<style>
  .debug-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 56rem;
    margin-inline: auto;
  }

  .debug-header {
    margin-bottom: 2rem;
  }

  .debug-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .debug-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    background: yellow;
    padding: 5px;
    border-radius: 5px;
  }

  .debug-section {
    margin-bottom: 2.5rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .section-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  /* State overview */
  .state-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .state-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .state-card {
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .state-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .state-value {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-primary);
    word-break: break-word;
  }

  /* Presets */
  .presets-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .preset-btn {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    border: 1px solid var(--color-border-hover);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    transition: all 0.2s ease-out;
  }

  .preset-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .preset-clear {
    border-color: var(--color-stage-crawl);
    color: var(--color-stage-crawl);
  }

  .preset-clear:hover {
    background: color-mix(in srgb, var(--color-stage-crawl) 10%, transparent);
    border-color: var(--color-stage-crawl);
    color: var(--color-stage-crawl);
  }

  .preset-crawl { border-color: var(--color-stage-crawl); color: var(--color-stage-crawl); }
  .preset-walk { border-color: var(--color-stage-walk); color: var(--color-stage-walk); }
  .preset-run { border-color: var(--color-stage-run); color: var(--color-stage-run); }
  .preset-fly { border-color: var(--color-stage-fly); color: var(--color-stage-fly); }

  /* Key editor */
  .keys-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .key-row {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .key-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 0.75rem 1rem;
    gap: 1rem;
  }

  .key-name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text-primary);
    display: block;
  }

  .key-code {
    font-family: monospace;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 0.125rem;
  }

  .key-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 0.25rem;
  }

  .key-actions {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .key-btn {
    padding: 0.25rem 0.625rem;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    transition: all 0.15s ease-out;
  }

  .key-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .key-btn-delete:hover {
    border-color: var(--color-stage-crawl);
    color: var(--color-stage-crawl);
  }

  .key-btn-save {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .key-btn-save:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--color-bg);
  }

  .key-value-display {
    padding: 0 1rem 0.75rem;
  }

  .key-value-display pre {
    margin: 0;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    overflow-x: auto;
    font-size: 0.75rem;
    line-height: 1.5;
    max-height: 8rem;
    overflow-y: auto;
  }

  .key-value-display code {
    color: var(--color-text-secondary);
    font-family: monospace;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .key-editor {
    padding: 0 1rem 0.75rem;
  }

  .key-textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: 0.375rem;
    font-family: monospace;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-text-primary);
    resize: vertical;
  }

  .key-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .editor-actions {
    display: flex;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  /* Bulk actions */
  .bulk-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Toast notification */
  :global(.debug-toast) {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: var(--font-body);
    z-index: 1000;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease-out, transform 0.25s ease-out;
  }

  :global(.debug-toast.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  /* Locked state */
  .debug-locked {
    text-align: center;
    padding: 4rem 2rem;
  }

  .locked-message {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .locked-message code {
    font-family: monospace;
    font-size: 0.8125rem;
    padding: 0.15rem 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-text-secondary);
  }
</style>

<script>
  // ── Gate: require ?debug-enabled=true ──
  const debugEnabled = new URLSearchParams(window.location.search).get('debug-enabled') === 'true';
  const lockedEl = document.getElementById('debug-locked');
  const contentEl = document.getElementById('debug-content');

  if (debugEnabled) {
    if (lockedEl) lockedEl.style.display = 'none';
    if (contentEl) contentEl.style.display = '';
  } else {
    if (lockedEl) lockedEl.style.display = '';
    if (contentEl) contentEl.style.display = 'none';
  }

  // ── Preset data ──
  const presetProfile = {
    company_name: 'Acme',
    company_arr: 'arr_5m_20m',
    customer_segment: 'seg_midmarket',
    industry: 'b2b_saas',
    product_complexity: 'moderate',
    cs_tenure: '1_3yr',
    cs_team_size: 'size_4_10',
    cs_ops: 'part_time',
  };

  const presetResponses: Record<string, number> = {};
  // We don't need real question IDs for presets; scores are what matter

  function makeScores(stage: string, score: number) {
    const domainScore = score;
    return {
      domainScores: {
        segmentation_coverage: domainScore,
        journey_lifecycle: domainScore,
        health_scoring_risk: domainScore,
        metrics_data: domainScore,
        expansion_value: domainScore,
        org_strategy: domainScore,
        cs_culture_alignment: domainScore,
      },
      overallScore: score,
      stage,
      responses: {},
      timestamp: new Date().toISOString(),
    };
  }

  const presets: Record<string, { profile: any; scores: any }> = {
    crawl: { profile: { ...presetProfile }, scores: makeScores('crawl', 1.4) },
    walk:  { profile: { ...presetProfile }, scores: makeScores('walk', 2.2) },
    run:   { profile: { ...presetProfile }, scores: makeScores('run', 3.0) },
    fly:   { profile: { ...presetProfile }, scores: makeScores('fly', 3.8) },
  };

  // ── Toast ──
  function showToast(message: string) {
    let toast = document.querySelector('.debug-toast') as HTMLElement;
    if (!toast) {
      toast = document.createElement('div');
      toast.className = 'debug-toast';
      document.body.appendChild(toast);
    }
    toast.textContent = message;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2000);
  }

  // ── Refresh state overview ──
  function refreshState() {
    try {
      const completed = localStorage.getItem('distilledcs_completed') === 'true';
      const scoresRaw = localStorage.getItem('distilledcs_scores');
      const profileRaw = localStorage.getItem('distilledcs_profile');
      const checklistRaw = localStorage.getItem('distilledcs_checklist');
      const scores = scoresRaw ? JSON.parse(scoresRaw) : null;
      const profile = profileRaw ? JSON.parse(profileRaw) : null;
      const checklist = checklistRaw ? JSON.parse(checklistRaw) : {};

      const el = (id: string) => document.getElementById(id);

      el('state-completed')!.textContent = completed ? 'Yes' : 'No';
      el('state-stage')!.textContent = scores?.stage ? scores.stage.charAt(0).toUpperCase() + scores.stage.slice(1) : 'Not set';
      el('state-score')!.textContent = scores?.overallScore != null ? `${scores.overallScore} / 4.0` : 'Not set';
      el('state-company')!.textContent = profile?.company_name || 'Not set';

      const optionLabels: Record<string, string> = {
        arr_under_5m: 'Under $5M', arr_5m_20m: '$5M-$20M', arr_20m_100m: '$20M-$100M', arr_over_100m: 'Over $100M',
        seg_smb: 'SMB', seg_midmarket: 'Mid-Market', seg_enterprise: 'Enterprise', seg_mixed: 'Mixed',
        size_1_3: '1-3', size_4_10: '4-10', size_11_25: '11-25', size_over_25: '25+',
      };
      const parts = [optionLabels[profile?.company_arr], optionLabels[profile?.customer_segment], optionLabels[profile?.cs_team_size]].filter(Boolean);
      el('state-profile')!.textContent = parts.length > 0 ? parts.join(' / ') : 'Not set';

      const total = Object.keys(checklist).length;
      const done = Object.values(checklist).filter(Boolean).length;
      el('state-checklist')!.textContent = total > 0 ? `${done} / ${total}` : 'No items';
    } catch {
      // ignore
    }
  }

  // ── Refresh key displays ──
  const storageKeys = [
    'distilledcs_profile', 'distilledcs_scores', 'distilledcs_completed',
    'distilledcs_checklist', 'distilledcs_previous_scores', 'distilledcs_preview_seen',
    'distilledcs_theme',
  ];

  const sessionKeysList = ['distilledcs_bar_dismissed', 'distilledcs_banner_dismissed'];

  function refreshKeyDisplays() {
    for (const key of storageKeys) {
      const display = document.querySelector(`[data-display="${key}"] code`);
      if (!display) continue;
      try {
        const raw = localStorage.getItem(key);
        if (raw === null) {
          display.textContent = '(not set)';
        } else {
          try {
            display.textContent = JSON.stringify(JSON.parse(raw), null, 2);
          } catch {
            display.textContent = raw;
          }
        }
      } catch {
        display.textContent = '(error reading)';
      }
    }

    for (const key of sessionKeysList) {
      const display = document.querySelector(`[data-session-display="${key}"] code`);
      if (!display) continue;
      try {
        const raw = sessionStorage.getItem(key);
        display.textContent = raw === null ? '(not set)' : raw;
      } catch {
        display.textContent = '(error reading)';
      }
    }
  }

  // ── Apply preset ──
  function applyPreset(stage: string) {
    const preset = presets[stage];
    localStorage.setItem('distilledcs_profile', JSON.stringify(preset.profile));
    localStorage.setItem('distilledcs_scores', JSON.stringify(preset.scores));
    localStorage.setItem('distilledcs_completed', 'true');
    showToast(`Set to ${stage.charAt(0).toUpperCase() + stage.slice(1)} stage`);
    refreshState();
    refreshKeyDisplays();
  }

  // ── Preset buttons ──
  document.getElementById('preset-fresh')?.addEventListener('click', () => {
    storageKeys.forEach(k => { try { localStorage.removeItem(k); } catch {} });
    try { localStorage.removeItem('distilledcs_checklist'); } catch {}
    sessionKeysList.forEach(k => { try { sessionStorage.removeItem(k); } catch {} });
    showToast('Cleared all state');
    refreshState();
    refreshKeyDisplays();
  });

  document.getElementById('preset-crawl')?.addEventListener('click', () => applyPreset('crawl'));
  document.getElementById('preset-walk')?.addEventListener('click', () => applyPreset('walk'));
  document.getElementById('preset-run')?.addEventListener('click', () => applyPreset('run'));
  document.getElementById('preset-fly')?.addEventListener('click', () => applyPreset('fly'));

  document.getElementById('preset-no-company')?.addEventListener('click', () => {
    try {
      const raw = localStorage.getItem('distilledcs_profile');
      if (raw) {
        const profile = JSON.parse(raw);
        delete profile.company_name;
        localStorage.setItem('distilledcs_profile', JSON.stringify(profile));
        showToast('Removed company name');
        refreshState();
        refreshKeyDisplays();
      } else {
        showToast('No profile to modify');
      }
    } catch {
      showToast('Error modifying profile');
    }
  });

  // ── Key edit/delete/save/cancel ──
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement;
    if (!btn) return;

    const action = btn.getAttribute('data-action');
    const key = btn.getAttribute('data-key');
    if (!key) return;

    if (action === 'edit') {
      const editor = document.querySelector(`[data-editor="${key}"]`) as HTMLElement;
      const display = document.querySelector(`[data-display="${key}"]`) as HTMLElement;
      const textarea = document.querySelector(`[data-textarea="${key}"]`) as HTMLTextAreaElement;
      if (!editor || !display || !textarea) return;

      const raw = localStorage.getItem(key);
      try {
        textarea.value = raw ? JSON.stringify(JSON.parse(raw), null, 2) : '';
      } catch {
        textarea.value = raw || '';
      }
      display.style.display = 'none';
      editor.style.display = '';
    }

    if (action === 'cancel') {
      const editor = document.querySelector(`[data-editor="${key}"]`) as HTMLElement;
      const display = document.querySelector(`[data-display="${key}"]`) as HTMLElement;
      if (editor) editor.style.display = 'none';
      if (display) display.style.display = '';
    }

    if (action === 'save') {
      const textarea = document.querySelector(`[data-textarea="${key}"]`) as HTMLTextAreaElement;
      const editor = document.querySelector(`[data-editor="${key}"]`) as HTMLElement;
      const display = document.querySelector(`[data-display="${key}"]`) as HTMLElement;
      if (!textarea) return;

      const value = textarea.value.trim();
      try {
        if (value) {
          // Validate JSON for object keys
          if (value.startsWith('{') || value.startsWith('[')) JSON.parse(value);
          localStorage.setItem(key, value);
        } else {
          localStorage.removeItem(key);
        }
        showToast(`Saved ${key}`);
        if (editor) editor.style.display = 'none';
        if (display) display.style.display = '';
        refreshState();
        refreshKeyDisplays();
      } catch (err) {
        showToast('Invalid JSON');
      }
    }

    if (action === 'delete') {
      try { localStorage.removeItem(key); } catch {}
      showToast(`Deleted ${key}`);
      refreshState();
      refreshKeyDisplays();
    }

    if (action === 'delete-session') {
      try { sessionStorage.removeItem(key); } catch {}
      showToast(`Deleted ${key}`);
      refreshKeyDisplays();
    }
  });

  // ── Bulk actions ──
  document.getElementById('action-clear-all')?.addEventListener('click', () => {
    if (!confirm('Clear all distilledcs_* localStorage and sessionStorage keys?')) return;
    storageKeys.forEach(k => { try { localStorage.removeItem(k); } catch {} });
    try { localStorage.removeItem('distilledcs_checklist'); } catch {}
    sessionKeysList.forEach(k => { try { sessionStorage.removeItem(k); } catch {} });
    showToast('All state cleared');
    refreshState();
    refreshKeyDisplays();
  });

  document.getElementById('action-export')?.addEventListener('click', () => {
    const exported: Record<string, any> = {};
    for (const key of storageKeys) {
      try {
        const raw = localStorage.getItem(key);
        if (raw !== null) exported[key] = raw;
      } catch {}
    }
    navigator.clipboard.writeText(JSON.stringify(exported, null, 2))
      .then(() => showToast('Copied to clipboard'))
      .catch(() => showToast('Failed to copy'));
  });

  document.getElementById('action-import')?.addEventListener('click', async () => {
    try {
      const text = await navigator.clipboard.readText();
      const data = JSON.parse(text);
      for (const [key, value] of Object.entries(data)) {
        if (key.startsWith('distilledcs_')) {
          localStorage.setItem(key, value as string);
        }
      }
      showToast('State imported');
      refreshState();
      refreshKeyDisplays();
    } catch {
      showToast('Failed to import. Check clipboard has valid JSON.');
    }
  });

  // ── Init ──
  refreshState();
  refreshKeyDisplays();
</script>
