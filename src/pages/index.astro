---
import BaseLayout from '../layouts/BaseLayout.astro';
import frameworkData from '../data/lean-cs-data.json';

const strategyLoop = frameworkData.strategy_loop;
const stages = frameworkData.maturity_stages.stages;
const principles = frameworkData.principles;

const phaseDetails: Record<string, string[]> = {
  assess: [
    'Answer a few questions across key areas of your CS practice',
    'Find out your maturity stage — Crawl, Walk, or Run',
    'Get a full report with domain scores and a prioritised action list',
  ],
  execute: [
    'Access playbooks built for your exact maturity stage',
    'Track the metrics that matter most right now',
    'Work through a checklist of the highest-impact actions',
  ],
  transform: [
    'See what has improved since you started',
    'Re-take the assessment to measure your growth',
    'Get a guide for moving up to your next stage',
  ],
};

const stageImageAlts: Record<string, string> = {
  crawl: 'Stick figure crawling, representing the Crawl stage of the customer success maturity model, a reactive and foundational phase',
  walk: 'Stick figure walking, representing the Walk stage of the customer success maturity model, where structure begins to form',
  run: 'Stick figure running, representing the Run stage of the customer success maturity model, where CS becomes predictive and operationalized',
};
---

<BaseLayout title="Customer Success Strategy & Maturity Framework" description="Open, vendor-neutral framework to assess your customer success maturity, get prescriptive playbooks, and track the metrics that move retention.">

  <!-- Section 1: Hero -->
  <section class="hp-hero" id="hero-section">
    <div class="hp-hero-inner">
      <!-- Left column: Text -->
      <div class="hp-hero-text" id="hp-hero-text">
        <h1 class="hp-hero-headline">
          An open framework to assess your <strong style="color: var(--color-accent); font-weight: 700;">Customer Success</strong>  maturity and rebuild your strategy.
        </h1>
        <p class="hp-hero-sub">
        With Distilled CS, you can quickly identify where you are in your customer success journey and get a clear strategy for moving forward.
        </p>
        <div class="hp-hero-ctas">
          <a href="/assess/" class="btn btn-primary" id="hp-hero-cta-primary" data-contextual="hero-cta">Take the Assessment</a>
          <a href="#how-it-works" class="btn btn-secondary">See how it works</a>
        </div>
      </div>

      <!-- Right column: Animated triangle loop — a liquid-flow dash travels the perimeter, pulsing each node as it passes -->
      <div class="hp-hero-visual" id="hp-hero-visual">
        <svg class="hp-loop-svg" viewBox="-20 -40 340 340" role="img" aria-labelledby="hp-loop-title hp-loop-desc">
          <title id="hp-loop-title">Strategy Loop: Assess, Execute, Transform</title>
          <desc id="hp-loop-desc">A continuous improvement cycle. Assess flows to Execute, Execute flows to Transform, and Transform loops back to Assess.</desc>

          <polygon points="150,20 280,240 20,240" class="hp-loop-track" pathLength="100" />
          <polygon points="150,20 280,240 20,240" class="hp-loop-flow" pathLength="100" />

          <g transform="translate(150, 160)">
            <text x="0" y="0" text-anchor="middle" class="hp-loop-center"><tspan>Distilled</tspan><tspan class="hp-loop-center-accent">CS</tspan></text>
            <text x="0" y="20" text-anchor="middle" class="hp-loop-center-subtitle">Framework</text>
          </g>

          <g transform="translate(150, 20)" class="hp-loop-node hp-loop-node--1">
            <circle r="16" class="hp-loop-node-outer" />
            <circle r="11" class="hp-loop-node-inner" />
            <text x="0" y="-25" text-anchor="middle" class="hp-loop-node-text">ASSESS</text>
          </g>

          <g transform="translate(280, 240)" class="hp-loop-node hp-loop-node--2">
            <circle r="16" class="hp-loop-node-outer" />
            <circle r="11" class="hp-loop-node-inner" />
            <text x="0" y="35" text-anchor="middle" class="hp-loop-node-text">EXECUTE</text>
          </g>

          <g transform="translate(20, 240)" class="hp-loop-node hp-loop-node--3">
            <circle r="16" class="hp-loop-node-outer" />
            <circle r="11" class="hp-loop-node-inner" />
            <text x="0" y="35" text-anchor="middle" class="hp-loop-node-text">TRANSFORM</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- Section 2: How it works -->
  <section class="hp-section hp-section-loop" id="how-it-works">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">How it works</h2>
      <p class="hp-section-subheadline scroll-reveal">The Distilled CS framework follows three steps: understand where you are, execute strategies tailored to your stage, and measure progress to keep improving as your CS team grows.</p>

      <div class="hp-how-grid">
        {strategyLoop.phases.map((phase, i) => (
          <div class="hp-how-card scroll-reveal" style={`--reveal-delay: ${i * 0.1}s`}>
            <span class="hp-how-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="hp-how-title">{phase.label}</h3>
            <p class="hp-how-tagline">{phase.tagline}</p>
            <ul class="hp-how-list">
              {(phaseDetails[phase.id] ?? []).map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="hp-section-cta scroll-reveal">
        <a href="/assess/" class="btn btn-primary" id="hp-how-cta">Take the Assessment</a>
      </div>
    </div>
  </section>

  <!-- Section 3: Maturity Stages -->
  <section class="hp-section hp-section-stages" id="maturity-stages">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">The three stages of CS maturity</h2>
      <p class="hp-section-subheadline scroll-reveal">Every CS team sits somewhere on this scale. The assessment tells you exactly where, and what to focus on from there.</p>
      <div class="hp-stages-grid">
        {stages.map((stage, i) => (
          <div class={`hp-stage-card scroll-reveal stage-${stage.id}`} style={`--stage-delay: ${i * 0.1}s`}>
            <div class="hp-stage-color-bar"></div>
            <div class="hp-stage-pill-row">
              <span class="hp-stage-pill">Stage {i + 1}</span>
              <span class="hp-stage-label">{stage.label}</span>
            </div>
            <div class="hp-stage-card-img">
              <img
                src={`/images/maturity-stages/cs-maturity-stage-${stage.id}.png`}
                alt={stageImageAlts[stage.id]}
                width="610"
                height="404"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="hp-stage-card-content">
              <span class="hp-stage-subtitle">{stage.subtitle}</span>
              <ul class="hp-stage-chars">
                {stage.key_characteristics.slice(0, 4).map(char => (
                  <li>{char}</li>
                ))}
              </ul>
              <a href={`/customer-success-maturity-model/#stage-${stage.id}`} class="hp-stage-more-link">
                See the full {stage.label} stage overview <span class="hp-stage-more-arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        ))}
      </div>
      <div class="hp-section-cta scroll-reveal">
        <a href="/customer-success-maturity-model/" class="btn btn-primary">Explore the full maturity model</a>
      </div>
    </div>
  </section>

  <!-- Section 4: Principles -->
  <section class="hp-section hp-section-principles" id="principles">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">Built on seven guiding principles</h2>
      <p class="hp-section-subheadline scroll-reveal">The beliefs that shape every recommendation, metric, and benchmark in the framework.</p>
      <div class="hp-principles-grid">
        {principles.map((p, i) => (
          <div class="hp-principle-card scroll-reveal" style={`--reveal-delay: ${i * 0.06}s`}>
            <span class="hp-principle-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="hp-principle-title">{p.title}</h3>
            <p class="hp-principle-summary">{p.summary}</p>
          </div>
        ))}
      </div>
      <div class="hp-section-cta scroll-reveal">
        <a href="/customer-success-principles/" class="btn btn-secondary">Read all principles</a>
      </div>
    </div>
  </section>

  <!-- Section 5: Open & Vendor-Neutral -->
  <section class="hp-section hp-section-open" id="open-source">
    <div class="container">
      <div class="hp-open-content scroll-reveal">
        <h2 class="hp-section-headline">Open source. Vendor neutral. Community driven.</h2>
        <p class="hp-open-body">
          Distilled CS is an open source Customer Success framework created for practitioners, by practitioners. The community can openly contribute, refine, and evolve the framework over time, helping establish a shared language for Customer Success teams everywhere.
        </p>
        <p class="hp-open-body">
          The framework is vendor neutral and designed to work alongside any tool stack, giving teams a consistent way to assess maturity and measure progress without lock-in or restrictions.
        </p>
        <p class="hp-open-body">Distilled CS is freely available under the CC BY-SA 4.0 license.</p>
        <p class="hp-open-body hp-open-emphasis">Built by practitioners, for practitioners.</p>
        <a href="https://github.com/saneeshnp/distilled-cs" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Contribute on GitHub</a>
        <a href="/contribute/" class="hp-open-contribute-link">How to contribute →</a>
      </div>
    </div>
  </section>

  <!-- Section 5.5: What to read next -->
  <section class="hp-section hp-section-read-next" id="read-next">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">What to read next</h2>
      <p class="hp-section-subheadline scroll-reveal">Five places to start, depending on what you need.</p>
      <div class="hp-read-next-grid">
        <a href="/customer-success-principles/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Principles</span>
          <span class="hp-read-next-title">Customer Success Principles</span>
          <span class="hp-read-next-body">Six beliefs that shape every recommendation in the framework.</span>
        </a>
        <a href="/customer-success-metrics/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Metrics</span>
          <span class="hp-read-next-title">Customer Success Metrics</span>
          <span class="hp-read-next-body">Sixteen metrics with formulas, benchmarks, and stage-by-stage priority.</span>
        </a>
        <a href="/customer-success-playbooks/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Playbooks</span>
          <span class="hp-read-next-title">Customer Success Playbooks</span>
          <span class="hp-read-next-body">Fourteen action plans grouped by maturity stage, each with steps and pitfalls.</span>
        </a>
        <a href="/customer-success-maturity-model/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Model</span>
          <span class="hp-read-next-title">Customer Success Maturity Model</span>
          <span class="hp-read-next-body">Three stages from Crawl to Run, with the capabilities that define each.</span>
        </a>
        <a href="/assess/" class="hp-read-next-card scroll-reveal" id="hp-read-next-assess">
          <span class="hp-read-next-eyebrow">Assessment</span>
          <span class="hp-read-next-title" id="hp-read-next-assess-title">Take the Maturity Assessment</span>
          <span class="hp-read-next-body" id="hp-read-next-assess-body">A few questions across eight domains. Get a stage and a priority list.</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 6: Final CTA -->
  <section class="hp-section hp-section-final-cta" id="get-started">
    <div class="container">
      <div class="hp-final-cta-inner scroll-reveal">
        <h2 class="hp-final-cta-headline" id="hp-final-cta-headline">Find out where your CS team stands</h2>
        <a href="/assess/" class="btn btn-primary btn-large" id="hp-final-cta-btn">Take the Assessment</a>
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  /* ══════════════════════════════════════════
     HERO
     ══════════════════════════════════════════ */
  /* ──────────────────────────────────────────
     HERO BACKGROUND
     ──────────────────────────────────────────
     Light mode: subtle diagonal line pattern layered over a soft neutral
     radial glow — evokes clean daylight without any raster image.
     Dark mode : night-sky gradient with 15 CSS-drawn stars, easing down
     into a muted steel-blue at the base (no sunset / no orange).
     Both are pure CSS — 0 KB, 0 network requests, theme-swaps instantly. */
  .hp-hero {
    position: relative;
    display: flex;
    align-items: center;
    padding: 4.5rem 1.5rem 5.5rem;
    overflow: hidden;
    /* Light-mode layers (top → bottom of the background stack):
       1. Diagonal line pattern (very faint, ~5% opacity, 28px spacing)
       2. Soft neutral radial glow centered top for "daylight" feel
       3. Accent-tinted ambient radial
       4. Base off-white color */
    background:
      repeating-linear-gradient(
        135deg,
        rgba(45, 106, 90, 0.05) 0 1px,
        transparent 1px 28px
      ),
      radial-gradient(
        ellipse 90% 70% at 50% -10%,
        rgba(255, 255, 255, 0.6) 0%,
        rgba(255, 255, 255, 0) 60%
      ),
      radial-gradient(
        ellipse at 50% 40%,
        color-mix(in srgb, var(--color-accent) 5%, transparent) 0%,
        transparent 65%
      ),
      #fbfaf7;
  }

  /* Dark-mode override: night sky with stars, easing into muted steel-blue.
     Top 0–45%:  near-black with faint greenish tint (deep night)
     45–68%:     deep navy / indigo emerging
     68–88%:     rising mid-blue
     88–100%:    muted steel-blue at the base */
  :root[data-theme="dark"] .hp-hero {
    background:
      /* Star-field: 15 dots at 2–3px, distributed across the upper ~45% of
         the hero. Higher opacities so they read clearly against the dark sky. */
      radial-gradient(2.5px 2.5px at  9%  7%, rgba(255,255,255,0.95), transparent 60%),
      radial-gradient(3px 3px     at 24%  5%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(3px 3px     at 38% 10%, rgba(255,255,255,0.95), transparent 60%),
      radial-gradient(2.5px 2.5px at 52%  6%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(3px 3px     at 66% 14%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(2.5px 2.5px at 80% 17%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(3px 3px     at 93% 11%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(2.5px 2.5px at 16% 22%, rgba(255,255,255,0.8),  transparent 60%),
      radial-gradient(3px 3px     at 34% 27%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(2px 2px     at 48% 20%, rgba(255,255,255,0.75), transparent 60%),
      radial-gradient(2.5px 2.5px at 60% 32%, rgba(255,255,255,0.75), transparent 60%),
      radial-gradient(3px 3px     at 74% 28%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(2.5px 2.5px at 87% 35%, rgba(255,255,255,0.7),  transparent 60%),
      radial-gradient(2.5px 2.5px at 22% 40%, rgba(255,255,255,0.7),  transparent 60%),
      radial-gradient(2px 2px     at 56% 43%, rgba(255,255,255,0.65), transparent 60%),
      /* Main vertical sky gradient */
      linear-gradient(
        to bottom,
        #0a0d0a  0%,
        #0a0e0d 22%,
        #0b1210 42%,
        #0c1a22 55%,
        #0f2a40 68%,
        #163c5c 82%,
        #1d4e6e 92%,
        #22587a 100%
      );
  }

  .hp-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .hp-hero-inner {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }
  }

  /* ── Hero text column ── */
  .hp-hero-text {
    flex: 1;
    opacity: 0;
    transform: translateY(24px);
    max-width: 38rem;
  }

  @media (min-width: 1024px) {
    .hp-hero-text {
      max-width: none;
    }
  }

  .hp-hero-headline {
    font-size: clamp(1.625rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    color: var(--color-text-primary);
  }

  .hp-hero-sub {
    font-size: clamp(0.9375rem, 1.3vw, 1.0625rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 32rem;
  }

  .hp-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ── Hero visual column ── */
  .hp-hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    max-width: 340px;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hp-hero-visual {
      max-width: 400px;
    }
  }

  /* ── Strategy Loop SVG ──
     Triangular track with a "liquid flow" of dashes traveling the perimeter.
     Each corner node pulses as the flow passes over it. */
  .hp-loop-svg {
    --hp-loop-duration: 10s;
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .hp-loop-track {
    stroke: var(--color-border);
    stroke-width: 4;
    fill: none;
    stroke-linejoin: round;
  }

  .hp-loop-flow {
    stroke: var(--color-accent);
    stroke-width: 6;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 20 80;
    animation: hp-loop-flow var(--hp-loop-duration) linear infinite;
    filter: drop-shadow(0 0 8px var(--color-accent-subtle));
  }

  @keyframes hp-loop-flow {
    0% { stroke-dashoffset: 20; }
    100% { stroke-dashoffset: -80; }
  }

  .hp-loop-center {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 26px;
    fill: var(--color-text-primary);
    letter-spacing: -0.02em;
    user-select: none;
  }

  .hp-loop-center-accent {
    fill: var(--color-accent);
  }

  .hp-loop-center-subtitle {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    fill: var(--color-text-muted);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    user-select: none;
  }

  .hp-loop-node-text {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.16em;
    fill: var(--color-text-muted);
    user-select: none;
  }

  /* Dark hero gradient swallows the muted grey — bump to secondary for legibility. */
  :root[data-theme="dark"] .hp-loop-node-text {
    fill: var(--color-text-secondary);
  }

  .hp-loop-node-outer {
    fill: var(--color-surface);
    stroke: var(--color-accent);
    stroke-width: 4;
  }

  .hp-loop-node-inner {
    fill: var(--color-accent);
  }

  /* Each node pulses (r:11 → r:16) as the flow reaches its corner. Timed in
     thirds of the cycle so the pulse is centered on the moment the dash arrives. */
  .hp-loop-node--1 .hp-loop-node-inner { animation: hp-loop-pulse-1 var(--hp-loop-duration) linear infinite; }
  @keyframes hp-loop-pulse-1 {
    0% { r: 11; }
    7%, 13% { r: 16; }
    20%, 100% { r: 11; }
  }

  .hp-loop-node--2 .hp-loop-node-inner { animation: hp-loop-pulse-2 var(--hp-loop-duration) linear infinite; }
  @keyframes hp-loop-pulse-2 {
    0%, 33.33% { r: 11; }
    40.33%, 46.33% { r: 16; }
    53.33%, 100% { r: 11; }
  }

  .hp-loop-node--3 .hp-loop-node-inner { animation: hp-loop-pulse-3 var(--hp-loop-duration) linear infinite; }
  @keyframes hp-loop-pulse-3 {
    0%, 66.66% { r: 11; }
    73.66%, 79.66% { r: 16; }
    86.66%, 100% { r: 11; }
  }

  /* ── Hero entrance animation ── */
  .hp-hero.entered .hp-hero-text {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .hp-hero.entered .hp-hero-visual {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hp-hero-text,
    .hp-hero-visual {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hp-loop-flow,
    .hp-loop-node-inner {
      animation: none;
    }
  }

  /* ══════════════════════════════════════════
     SHARED SECTION STYLES
     ══════════════════════════════════════════ */
  .hp-section {
    padding: 8rem 0;
    border-top: 1px solid var(--color-border);
  }

  .hp-section-headline {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 3rem;
    max-width: 40rem;
    letter-spacing: -0.02em;
  }

  .hp-section-subheadline {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-top: -2rem;
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .hp-section-cta {
    margin-top: 3rem;
    text-align: center;
  }

  /* ══════════════════════════════════════════
     BUTTONS
     ══════════════════════════════════════════ */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-hover);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 1.0625rem;
  }

  /* ══════════════════════════════════════════
     SECTION: HOW IT WORKS
     ══════════════════════════════════════════ */
  .hp-how-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .hp-how-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .hp-how-card {
    padding: 1.75rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .hp-how-number {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
