---
import BaseLayout from '../layouts/BaseLayout.astro';
import frameworkData from '../data/lean-cs-data.json';

const strategyLoop = frameworkData.strategy_loop;
const stages = frameworkData.maturity_stages.stages;
const principles = frameworkData.principles;
---

<BaseLayout title="Customer Success Strategy & Maturity Framework" description="Open, vendor-neutral framework to assess your customer success maturity, get prescriptive playbooks, and track the metrics that move retention.">

  <!-- Section 1: Hero -->
  <section class="hp-hero" id="hero-section">
    <div class="hp-hero-inner">
      <!-- Left column: Text -->
      <div class="hp-hero-text" id="hp-hero-text">
        <h1 class="hp-hero-headline">
          An open framework to assess your <strong style="color: var(--color-accent); font-weight: 700;">Customer Success</strong>  maturity and rebuild your strategy.
        </h1>
        <p class="hp-hero-sub">
          With Distilled CS, you can quickly identify where your organization stands in its customer success journey, uncover what is missing from your strategy, and map out the exact next steps to elevate your CS team's impact.
        </p>
        <div class="hp-hero-ctas">
          <a href="/assess/" class="btn btn-primary" id="hp-hero-cta-primary" data-contextual="hero-cta">Take the Assessment</a>
          <a href="/customer-success-maturity-model/" class="btn btn-secondary">Explore the Framework</a>
        </div>
      </div>

      <!-- Right column: Animated SVG loop — circular track + orbiting progress dashes that light up each node in turn -->
      <div class="hp-hero-visual" id="hp-hero-visual">
        <svg class="hp-loop-svg" viewBox="0 0 720 720" role="img" aria-labelledby="hp-loop-title hp-loop-desc">
          <title id="hp-loop-title">Strategy Loop: Assess, Execute, Transform</title>
          <desc id="hp-loop-desc">A continuous improvement cycle. Assess flows to Execute, Execute flows to Transform, and Transform loops back to Assess.</desc>

          <!-- Faint full-circle track -->
          <path class="hp-loop-track" d="M 360 92 A 268 268 0 1 1 359.9 92" />
          <!-- Three orbiting progress dashes (pathLength 300; 14 + 86 dasharray repeated three times keeps them evenly spaced) -->
          <path class="hp-loop-progress" pathLength="300" d="M 360 92 A 268 268 0 1 1 359.9 92" />

          <!-- Center label — mirrors the site logo (Distilled + CS accent) -->
          <text class="hp-loop-center" x="360" y="360"><tspan>Distilled</tspan><tspan class="hp-loop-center-accent">CS</tspan></text>

          <!-- Node: Assess (top) -->
          <g class="hp-loop-node hp-loop-node--assess">
            <rect class="hp-loop-card" x="252" y="49" width="216" height="90" rx="10" />
            <text class="hp-loop-label" x="360" y="94">Assess</text>
          </g>

          <!-- Node: Execute (bottom-right) -->
          <g class="hp-loop-node hp-loop-node--execute">
            <rect class="hp-loop-card" x="484" y="455" width="196" height="90" rx="10" />
            <text class="hp-loop-label" x="582" y="500">Execute</text>
          </g>

          <!-- Node: Transform (bottom-left) -->
          <g class="hp-loop-node hp-loop-node--transform">
            <rect class="hp-loop-card" x="40" y="455" width="224" height="90" rx="10" />
            <text class="hp-loop-label" x="152" y="500">Transform</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- Section 2: Maturity Stages -->
  <section class="hp-section hp-section-stages" id="maturity-stages">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">The four stages of CS maturity</h2>
      <p class="hp-section-subheadline scroll-reveal">DistilledCS maps your customer success maturity across four progressive stages. Each stage describes where your team is today and what it takes to reach the next level.</p>
      <div class="hp-stages-grid">
        {stages.map((stage, i) => (
          <div class={`hp-stage-card scroll-reveal stage-${stage.id}`} style={`--stage-delay: ${i * 0.1}s`}>
            <div class="hp-stage-color-bar"></div>
            <div class="hp-stage-card-content">
              <span class="hp-stage-pill">Stage {i + 1}</span>
              <span class="hp-stage-label">{stage.label}</span>
              <span class="hp-stage-subtitle">{stage.subtitle}</span>
              <ul class="hp-stage-chars">
                {stage.key_characteristics.slice(0, 3).map(char => (
                  <li>{char}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div class="hp-section-cta scroll-reveal">
        <a href="/customer-success-maturity-model/" class="btn btn-secondary">Explore the full maturity model</a>
      </div>
    </div>
  </section>

  <!-- Section 3: The Strategy Loop -->
  <section class="hp-section hp-section-loop" id="strategy-loop">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">The Strategy Loop</h2>
      <p class="hp-section-subheadline scroll-reveal">A continuous cycle of improvement — assess your current state, execute stage-appropriate actions, and transform your CS organisation over time.</p>

      <ol class="hp-loop-phases-detail">
        {strategyLoop.phases.map((phase, i) => (
          <li class="hp-loop-phase-row scroll-reveal" style={`--reveal-delay: ${i * 0.1}s`}>
            <span class="hp-loop-phase-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="hp-loop-phase-body">
              <h3 class="hp-loop-phase-title">{phase.label}</h3>
              <p class="hp-loop-phase-desc">{phase.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Section 4: Principles -->
  <section class="hp-section hp-section-principles" id="principles">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">Built on six guiding principles</h2>
      <p class="hp-section-subheadline scroll-reveal">The beliefs that shape every recommendation, metric, and benchmark in the framework.</p>
      <div class="hp-principles-grid">
        {principles.map((p, i) => (
          <div class="hp-principle-card scroll-reveal" style={`--reveal-delay: ${i * 0.06}s`}>
            <span class="hp-principle-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="hp-principle-title">{p.title}</h3>
            <p class="hp-principle-summary">{p.summary}</p>
          </div>
        ))}
      </div>
      <div class="hp-section-cta scroll-reveal">
        <a href="/customer-success-principles/" class="btn btn-secondary">Read all principles</a>
      </div>
    </div>
  </section>

  <!-- Section 5: Open & Vendor-Neutral -->
  <section class="hp-section hp-section-open" id="open-source">
    <div class="container">
      <div class="hp-open-content scroll-reveal">
        <h2 class="hp-section-headline">Open source. Vendor neutral. Community driven.</h2>
        <p class="hp-open-body">
          Distilled CS is licensed under CC BY-SA 4.0, so it is open and accessible to everyone. There is no vendor lock-in and it is free to use. The framework is designed to give Customer Success teams and practitioners a shared language and a consistent way to measure where they stand, no matter which tools they use.
        </p>
        <p class="hp-open-body hp-open-emphasis">Built by practitioners, for practitioners.</p>
        <a href="https://github.com/saneeshnp/distilled-cs" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Contribute on GitHub (Coming soon!)</a>
      </div>
    </div>
  </section>

  <!-- Section 5.5: What to read next -->
  <section class="hp-section hp-section-read-next" id="read-next">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">What to read next</h2>
      <p class="hp-section-subheadline scroll-reveal">Five places to start, depending on what you need.</p>
      <div class="hp-read-next-grid">
        <a href="/customer-success-principles/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Principles</span>
          <span class="hp-read-next-title">Customer Success Principles</span>
          <span class="hp-read-next-body">Six beliefs that shape every recommendation in the framework.</span>
        </a>
        <a href="/customer-success-metrics/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Metrics</span>
          <span class="hp-read-next-title">Customer Success Metrics</span>
          <span class="hp-read-next-body">Sixteen metrics with formulas, benchmarks, and stage-by-stage priority.</span>
        </a>
        <a href="/customer-success-playbooks/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Playbooks</span>
          <span class="hp-read-next-title">Customer Success Playbooks</span>
          <span class="hp-read-next-body">Sixteen action plans grouped by maturity stage, each with steps and pitfalls.</span>
        </a>
        <a href="/customer-success-maturity-model/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Model</span>
          <span class="hp-read-next-title">Customer Success Maturity Model</span>
          <span class="hp-read-next-body">Four stages from Crawl to Fly, with the capabilities that define each.</span>
        </a>
        <a href="/assess/" class="hp-read-next-card scroll-reveal">
          <span class="hp-read-next-eyebrow">Assessment</span>
          <span class="hp-read-next-title">Take the Maturity Assessment</span>
          <span class="hp-read-next-body">Twenty-four questions across eight domains. Get a stage and a priority list.</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Section 6: Final CTA -->
  <section class="hp-section hp-section-final-cta" id="get-started">
    <div class="container">
      <div class="hp-final-cta-inner scroll-reveal">
        <h2 class="hp-final-cta-headline">Find out where your CS team stands</h2>
        <a href="/assess/" class="btn btn-primary btn-large">Take the Assessment</a>
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  /* ══════════════════════════════════════════
     HERO
     ══════════════════════════════════════════ */
  /* ──────────────────────────────────────────
     HERO BACKGROUND
     ──────────────────────────────────────────
     Light mode: subtle diagonal line pattern layered over a soft neutral
     radial glow — evokes clean daylight without any raster image.
     Dark mode : night-sky gradient with 15 CSS-drawn stars, easing down
     into a muted steel-blue at the base (no sunset / no orange).
     Both are pure CSS — 0 KB, 0 network requests, theme-swaps instantly. */
  .hp-hero {
    position: relative;
    display: flex;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    overflow: hidden;
    /* Light-mode layers (top → bottom of the background stack):
       1. Diagonal line pattern (very faint, ~5% opacity, 28px spacing)
       2. Soft neutral radial glow centered top for "daylight" feel
       3. Accent-tinted ambient radial
       4. Base off-white color */
    background:
      repeating-linear-gradient(
        135deg,
        rgba(45, 106, 90, 0.05) 0 1px,
        transparent 1px 28px
      ),
      radial-gradient(
        ellipse 90% 70% at 50% -10%,
        rgba(255, 255, 255, 0.6) 0%,
        rgba(255, 255, 255, 0) 60%
      ),
      radial-gradient(
        ellipse at 50% 40%,
        color-mix(in srgb, var(--color-accent) 5%, transparent) 0%,
        transparent 65%
      ),
      #fbfaf7;
  }

  /* Dark-mode override: night sky with stars, easing into muted steel-blue.
     Top 0–45%:  near-black with faint greenish tint (deep night)
     45–68%:     deep navy / indigo emerging
     68–88%:     rising mid-blue
     88–100%:    muted steel-blue at the base */
  :root[data-theme="dark"] .hp-hero {
    background:
      /* Star-field: 15 dots at 2–3px, distributed across the upper ~45% of
         the hero. Higher opacities so they read clearly against the dark sky. */
      radial-gradient(2.5px 2.5px at  9%  7%, rgba(255,255,255,0.95), transparent 60%),
      radial-gradient(3px 3px     at 24%  5%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(3px 3px     at 38% 10%, rgba(255,255,255,0.95), transparent 60%),
      radial-gradient(2.5px 2.5px at 52%  6%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(3px 3px     at 66% 14%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(2.5px 2.5px at 80% 17%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(3px 3px     at 93% 11%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(2.5px 2.5px at 16% 22%, rgba(255,255,255,0.8),  transparent 60%),
      radial-gradient(3px 3px     at 34% 27%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(2px 2px     at 48% 20%, rgba(255,255,255,0.75), transparent 60%),
      radial-gradient(2.5px 2.5px at 60% 32%, rgba(255,255,255,0.75), transparent 60%),
      radial-gradient(3px 3px     at 74% 28%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(2.5px 2.5px at 87% 35%, rgba(255,255,255,0.7),  transparent 60%),
      radial-gradient(2.5px 2.5px at 22% 40%, rgba(255,255,255,0.7),  transparent 60%),
      radial-gradient(2px 2px     at 56% 43%, rgba(255,255,255,0.65), transparent 60%),
      /* Main vertical sky gradient */
      linear-gradient(
        to bottom,
        #0a0d0a  0%,
        #0a0e0d 22%,
        #0b1210 42%,
        #0c1a22 55%,
        #0f2a40 68%,
        #163c5c 82%,
        #1d4e6e 92%,
        #22587a 100%
      );
  }

  .hp-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .hp-hero-inner {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }
  }

  /* ── Hero text column ── */
  .hp-hero-text {
    flex: 1;
    opacity: 0;
    transform: translateY(24px);
    max-width: 38rem;
  }

  @media (min-width: 1024px) {
    .hp-hero-text {
      max-width: none;
    }
  }

  .hp-hero-headline {
    font-size: clamp(1.625rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    color: var(--color-text-primary);
  }

  .hp-hero-sub {
    font-size: clamp(0.9375rem, 1.3vw, 1.0625rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 32rem;
  }

  .hp-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ── Hero visual column ── */
  .hp-hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    max-width: 420px;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hp-hero-visual {
      max-width: 480px;
    }
  }

  /* ── Strategy Loop SVG ──
     Single circular track. Three evenly-spaced dashes orbit it; each node
     card briefly glows as the dash reaches its position on the perimeter. */
  .hp-loop-svg {
    --hp-loop-duration: 8.4s;
    --hp-loop-card-shadow: drop-shadow(0 12px 18px rgba(26, 26, 46, 0.08));
    --hp-loop-resting-stroke: var(--color-border);
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  :root[data-theme="dark"] .hp-loop-svg {
    --hp-loop-card-shadow: drop-shadow(0 8px 18px rgba(0, 0, 0, 0.45));
    --hp-loop-resting-stroke: rgba(240, 237, 230, 0.28);
  }

  .hp-loop-track {
    fill: none;
    stroke: var(--color-text-primary);
    stroke-width: 16;
    stroke-linecap: round;
    opacity: 0.1;
  }

  .hp-loop-progress {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 15;
    stroke-linecap: round;
    /* 14 + 86 = 100, repeated 3× across pathLength 300 — three evenly-spaced dashes */
    stroke-dasharray: 14 86;
    animation: hp-loop-orbit var(--hp-loop-duration) linear infinite;
  }

  @keyframes hp-loop-orbit {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -300; }
  }

  /* Mirrors the site header logo — same display font, same accent split, scaled up. */
  .hp-loop-center {
    fill: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: 55px;
    font-weight: 500;
    letter-spacing: -0.02em;
    text-anchor: middle;
    dominant-baseline: middle;
  }

  .hp-loop-center-accent {
    fill: var(--color-accent);
  }

  .hp-loop-card {
    fill: var(--color-surface);
    stroke: var(--color-border);
    stroke-width: 1.5;
    color: var(--color-accent);
    filter: var(--hp-loop-card-shadow);
    animation: hp-loop-card-glow var(--hp-loop-duration) ease-in-out infinite;
  }

  .hp-loop-node--execute .hp-loop-card {
    animation-delay: calc(var(--hp-loop-duration) / 3);
  }

  .hp-loop-node--transform .hp-loop-card {
    animation-delay: calc(var(--hp-loop-duration) * 2 / 3);
  }

  /* Resting border softened (stroke-opacity 0.6) so the glow has somewhere to rise into. */
  @keyframes hp-loop-card-glow {
    0%, 28%, 100% {
      stroke: var(--color-border);
      stroke-opacity: 0.6;
      filter: var(--hp-loop-card-shadow);
    }
    10% {
      stroke: currentColor;
      stroke-opacity: 1;
      filter: drop-shadow(0 0 16px currentColor);
    }
  }

  .hp-loop-label {
    fill: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: 38px;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-anchor: middle;
    dominant-baseline: middle;
  }

  /* ── Hero entrance animation ── */
  .hp-hero.entered .hp-hero-text {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .hp-hero.entered .hp-hero-visual {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hp-hero-text,
    .hp-hero-visual {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hp-loop-progress,
    .hp-loop-card {
      animation: none;
    }
    .hp-loop-card {
      stroke: var(--color-border);
    }
  }

  /* ══════════════════════════════════════════
     SHARED SECTION STYLES
     ══════════════════════════════════════════ */
  .hp-section {
    padding: 8rem 0;
    border-top: 1px solid var(--color-border);
  }

  .hp-section-headline {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 3rem;
    max-width: 40rem;
    letter-spacing: -0.02em;
  }

  .hp-section-subheadline {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-top: -2rem;
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .hp-section-cta {
    margin-top: 3rem;
    text-align: center;
  }

  /* ══════════════════════════════════════════
     BUTTONS
     ══════════════════════════════════════════ */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-hover);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 1.0625rem;
  }

  /* ══════════════════════════════════════════
     SECTION: STRATEGY LOOP
     ══════════════════════════════════════════ */
  .hp-loop-phases-detail {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: flex;
    flex-direction: column;
  }

  .hp-loop-phase-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    column-gap: 1.25rem;
    padding: 1.25rem 0;
  }

  .hp-loop-phase-row + .hp-loop-phase-row {
    border-top: 1px dashed color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  @media (min-width: 768px) {
    .hp-loop-phase-row {
      grid-template-columns: 48px 1fr;
      column-gap: 1.5rem;
      padding: 1.25rem 0;
    }
  }

  .hp-loop-phase-number {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-accent);
    opacity: 0.7;
    line-height: 1.3;
  }

  .hp-loop-phase-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hp-loop-phase-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .hp-loop-phase-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ══════════════════════════════════════════
     SECTION: PRINCIPLES
     ══════════════════════════════════════════ */
  .hp-principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .hp-principles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .hp-principles-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .hp-principle-card {
    padding: 1.5rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .hp-principle-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .hp-principle-number {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    opacity: 0.5;
    display: block;
    margin-bottom: 0.75rem;
  }

  .hp-principle-title {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    color: var(--color-text-primary);
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
