---
import BaseLayout from '../layouts/BaseLayout.astro';
import StrategyLoop from '../components/StrategyLoop.astro';
import frameworkData from '../data/lean-cs-data.json';

const strategyLoop = frameworkData.strategy_loop;
const stages = frameworkData.maturity_stages.stages;
const principles = frameworkData.principles;
---

<BaseLayout title="Customer Success Strategy & Maturity Framework">

  <!-- Section 1: Hero -->
  <section class="hp-hero" id="hero-section">
    <div class="hp-hero-inner">
      <!-- Left column: Text -->
      <div class="hp-hero-text" id="hp-hero-text">
        <h1 class="hp-hero-headline">
          An open framework to assess your organization's Customer Success maturity and focus on what matters.
        </h1>
        <p class="hp-hero-sub">
          Distilled CS provides a structured approach to customer success — with a maturity assessment, stage-specific playbooks, benchmarks, and an execution checklist. Open source and vendor neutral.
        </p>
        <div class="hp-hero-ctas">
          <a href="/assess/" class="btn btn-primary" id="hp-hero-cta-primary" data-contextual="hero-cta">Take the Assessment</a>
          <a href="/model/" class="btn btn-secondary">Explore the Framework</a>
        </div>
      </div>

      <!-- Right column: Animated SVG loop — based on user-edited positions -->
      <div class="hp-hero-visual" id="hp-hero-visual">
        <svg class="hp-hero-svg" viewBox="0 0 400 420" role="img" aria-label="Strategy Loop: Assess, Execute, Transform — a continuous improvement cycle">
          <defs>
            <radialGradient id="hp-center-glow" cx="50%" cy="52%" r="50%">
              <stop offset="0%" style="stop-color: color-mix(in srgb, var(--color-accent) 7%, transparent);" />
              <stop offset="100%" style="stop-color: color-mix(in srgb, var(--color-accent) 0%, transparent);" />
            </radialGradient>
          </defs>

          <!-- Decorative orbital rings -->
          <g class="hp-orbital-group">
            <circle cx="200" cy="215" r="185" fill="none" style="stroke: color-mix(in srgb, var(--color-accent) 6%, transparent);" stroke-width="1" stroke-dasharray="4 8" />
            <circle cx="200" cy="215" r="168" fill="none" stroke="rgba(91,154,139,0.05)" stroke-width="0.5" stroke-dasharray="2 12" />
            <circle cx="200" cy="30" r="2.5" fill="var(--color-accent)" opacity="0.4" />
            <circle cx="385" cy="215" r="2" fill="var(--color-secondary)" opacity="0.35" />
            <circle cx="200" cy="400" r="2.5" fill="var(--color-accent)" opacity="0.3" />
            <circle cx="15" cy="215" r="2" fill="var(--color-secondary)" opacity="0.35" />
          </g>

          <!-- Center glow -->
          <circle cx="195" cy="223" r="85" fill="url(#hp-center-glow)" />

          <!-- Flowing arrow arcs (bezier curves from user-edited SVG) -->
          <!-- Arc 1: Assess → Execute -->
          <path class="hp-flow-arrow hp-flow-arrow--1" d="M 239 94 C 309 117 349 191 327 262" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-opacity="0.4" />
          <!-- Arc 2: Execute → Transform -->
          <path class="hp-flow-arrow hp-flow-arrow--2" d="M 290 319 C 233 372 156 372 100 319" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-opacity="0.4" />
          <!-- Arc 3: Transform → Assess -->
          <path class="hp-flow-arrow hp-flow-arrow--3" d="M 64 261 C 42 191 81 116 152 93" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-opacity="0.4" />

          <!-- Center label -->
          <text x="197" y="222" text-anchor="middle" dominant-baseline="middle" fill="var(--color-text-secondary)" font-size="20" font-family="var(--font-display)" opacity="0.85">Distilled CS</text>

          <!-- Node: Assess (top center) -->
          <g class="hp-svg-node">
            <rect class="hp-svg-node-rect" x="145" y="64" width="106" height="44" rx="10" fill="var(--color-surface)" />
            <text x="198" y="88" text-anchor="middle" dominant-baseline="middle" fill="var(--color-text-primary)" font-size="22" font-family="var(--font-display)">Assess</text>
          </g>

          <!-- Node: Execute (bottom-right) -->
          <g class="hp-svg-node">
            <rect class="hp-svg-node-rect" x="256" y="270" width="115" height="44" rx="10" fill="var(--color-surface)" />
            <text x="314" y="294" text-anchor="middle" dominant-baseline="middle" fill="var(--color-text-primary)" font-size="22" font-family="var(--font-display)">Execute</text>
          </g>

          <!-- Node: Transform (bottom-left) -->
          <g class="hp-svg-node">
            <rect class="hp-svg-node-rect" x="18" y="270" width="130" height="44" rx="10" fill="var(--color-surface)" />
            <text x="83" y="294" text-anchor="middle" dominant-baseline="middle" fill="var(--color-text-primary)" font-size="22" font-family="var(--font-display)">Transform</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- Section 2: The Strategy Loop -->
  <section class="hp-section hp-section-loop" id="strategy-loop">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">The Strategy Loop</h2>
      <p class="hp-section-subheadline scroll-reveal">A continuous cycle of improvement — assess your current state, execute stage-appropriate actions, and transform your CS organisation over time.</p>

      <div class="hp-loop-section-layout">
        <div class="hp-loop-diagram-wrapper scroll-reveal">
          <StrategyLoop size="lg" interactive={true} />
        </div>

        <div class="hp-loop-phases-detail">
          {strategyLoop.phases.map((phase, i) => (
            <div class="hp-loop-phase-card scroll-reveal" style={`--reveal-delay: ${i * 0.1}s`}>
              <span class="hp-loop-phase-number">{String(i + 1).padStart(2, '0')}</span>
              <p class="hp-loop-phase-desc">{phase.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Maturity Stages -->
  <section class="hp-section hp-section-stages" id="maturity-stages">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">The four stages of CS maturity</h2>
      <p class="hp-section-subheadline scroll-reveal">A progression model from reactive operations to predictive, data-led customer success. The assessment determines where your team currently sits.</p>
      <div class="hp-stages-grid">
        {stages.map((stage, i) => (
          <div class={`hp-stage-card scroll-reveal stage-${stage.id}`} style={`--stage-delay: ${i * 0.1}s`}>
            <div class="hp-stage-color-bar"></div>
            <div class="hp-stage-card-content">
              <span class="hp-stage-label">{stage.label}</span>
              <span class="hp-stage-subtitle">{stage.subtitle}</span>
              <ul class="hp-stage-chars">
                {stage.key_characteristics.slice(0, 3).map(char => (
                  <li>{char}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div class="hp-section-cta scroll-reveal">
        <a href="/model/" class="btn btn-secondary">Explore the full maturity model</a>
      </div>
    </div>
  </section>

  <!-- Section 4: Principles -->
  <section class="hp-section hp-section-principles" id="principles">
    <div class="container">
      <h2 class="hp-section-headline scroll-reveal">Built on six guiding principles</h2>
      <p class="hp-section-subheadline scroll-reveal">The beliefs that shape every recommendation, metric, and benchmark in the framework.</p>
      <div class="hp-principles-grid">
        {principles.map((p, i) => (
          <div class="hp-principle-card scroll-reveal" style={`--reveal-delay: ${i * 0.06}s`}>
            <span class="hp-principle-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="hp-principle-title">{p.title}</h3>
            <p class="hp-principle-summary">{p.summary}</p>
          </div>
        ))}
      </div>
      <div class="hp-section-cta scroll-reveal">
        <a href="/principles/" class="btn btn-secondary">Read all principles</a>
      </div>
    </div>
  </section>

  <!-- Section 5: Open & Vendor-Neutral -->
  <section class="hp-section hp-section-open" id="open-source">
    <div class="container">
      <div class="hp-open-content scroll-reveal">
        <h2 class="hp-section-headline">Open source. Vendor neutral. Community driven.</h2>
        <p class="hp-open-body">
          Distilled CS is licensed under CC BY-SA 4.0. No vendor lock-in, no paywall, no hidden agenda. The framework is built to give Customer Success teams a shared language and measurement standard — regardless of the tools they use.
        </p>
        <p class="hp-open-body hp-open-emphasis">Built by practitioners, for practitioners.</p>
        <a href="#" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Contribute on GitHub (Coming soon!)</a>
      </div>
    </div>
  </section>

  <!-- Section 6: Final CTA -->
  <section class="hp-section hp-section-final-cta" id="get-started">
    <div class="container">
      <div class="hp-final-cta-inner scroll-reveal">
        <h2 class="hp-final-cta-headline">Find out where your CS team stands</h2>
        <a href="/assess/" class="btn btn-primary btn-large">Take the Assessment</a>
      </div>
    </div>
  </section>

  <!-- Preview Modal (one-time notification) -->
  <div class="preview-modal-overlay" id="preview-modal" role="dialog" aria-modal="true" aria-labelledby="preview-modal-title">
    <div class="preview-modal">
      <div class="preview-modal-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h2 class="preview-modal-title" id="preview-modal-title">Early Preview</h2>
      <p class="preview-modal-body">
        Thanks for checking this out. This is an early preview, features may be incomplete or change before launch.
      </p>
      <p class="preview-modal-sub">DistilledCS</p>
      <button class="preview-modal-btn" id="preview-modal-close" type="button">Got it</button>
    </div>
  </div>

</BaseLayout>

<style>
  /* ══════════════════════════════════════════
     HERO
     ══════════════════════════════════════════ */
  /* ──────────────────────────────────────────
     HERO BACKGROUND
     ──────────────────────────────────────────
     Light mode: subtle diagonal line pattern layered over a soft neutral
     radial glow — evokes clean daylight without any raster image.
     Dark mode : night-sky gradient with 15 CSS-drawn stars, easing down
     into a muted steel-blue at the base (no sunset / no orange).
     Both are pure CSS — 0 KB, 0 network requests, theme-swaps instantly. */
  .hp-hero {
    position: relative;
    display: flex;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    overflow: hidden;
    /* Light-mode layers (top → bottom of the background stack):
       1. Diagonal line pattern (very faint, ~5% opacity, 28px spacing)
       2. Soft neutral radial glow centered top for "daylight" feel
       3. Accent-tinted ambient radial
       4. Base off-white color */
    background:
      repeating-linear-gradient(
        135deg,
        rgba(45, 106, 90, 0.05) 0 1px,
        transparent 1px 28px
      ),
      radial-gradient(
        ellipse 90% 70% at 50% -10%,
        rgba(255, 255, 255, 0.6) 0%,
        rgba(255, 255, 255, 0) 60%
      ),
      radial-gradient(
        ellipse at 50% 40%,
        color-mix(in srgb, var(--color-accent) 5%, transparent) 0%,
        transparent 65%
      ),
      #fbfaf7;
  }

  /* Dark-mode override: night sky with stars, easing into muted steel-blue.
     Top 0–45%:  near-black with faint greenish tint (deep night)
     45–68%:     deep navy / indigo emerging
     68–88%:     rising mid-blue
     88–100%:    muted steel-blue at the base */
  :root[data-theme="dark"] .hp-hero {
    background:
      /* Star-field: 15 dots at 2–3px, distributed across the upper ~45% of
         the hero. Higher opacities so they read clearly against the dark sky. */
      radial-gradient(2.5px 2.5px at  9%  7%, rgba(255,255,255,0.95), transparent 60%),
      radial-gradient(3px 3px     at 24%  5%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(3px 3px     at 38% 10%, rgba(255,255,255,0.95), transparent 60%),
      radial-gradient(2.5px 2.5px at 52%  6%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(3px 3px     at 66% 14%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(2.5px 2.5px at 80% 17%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(3px 3px     at 93% 11%, rgba(255,255,255,0.9),  transparent 60%),
      radial-gradient(2.5px 2.5px at 16% 22%, rgba(255,255,255,0.8),  transparent 60%),
      radial-gradient(3px 3px     at 34% 27%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(2px 2px     at 48% 20%, rgba(255,255,255,0.75), transparent 60%),
      radial-gradient(2.5px 2.5px at 60% 32%, rgba(255,255,255,0.75), transparent 60%),
      radial-gradient(3px 3px     at 74% 28%, rgba(255,255,255,0.85), transparent 60%),
      radial-gradient(2.5px 2.5px at 87% 35%, rgba(255,255,255,0.7),  transparent 60%),
      radial-gradient(2.5px 2.5px at 22% 40%, rgba(255,255,255,0.7),  transparent 60%),
      radial-gradient(2px 2px     at 56% 43%, rgba(255,255,255,0.65), transparent 60%),
      /* Main vertical sky gradient */
      linear-gradient(
        to bottom,
        #0a0d0a  0%,
        #0a0e0d 22%,
        #0b1210 42%,
        #0c1a22 55%,
        #0f2a40 68%,
        #163c5c 82%,
        #1d4e6e 92%,
        #22587a 100%
      );
  }

  .hp-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .hp-hero-inner {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }
  }

  /* ── Hero text column ── */
  .hp-hero-text {
    flex: 1;
    opacity: 0;
    transform: translateY(24px);
    max-width: 38rem;
  }

  @media (min-width: 1024px) {
    .hp-hero-text {
      max-width: none;
    }
  }

  .hp-hero-headline {
    font-size: clamp(1.625rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    color: var(--color-text-primary);
  }

  .hp-hero-sub {
    font-size: clamp(0.9375rem, 1.3vw, 1.0625rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 32rem;
  }

  .hp-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ── Hero visual column ── */
  .hp-hero-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    max-width: 420px;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hp-hero-visual {
      max-width: 480px;
    }
  }

  .hp-hero-svg {
    width: 100%;
    height: auto;
  }

  /* ── Orbital ring (decorative, rotates) ── */
  .hp-orbital-group {
    transform-origin: 200px 215px;
    animation: hp-orbit-rotate 40s linear infinite;
  }

  @keyframes hp-orbit-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ── SVG node box borders (theme-aware) ──
     In light mode we use a darker, thicker stroke so the three boxes read
     clearly against the cream hero background. In dark mode a faint light
     stroke is enough since the surface fill already contrasts the sky. */
  .hp-svg-node-rect {
    stroke: rgba(26, 26, 46, 0.22);
    stroke-width: 1.5;
  }

  :root[data-theme="dark"] .hp-svg-node-rect {
    stroke: rgba(240, 237, 230, 0.15);
    stroke-width: 1;
  }

  /* ── Flowing arrow animation ── */
  .hp-flow-arrow {
    stroke-dasharray: 12 8;
    animation: hp-flow-dash 8s linear infinite;
  }

  .hp-flow-arrow--2 {
    animation-delay: -2.66s;
  }

  .hp-flow-arrow--3 {
    animation-delay: -5.33s;
  }

  @keyframes hp-flow-dash {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -60; }
  }

  /* ── Hero entrance animation ── */
  .hp-hero.entered .hp-hero-text {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .hp-hero.entered .hp-hero-visual {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hp-hero-text,
    .hp-hero-visual {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .hp-orbital-group {
      animation: none;
    }
    .hp-flow-arrow {
      animation: none;
      stroke-dasharray: none;
    }
  }

  /* ══════════════════════════════════════════
     SHARED SECTION STYLES
     ══════════════════════════════════════════ */
  .hp-section {
    padding: 8rem 0;
    border-top: 1px solid var(--color-border);
  }

  .hp-section-headline {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 3rem;
    max-width: 40rem;
    letter-spacing: -0.02em;
  }

  .hp-section-subheadline {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-top: -2rem;
    margin-bottom: 3rem;
    max-width: 36rem;
  }

  .hp-section-cta {
    margin-top: 3rem;
    text-align: center;
  }

  /* ══════════════════════════════════════════
     BUTTONS
     ══════════════════════════════════════════ */
  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-hover);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 1.0625rem;
  }

  /* ══════════════════════════════════════════
     SECTION: STRATEGY LOOP
     ══════════════════════════════════════════ */
  .hp-loop-section-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .hp-loop-section-layout {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
    }

    .hp-loop-diagram-wrapper {
      flex: 1;
      max-width: 420px;
    }

    .hp-loop-phases-detail {
      flex: 1;
    }
  }

  .hp-loop-phases-detail {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hp-loop-phase-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .hp-loop-phase-card:last-child {
    border-bottom: none;
  }

  .hp-loop-phase-number {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-accent);
    opacity: 0.6;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .hp-loop-phase-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* ══════════════════════════════════════════
     SECTION: PRINCIPLES
     ══════════════════════════════════════════ */
  .hp-principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .hp-principles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .hp-principles-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .hp-principle-card {
    padding: 1.5rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .hp-principle-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .hp-principle-number {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    opacity: 0.5;
    display: block;
    margin-bottom: 0.75rem;
  }

  .hp-principle-title {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    color: var(--color-text-primary);
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .hp-principle-summary {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  /* ══════════════════════════════════════════
     SECTION: STAGES
     ══════════════════════════════════════════ */
  .hp-stages-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .hp-stages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .hp-stages-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .hp-stage-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color 0.25s ease-out, transform 0.25s ease-out;
  }

  .hp-stage-card:hover {
    border-color: var(--stage-color);
    transform: translateY(-2px);
  }

  .hp-stage-color-bar {
    height: 3px;
    background: var(--stage-color);
  }

  .hp-stage-card-content {
    padding: 1.5rem;
  }

  .hp-stage-label {
    display: block;
    font-family: var(--font-display);
    font-size: 1.375rem;
    margin-bottom: 0.25rem;
    color: var(--stage-color);
  }

  .hp-stage-subtitle {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .hp-stage-chars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hp-stage-chars li {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }

  .hp-stage-chars li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--stage-color);
  }

  /* ══════════════════════════════════════════
     SECTION: OPEN SOURCE
     ══════════════════════════════════════════ */
  .hp-open-content {
    max-width: 36rem;
  }

  .hp-open-body {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .hp-open-emphasis {
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
  }

  /* ══════════════════════════════════════════
     SECTION: FINAL CTA
     ══════════════════════════════════════════ */
  .hp-final-cta-inner {
    text-align: center;
  }

  .hp-final-cta-headline {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }

  /* ══════════════════════════════════════════
     SCROLL REVEAL
     ══════════════════════════════════════════ */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(24px);
  }

  /* ══════════════════════════════════════════
     PREVIEW MODAL
     ══════════════════════════════════════════ */
  .preview-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 1.5rem;
    opacity: 0;
    animation: modalFadeIn 0.35s ease forwards;
  }

  .preview-modal-overlay.hidden {
    display: none;
  }

  .preview-modal-overlay.dismissing {
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  @keyframes modalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .preview-modal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 2.5rem 2rem 2rem;
    max-width: 26rem;
    width: 100%;
    text-align: center;
    transform: translateY(12px) scale(0.97);
    animation: modalSlideIn 0.35s ease 0.05s forwards;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }

  @keyframes modalSlideIn {
    from { transform: translateY(12px) scale(0.97); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  .preview-modal-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .preview-modal-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .preview-modal-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .preview-modal-sub {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1.75rem;
  }

  .preview-modal-btn {
    display: inline-block;
    padding: 0.625rem 2rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .preview-modal-btn:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .preview-modal-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-modal-overlay { animation: none; opacity: 1; }
    .preview-modal { animation: none; transform: none; opacity: 1; }
    .preview-modal-overlay.dismissing { transition: none; }
  }
</style>

<script>
  // ── Preview modal (once per device, persisted in localStorage) ──
  const modal = document.getElementById('preview-modal')!;
  const modalClose = document.getElementById('preview-modal-close')!;
  try {
    if (localStorage.getItem('distilledcs_preview_seen') === 'true') {
      modal.classList.add('hidden');
    }
  } catch {
    modal.classList.add('hidden');
  }

  function dismissModal() {
    modal.classList.add('dismissing');
    try { localStorage.setItem('distilledcs_preview_seen', 'true'); } catch {}
    setTimeout(() => modal.classList.add('hidden'), 250);
  }

  modalClose.addEventListener('click', dismissModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) dismissModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) dismissModal();
  });

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Hero entrance ──
  const heroSection = document.getElementById('hero-section')!;
  requestAnimationFrame(() => {
    heroSection.classList.add('entered');
  });

  // ── Dynamic CTA for assessed users ──
  try {
    if (localStorage.getItem('distilledcs_completed') === 'true') {
      const ctaBtn = document.getElementById('hp-hero-cta-primary');
      if (ctaBtn) ctaBtn.textContent = 'View My Assessment';
    }
  } catch {}

  // ── Scroll-triggered reveals ──
  if (!prefersReducedMotion) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.style.getPropertyValue('--reveal-delay') || el.style.getPropertyValue('--stage-delay') || '0';
            el.style.transition = `opacity 0.6s ease ${delay}, transform 0.6s ease ${delay}`;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            revealObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.scroll-reveal').forEach(el => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.scroll-reveal').forEach(el => {
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'none';
    });
  }
</script>
