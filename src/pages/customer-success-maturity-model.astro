---
import BaseLayout from '../layouts/BaseLayout.astro';
import frameworkData from '../data/lean-cs-data.json';

const stages = frameworkData.maturity_stages.stages;
const comparisonMatrix = frameworkData.maturity_stages.comparison_matrix;
const stageOrder = ['crawl', 'walk', 'run'];
const stageTransitions = frameworkData.stage_transitions;
const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };
const transitionMap: Record<string, string> = { crawl: 'crawl_to_walk', walk: 'walk_to_run' };

// Page-only orientation lines — sit above each stage's description in the
// accordion to give first-time readers context before the definition.
const stageIntroLines: Record<string, string> = {
  crawl: 'The starting point of CS maturity. Every team begins here.',
  walk: 'The middle stage, where structure starts to take hold.',
  run: 'The most mature stage in the model. Scaled, predictive, and operationalized.',
};

// Descriptive alt text for the stage illustrations. Combines the visual
// subject with stage context so it reads well for screen readers and is
// keyword-rich for image-search indexing without being stuffed.
const stageImageAlt: Record<string, string> = {
  crawl: 'Stick figure crawling, representing the Crawl stage of the customer success maturity model, a reactive and foundational phase',
  walk: 'Stick figure walking, representing the Walk stage of the customer success maturity model, where structure begins to form',
  run: 'Stick figure running, representing the Run stage of the customer success maturity model, where CS becomes predictive and operationalized',
};

const faqItems = [
  {
    q: 'What is the customer success maturity model?',
    a: 'A three-stage model that describes how CS organizations evolve from reactive firefighting to proactive, outcome-driven operations. The stages are Crawl, Walk, and Run. Each names the operating mode of the team, the metrics that matter at that level, and the plays that move the team forward.',
  },
  {
    q: 'How do the three stages differ?',
    a: 'Crawl is reactive and foundational: the team is saving what it can while standardizing onboarding and renewal. Walk is informed and structured: segmentation is real, health scoring exists, QBRs run reliably. Run is proactive and operationalized: leading indicators drive action, expansion is a repeatable motion, and AI-assisted workflows are in practice. Continued improvement within Run is the ongoing discipline.',
  },
  {
    q: 'How do I know which stage I am in?',
    a: 'The Distilled CS assessment scores eight domains and maps your overall score to a stage. If you have not completed it, a quick heuristic: if renewals surprise you, you are at Crawl. If you know which accounts are at risk but react late, you are at Walk. If you catch risk weeks in advance, expansion is a repeatable motion, and predictive models or AI workflows are in use, you are at Run.',
  },
  {
    q: 'How long does it take to move between stages?',
    a: 'Typically nine to eighteen months per transition, depending on company growth rate and how much the CS function is already instrumented. Crawl to Walk is the fastest when the team commits to consistent motions. Walk to Run is the longest because it requires a data layer that most teams underestimate.',
  },
  {
    q: 'Can a CS team skip a stage?',
    a: 'No. Stages are not arbitrary. Each layer depends on the capabilities built in the prior one. A team that skips to Run without Walk-stage segmentation and health scoring ends up running plays on accounts it cannot read. The work compounds.',
  },
  {
    q: 'Is maturity the same across segments?',
    a: 'The stages are, but the expression differs. A Run-stage enterprise team runs multi-stakeholder QBRs with outcome scorecards. A Run-stage SMB team runs automated usage-triggered nudges with human escalation. The principles match; the tooling and cadence shift with segment economics.',
  },
  {
    q: 'What triggers a stage transition?',
    a: 'A combination of outgrowing the current stage playbook (CSMs hit the ceiling of what reactive motion can achieve) and new pressure on the business (board expectations, new segment, scale). The transition guide on the transform page walks through the signals that mark each boundary.',
  },
  {
    q: 'How do the stages compare across CS functions?',
    a: 'Read the stage comparison matrix on this page. It lays the eight capability domains down the left and the three stages across the top, so you can see how a single function shifts as a team matures. Health scoring, for example, moves from gut feel at Crawl, to basic scores at Walk, to multi-signal models with automated alerts at Run. Read a row to see what progression looks like for one function; scan a column to picture the operating mode of a whole stage.',
  },
  {
    q: 'How does this compare to other CS frameworks?',
    a: 'Most published CS frameworks focus on either metric taxonomies or operational checklists. The Distilled CS model connects a maturity stage to specific principles, metrics, and playbooks. It is open-source, vendor-neutral, and designed so the advice changes as the team matures, not just as its size grows.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout title="Customer Success Maturity Model" description="The Customer Success Maturity Model: three stages (Crawl, Walk, Run) with characteristics, priority actions, and transition signals for each." structuredData={[faqSchema]}>

  <div class="container model-page">

    <!-- Assess phase intro -->
    <div class="assess-phase-intro">
      <p class="phase-context-label">Part of the <strong>Assess</strong> phase</p>
    </div>

    <!-- Persistent H1 for SEO -->
    <header class="model-header">
      <h1 class="model-title">Customer Success Maturity Model</h1>
      <p class="model-subtitle">The Distilled CS maturity model places your CS organization on a three-stage scale (Crawl, Walk, Run) and shows the priority actions for moving up. It anchors the assessment, the recommended playbooks, and the metrics directory.</p>
    </header>

    <!-- Contextual header — shown if assessed (populated by JS) -->
    <div class="user-stage-header" id="user-stage-header" data-show-if-assessed style="display:none;"></div>

    <!-- CTA for non-assessed users -->
    <div class="assess-cta" id="model-cta" data-hide-if-assessed>
      <a href="/assess/" class="btn btn-primary">Take the Assessment to see where you stand</a>
    </div>

    <!-- Stage comparison matrix — the model at a glance, above the per-stage detail -->
    <section class="stage-comparison" aria-labelledby="comparison-heading">
      <h2 id="comparison-heading">The model at a glance</h2>
      <p class="comparison-intro">{comparisonMatrix.description}</p>
      <div class="comparison-scroll-shell">
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th scope="col" class="comparison-corner">Dimension</th>
              {stageOrder.map(id => (
                <th scope="col" class={`comparison-stage-head stage-${id}`} data-stage-col={id}>
                  <span class="comparison-stage-icon">
                    <img
                      src={`/images/maturity-stages/cs-maturity-stage-${id}.png`}
                      alt=""
                      width="28"
                      height="28"
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                  <span class="comparison-stage-label">{stageLabels[id]}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr class="comparison-score-row">
              <th scope="row" class="comparison-param">Distilled CS maturity score <span class="comparison-param-note">out of 10</span></th>
              {stageOrder.map(id => {
                const st = stages.find(s => s.id === id);
                return (
                  <td class="comparison-cell" data-stage-col={id}>
                    {(st.score_range[0] * 2.5).toFixed(1)}&ndash;{(st.score_range[1] * 2.5).toFixed(1)}
                  </td>
                );
              })}
            </tr>
            {comparisonMatrix.rows.map((row: any) => (
              <tr>
                <th scope="row" class="comparison-param">{row.parameter}</th>
                {stageOrder.map(id => (
                  <td class="comparison-cell" data-stage-col={id}>
                    <strong class="comparison-cell-label">{row[id].label}</strong>
                    <span class="comparison-cell-detail">{row[id].detail}</span>
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <button class="comparison-scroll-hint" type="button" aria-label="Scroll to see more stages">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      </div>
    </section>

    <!-- Per-stage detail lead-in -->
    <div class="stage-detail-lead">
      <h2 class="stage-detail-lead-heading">Each stage in detail</h2>
      <p class="stage-detail-lead-sub">Expand any stage for its characteristics, priority actions, and what unlocks at the next stage.</p>
    </div>

    <!-- Stage progression -->
    <div class="stages-progression">
      {stages.map((stage, i) => (
        <div
          class={`stage-section stage-${stage.id}`}
          data-stage-id={stage.id}
          id={`stage-${stage.id}`}
        >
          <!-- Stage header bar -->
          <button
            class="stage-header-bar"
            aria-expanded="true"
            aria-controls={`stage-content-${stage.id}`}
            type="button"
          >
            <div class="stage-header-left">
              <div class="stage-timeline-dot">
                <span class="stage-number">{i + 1}</span>
              </div>
              <div>
                <h2 class="stage-name">{stage.label}</h2>
                <span class="stage-subtitle-text">{stage.subtitle}</span>
              </div>
            </div>
            <div class="stage-header-right">
              <span class="stage-score-range">{stage.score_range[0] * 2.5} – {stage.score_range[1] * 2.5}</span>
              <span class="stage-badge-slot" data-stage-badge={stage.id}></span>
              <svg class="stage-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </button>

          <!-- Expandable content -->
          <div class="stage-content" id={`stage-content-${stage.id}`}>
            <div class="stage-intro-row">
              <div class="stage-illustration">
                <img
                  src={`/images/maturity-stages/cs-maturity-stage-${stage.id}.png`}
                  alt={stageImageAlt[stage.id]}
                  width="610"
                  height="404"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="stage-text-column">
                <p class="stage-intro-line">{stageIntroLines[stage.id]}</p>
                <p class="stage-description">In this stage, {stage.description}</p>
              </div>
            </div>

            <div class="stage-details-grid">
              <div class="stage-detail-block">
                <h3 class="detail-heading">Key Characteristics</h3>
                <ul class="detail-list">
                  {stage.key_characteristics.map(char => (
                    <li>{char}</li>
                  ))}
                </ul>
              </div>

              <div class="stage-detail-block">
                <h3 class="detail-heading">Priority Actions</h3>
                <ol class="detail-list-ordered">
                  {stage.priority_actions.map((action: any) => (
                    <li>{typeof action === 'string' ? action : action.text}</li>
                  ))}
                </ol>
              </div>
            </div>

            <div class="stage-profile">
              <h3 class="detail-heading">Typical Profile</h3>
              <p class="typical-profile-text">{stage.typical_profile}</p>
            </div>

            {/* Stage transition teaser — what unlocks at next stage */}
            {transitionMap[stage.id] && (() => {
              const transKey = transitionMap[stage.id];
              const trans = (stageTransitions as any)[transKey];
              const nextIdx = stageOrder.indexOf(stage.id) + 1;
              const nextStageId = stageOrder[nextIdx];
              const nextLabel = stageLabels[nextStageId];
              return (
                <div class={`transition-teaser stage-${nextStageId}`}>
                  <h3 class="detail-heading transition-teaser-heading">What unlocks at {nextLabel}</h3>
                  <ul class="transition-teaser-list">
                    {trans.new_capabilities.slice(0, 3).map((cap: string) => (
                      <li>{cap}</li>
                    ))}
                  </ul>
                  <a href="/transform/" class="transition-teaser-link">See the full transition guide &rarr;</a>
                </div>
              );
            })()}
          </div>

          {i < stages.length - 1 && <div class="stage-connector"></div>}
        </div>
      ))}
    </div>

    <!-- Intro prose (moved below stages so users see the model first) -->
    <section class="pillar-intro" data-hide-if-assessed>
      <h2>Why a maturity model for customer success</h2>
      <p>A maturity model gives the CS team a shared frame for what it is ready to do next, instead of arguing about tactics in the abstract. Principles that work at Crawl can misfire at Run. Metrics that matter at Run are noise at Crawl. Naming the stage lets the team match the advice to the reality of the organization.</p>
      <p>The three stages above are ordered by capability, not by company size. A lean team at a Series A startup can operate at Run. A hundred-person CS org at a public company can still be stuck at Crawl if the motions are inconsistent. Stage is a description of the operating system, not a badge for the team.</p>
    </section>

    <section class="pillar-faq">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <details class="faq-item">
            <summary class="faq-question">{item.q}</summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="pillar-related">
      <h2>Related topics</h2>
      <div class="related-grid">
        <a href="/customer-success-principles/" class="related-card">
          <h3>Principles</h3>
          <p>The beliefs that inform which stage behavior is worth the climb.</p>
        </a>
        <a href="/customer-success-playbooks/" class="related-card">
          <h3>Playbooks</h3>
          <p>Stage-specific plays that move a team from one stage to the next.</p>
        </a>
        <a href="/customer-success-metrics/" class="related-card">
          <h3>Metrics</h3>
          <p>Which signals matter most at each stage, with segment benchmarks.</p>
        </a>
        <a href="/transform/" class="related-card">
          <h3>Transform</h3>
          <p>Track progress and spot the signals that mark a stage transition.</p>
        </a>
      </div>
    </section>

    <!-- Bottom CTA: move to Execute -->
    <div class="model-bottom-cta">
      <h2 class="bottom-cta-headline">Ready to execute?</h2>
      <p class="bottom-cta-body">Now that you understand the maturity model, put it into action with stage-specific playbooks.</p>
      <div class="bottom-cta-links">
        <a href="/customer-success-playbooks/" class="btn btn-primary">View Your Playbooks</a>
        <a href="/assess/" class="btn btn-secondary" data-hide-if-assessed>Take the Assessment First</a>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .model-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 52rem;
    margin-inline: auto;
  }

  .model-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .model-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }

  .assess-cta {
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  /* ── User stage header (JS populated) ── */
  :global(.user-stage-header) {
    margin-bottom: 3rem;
  }

  :global(.user-stage-banner) {
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--stage-color) 25%, transparent);
    background: color-mix(in srgb, var(--stage-color) 6%, transparent);
    margin-bottom: 1rem;
    text-align: center;
  }

  :global(.user-stage-banner-title) {
    font-family: var(--font-display);
    font-size: 2rem;
    margin-bottom: 0.375rem;
    color: var(--stage-color);
  }

  :global(.user-stage-banner-sub) {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }

  :global(.btn-stage-jump) {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border-radius: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--stage-color) 50%, transparent);
    background: color-mix(in srgb, var(--stage-color) 12%, transparent);
    color: var(--stage-color);
    transition: background 0.2s ease-out, border-color 0.2s ease-out;
  }

  :global(.btn-stage-jump:hover) {
    background: color-mix(in srgb, var(--stage-color) 20%, transparent);
    border-color: color-mix(in srgb, var(--stage-color) 70%, transparent);
  }

  /* ── Stages progression ── */
  .stages-progression {
    display: flex;
    flex-direction: column;
  }

  .stage-section {
    position: relative;
    transition: opacity 0.3s ease-out;
    scroll-margin-top: 5rem;
  }

  .stage-section.dimmed {
    opacity: 0.5;
  }

  .stage-section.current {
    opacity: 1;
  }

  .stage-connector {
    width: 2px;
    height: 1.5rem;
    margin-left: 1.375rem;
    border-left: 2px dashed color-mix(in srgb, var(--stage-color) 30%, transparent);
  }

  .stage-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem 0.75rem 0 0;
    cursor: pointer;
    font-family: var(--font-body);
    color: var(--color-text-primary);
    text-align: left;
    transition: border-color 0.2s ease-out;
  }

  .stage-header-bar:hover {
    border-color: var(--color-border-hover);
  }

  .stage-header-bar[aria-expanded="false"] {
    border-radius: 0.75rem;
  }

  .stage-header-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .stage-timeline-dot {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--stage-color);
  }

  .stage-number {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-on-stage);
  }

  .stage-name {
    font-size: 1.25rem;
    margin-bottom: 0;
    font-family: var(--font-display);
    color: var(--stage-color);
  }

  .stage-subtitle-text {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .stage-header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .stage-score-range {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: none;
  }

  @media (min-width: 640px) {
    .stage-score-range {
      display: inline;
    }
  }

  .stage-chevron {
    color: var(--color-text-muted);
    transition: transform 0.2s ease-out;
  }

  .stage-header-bar[aria-expanded="false"] .stage-chevron {
    transform: rotate(-90deg);
  }

  /* Stage content */
  .stage-content {
    padding: 1.5rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 0.75rem 0.75rem;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }

  .stage-content[hidden] {
    display: none;
  }

  .stage-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .stage-intro-line {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .stage-intro-row {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .stage-intro-row .stage-description {
    margin-bottom: 0;
  }

  .stage-illustration {
    width: 100%;
    max-width: 320px;
    align-self: center;
    border: 1px solid color-mix(in srgb, var(--stage-color) 25%, var(--color-border));
    border-radius: 0.5rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--stage-color) 8%, var(--color-surface));
    padding: 0.75rem;
  }

  .stage-illustration img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 768px) {
    .stage-intro-row {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .stage-illustration {
      width: 240px;
      max-width: 240px;
      align-self: flex-start;
      flex-shrink: 0;
    }

    .stage-text-column {
      flex: 1;
      min-width: 0;
    }
  }

  .stage-details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .stage-details-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .stage-detail-block {
    padding: 1.25rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .detail-heading {
    font-size: 0.875rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .detail-list, .detail-list-ordered {
    margin: 0;
    padding: 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-list li, .detail-list-ordered li {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .stage-profile {
    padding: 1.25rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .typical-profile-text {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  :global(.you-are-here) {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.you-are-here--current) {
    background: color-mix(in srgb, var(--stage-color) 22%, transparent);
    color: var(--stage-color);
  }

  :global(.you-are-here--completed) {
    background: var(--color-surface-hover);
    color: var(--color-text-muted);
  }

  :global(.you-are-here--next) {
    background: var(--color-surface-hover);
    color: var(--color-text-secondary);
  }

  /* ── Assess phase intro ── */
  .assess-phase-intro {
    margin-bottom: 2rem;
  }

  .phase-context-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .phase-context-label strong {
    color: var(--color-accent);
  }

  .model-intro-copy {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 36rem;
  }

  /* ── Transition teaser ── */
  .transition-teaser {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: var(--color-bg);
    border: 1px solid color-mix(in srgb, var(--stage-color) 25%, transparent);
    border-radius: 0.5rem;
  }

  .transition-teaser-heading {
    color: var(--stage-color);
  }

  .transition-teaser-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .transition-teaser-list li {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding-left: 1.25rem;
    position: relative;
  }

  .transition-teaser-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }

  .transition-teaser-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .transition-teaser-link:hover {
    color: var(--color-accent-hover);
  }

  /* ── Bottom CTA ── */
  .model-bottom-cta {
    text-align: center;
    padding: 3rem 2rem;
    margin-top: 3rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .bottom-cta-headline {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .bottom-cta-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    max-width: 28rem;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .bottom-cta-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-hover);
    transform: translateY(-1px);
  }

  /* Persistent header */
  .model-header { margin-bottom: 1.5rem; }

  /* Stage comparison matrix */
  .stage-comparison { margin-top: 2rem; }
  .stage-comparison h2 { font-family: var(--font-display); font-size: 1.75rem; letter-spacing: -0.02em; margin-bottom: 0.5rem; color: var(--color-text-primary); }
  .comparison-intro { font-size: 0.9375rem; line-height: 1.65; color: var(--color-text-secondary); max-width: 44rem; margin-bottom: 1.5rem; }
  .comparison-scroll-shell { position: relative; }
  .comparison-table-wrap { overflow-x: auto; border: 1px solid var(--color-border); border-radius: 0.75rem; }

  /* Horizontal-scroll affordance (mobile): fade + pulsing chevron, shown only while more columns lie to the right */
  .comparison-scroll-shell::after {
    content: "";
    position: absolute;
    top: 1px;
    right: 1px;
    bottom: 1px;
    width: 3.5rem;
    z-index: 1;
    border-radius: 0 0.75rem 0.75rem 0;
    background: linear-gradient(to right, transparent, color-mix(in srgb, var(--color-accent) 22%, var(--color-bg)));
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  /* Pinned dimension column casts a shadow once earlier columns scroll under it */
  .comparison-corner, .comparison-param { transition: box-shadow 0.3s ease; }
  .comparison-scroll-shell.scrolled-past-start .comparison-corner,
  .comparison-scroll-shell.scrolled-past-start .comparison-param { box-shadow: 8px 0 10px -6px rgba(0, 0, 0, 0.2); }
  .comparison-scroll-hint {
    position: absolute;
    top: 5.5rem;
    right: 0.625rem;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    -webkit-appearance: none;
    appearance: none;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.16);
    color: var(--color-accent);
    cursor: pointer;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
    animation: comparison-scroll-nudge 1.5s ease-in-out infinite;
  }
  .comparison-scroll-shell.is-scrollable:not(.scrolled-end)::after { opacity: 1; }
  .comparison-scroll-shell.is-scrollable:not(.scrolled-end) .comparison-scroll-hint { opacity: 1; pointer-events: auto; }
  @keyframes comparison-scroll-nudge {
    0%, 100% { transform: translateX(0) scale(1); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.16); }
    50% { transform: translateX(4px) scale(1.08); box-shadow: 0 3px 12px rgba(0, 0, 0, 0.22); }
  }
  @media (prefers-reduced-motion: reduce) {
    .comparison-scroll-hint { animation: none; }
  }
  .comparison-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; min-width: 40rem; table-layout: fixed; }
  /* First (dimension) column: fixed, wrapping, pinned while the stage columns scroll */
  .comparison-corner, .comparison-param { width: 10rem; }
  .comparison-table th,
  .comparison-table td { text-align: left; padding: 0.75rem 1rem; vertical-align: top; border-bottom: 1px solid var(--color-border); }
  .comparison-table tbody tr:last-child th,
  .comparison-table tbody tr:last-child td { border-bottom: none; }
  .comparison-corner { background: var(--color-surface); font-weight: 600; color: var(--color-text-secondary); font-size: 0.9375rem; position: sticky; left: 0; z-index: 2; border-right: 1px solid var(--color-border); }
  .comparison-stage-head {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--stage-color);
    background: color-mix(in srgb, var(--stage-color) 8%, var(--color-surface));
    border-bottom: 2px solid color-mix(in srgb, var(--stage-color) 45%, transparent);
    white-space: nowrap;
  }
  .comparison-stage-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    margin-right: 0.5rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--stage-color) 16%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--stage-color) 35%, transparent);
    overflow: hidden;
    vertical-align: middle;
  }
  .comparison-stage-icon img { width: 80%; height: 80%; object-fit: contain; display: block; }
  .comparison-stage-label { vertical-align: middle; }
  .comparison-param {
    font-weight: 600;
    color: var(--color-text-primary);
    background: var(--color-surface);
    position: sticky;
    left: 0;
    z-index: 1;
    border-right: 1px solid var(--color-border);
  }
  .comparison-cell { color: var(--color-text-secondary); line-height: 1.5; }
  .comparison-cell-label { display: block; font-weight: 600; color: var(--color-text-secondary); }
  .comparison-cell-detail { display: block; margin-top: 0.125rem; font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.45; }
  .comparison-param-note { display: block; font-weight: 400; font-size: 0.6875rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.04em; }
  /* Score row: slightly set apart with a faint accent tint */
  .comparison-score-row .comparison-param { background: color-mix(in srgb, var(--color-accent) 6%, var(--color-surface)); }
  .comparison-score-row .comparison-cell { background: color-mix(in srgb, var(--color-accent) 6%, transparent); color: var(--color-accent); font-weight: 600; }
  .comparison-table tbody tr:hover .comparison-cell { background: color-mix(in srgb, var(--color-accent) 4%, transparent); }
  .comparison-table tbody tr:hover .comparison-param { background: color-mix(in srgb, var(--color-accent) 4%, var(--color-surface)); }

  /* Assessed-user active column */
  .comparison-cell.col-active {
    background: color-mix(in srgb, var(--stage-color) 8%, transparent);
    color: var(--color-text-primary);
    box-shadow: inset 2px 0 0 color-mix(in srgb, var(--stage-color) 45%, transparent),
                inset -2px 0 0 color-mix(in srgb, var(--stage-color) 45%, transparent);
  }
  .comparison-table tbody tr:last-child .comparison-cell.col-active {
    box-shadow: inset 2px 0 0 color-mix(in srgb, var(--stage-color) 45%, transparent),
                inset -2px 0 0 color-mix(in srgb, var(--stage-color) 45%, transparent),
                inset 0 -2px 0 color-mix(in srgb, var(--stage-color) 45%, transparent);
  }
  .comparison-stage-head.col-active {
    background: color-mix(in srgb, var(--stage-color) 16%, var(--color-surface));
  }
  :global(.comparison-your-stage) {
    display: block;
    margin-top: 0.25rem;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  @media print {
    .comparison-table-wrap { overflow-x: visible; }
    .comparison-table { min-width: 0; font-size: 0.75rem; }
  }

  /* Per-stage detail lead-in (sits between the matrix overview and the accordion) */
  .stage-detail-lead { margin-top: 3.5rem; margin-bottom: 1.25rem; }
  .stage-detail-lead-heading { font-family: var(--font-display); font-size: 1.75rem; letter-spacing: -0.02em; margin-bottom: 0.375rem; color: var(--color-text-primary); }
  .stage-detail-lead-sub { font-size: 0.9375rem; line-height: 1.6; color: var(--color-text-secondary); max-width: 44rem; }

  /* Pillar content */
  .pillar-intro { max-width: 44rem; margin-top: 4rem; }
  .pillar-intro h2 { font-family: var(--font-display); font-size: 1.5rem; letter-spacing: -0.01em; margin-bottom: 0.75rem; color: var(--color-text-primary); }
  .pillar-intro h3 { font-family: var(--font-display); font-size: 1.125rem; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--color-text-primary); }
  .pillar-intro p { font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-secondary); margin-bottom: 0.875rem; }

  .pillar-faq { margin-top: 4rem; }
  .pillar-faq h2 { font-family: var(--font-display); font-size: 1.75rem; letter-spacing: -0.02em; margin-bottom: 1.25rem; color: var(--color-text-primary); }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { padding: 1rem 1.25rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0.5rem; }
  .faq-question { font-weight: 500; font-size: 0.9375rem; color: var(--color-text-primary); cursor: pointer; list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); font-weight: 400; }
  .faq-item[open] .faq-question::after { content: '–'; }
  .faq-answer { margin-top: 0.75rem; font-size: 0.9375rem; line-height: 1.65; color: var(--color-text-secondary); }

  .pillar-related { margin-top: 3rem; }
  .pillar-related h2 { font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 1rem; color: var(--color-text-primary); }
  .related-grid { display: grid; grid-template-columns: 1fr; gap: 0.875rem; }
  @media (min-width: 640px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
  .related-card { padding: 1rem 1.125rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0.5rem; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s; }
  .related-card:hover { border-color: var(--color-accent); transform: translateY(-2px); color: inherit; }
  .related-card h3 { font-family: var(--font-display); font-size: 1rem; margin-bottom: 0.375rem; color: var(--color-text-primary); }
  .related-card p { font-size: 0.8125rem; line-height: 1.55; color: var(--color-text-muted); }
</style>

<script>
  import { isAssessmentCompleted, getScores, getProfile } from '../scripts/context-manager.js';
  import { toDisplayScore } from '../scripts/scoring-engine.js';

  const stageOrder = ['crawl', 'walk', 'run'];
  const stageLabels = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };
  const stageSubtitles = {
    crawl: 'Reactive / Foundational',
    walk: 'Informed / Structured',
    run: 'Proactive / Operationalized',
  };

  // Accordion toggle
  document.querySelectorAll('.stage-header-bar').forEach(bar => {
    bar.addEventListener('click', () => {
      const expanded = bar.getAttribute('aria-expanded') === 'true';
      const contentId = bar.getAttribute('aria-controls');
      const content = document.getElementById(contentId);
      bar.setAttribute('aria-expanded', String(!expanded));
      if (content) content.hidden = expanded;
    });
  });

  // Horizontal-scroll affordance for the comparison matrix
  (() => {
    const shell = document.querySelector('.comparison-scroll-shell');
    const wrap = shell?.querySelector('.comparison-table-wrap');
    if (!shell || !wrap) return;
    const update = () => {
      const scrollable = wrap.scrollWidth - wrap.clientWidth > 4;
      shell.classList.toggle('is-scrollable', scrollable);
      const atEnd = wrap.scrollLeft + wrap.clientWidth >= wrap.scrollWidth - 4;
      shell.classList.toggle('scrolled-end', atEnd);
      shell.classList.toggle('scrolled-past-start', wrap.scrollLeft > 4);
    };
    update();
    wrap.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    shell.querySelector('.comparison-scroll-hint')?.addEventListener('click', () => {
      wrap.scrollBy({ left: Math.round(wrap.clientWidth * 0.7), behavior: 'smooth' });
    });
  })();

  // Contextual personalization
  if (isAssessmentCompleted()) {
    const scores = getScores();
    const profile = getProfile();
    if (scores && scores.stage) {
      const userStage = scores.stage;
      const userStageIdx = stageOrder.indexOf(userStage);
      const companyName = profile?.company_name || '';

      // Show assessed elements, hide CTA
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => el.style.display = '');
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => el.style.display = 'none');

      // Populate user stage header — class carries the stage color.
      const stagePrefix = companyName ? `${companyName}'s stage` : 'Your stage';
      const header = document.getElementById('user-stage-header');
      if (header) {
        header.innerHTML = `
          <div class="user-stage-banner stage-${userStage}">
            <h2 class="user-stage-banner-title">${stagePrefix}: ${stageLabels[userStage]}</h2>
            <p class="user-stage-banner-sub">${stageSubtitles[userStage]} &middot; Overall score: ${toDisplayScore(scores.overallScore)} / 10</p>
            <button class="btn btn-stage-jump" id="jump-to-stage">View my stage's characteristics</button>
          </div>
        `;
        document.getElementById('jump-to-stage')?.addEventListener('click', () => {
          document.getElementById(`stage-${userStage}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }

      // Add badges and visual states to stage sections
      stageOrder.forEach((stageId, idx) => {
        const section = document.querySelector(`[data-stage-id="${stageId}"]`);
        const badgeSlot = document.querySelector(`[data-stage-badge="${stageId}"]`);

        if (idx === userStageIdx) {
          section?.classList.add('current');
          if (badgeSlot) {
            badgeSlot.innerHTML = `<span class="you-are-here you-are-here--current stage-${stageId}">You are here</span>`;
          }
        } else if (idx < userStageIdx) {
          if (badgeSlot) {
            badgeSlot.innerHTML = `<span class="you-are-here you-are-here--completed">Completed</span>`;
          }
        } else if (idx === userStageIdx + 1) {
          if (badgeSlot) {
            badgeSlot.innerHTML = `<span class="you-are-here you-are-here--next">Next milestone</span>`;
          }
        }
      });

      // Highlight the user's stage column in the comparison matrix
      const stageTag = companyName ? `${companyName}'s stage` : 'Your stage';
      document.querySelectorAll(`.comparison-table [data-stage-col="${userStage}"]`).forEach(cell => {
        cell.classList.add('col-active');
      });
      const activeHead = document.querySelector(`.comparison-stage-head[data-stage-col="${userStage}"]`);
      if (activeHead && !activeHead.querySelector('.comparison-your-stage')) {
        const tag = document.createElement('span');
        tag.className = 'comparison-your-stage';
        tag.textContent = stageTag;
        activeHead.appendChild(tag);
      }

    }
  }
</script>
