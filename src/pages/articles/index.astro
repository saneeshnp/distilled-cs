---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Articles" description="Long-form articles on customer success strategy, maturity, and the operational decisions behind moving from one stage to the next.">
  <div class="container blog-index">

    <div class="page-header">
      <h1 class="page-title">Articles</h1>
      <p class="page-subtitle">Long-form writing on customer success strategy, maturity, and the operational decisions between stages.</p>
    </div>

    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map(post => {
          const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <li>
              <a href={`/articles/${post.id}/`} class="post-card">
                <div class="post-meta">
                  <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <div class="empty-state">
        <p>No published posts yet. Check back soon.</p>
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .blog-index {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 42rem;
    margin-inline: auto;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: block;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease-out, transform 0.2s ease-out;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    color: inherit;
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    color: var(--color-text-secondary);
  }

  .post-title {
    font-size: 1.25rem;
    font-family: var(--font-display);
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .empty-state {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }
</style>
