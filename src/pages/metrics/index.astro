---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StrategyLoop from '../../components/StrategyLoop.astro';
import frameworkData from '../../data/lean-cs-data.json';

const metrics = frameworkData.metrics_directory.metrics;

const categories = [...new Set(metrics.map(m => m.category))];

const categoryLabels: Record<string, string> = {
  revenue: 'Revenue',
  retention: 'Retention',
  onboarding: 'Onboarding',
  health: 'Health',
  sentiment: 'Sentiment',
  usage: 'Usage',
  ai: 'AI & Automation',
};
---

<BaseLayout title="Metrics Directory" description="CS metrics that matter — with stage-specific priorities, benchmarks, and guidance.">
  <div class="container metrics-page">

    <!-- Strategy Loop wayfinding -->
    <div class="metrics-loop-indicator">
      <StrategyLoop activePhase="execute" size="sm" interactive={false} />
    </div>

    <div class="page-header">
      <h1 class="page-title">Metrics Directory</h1>
      <p class="page-subtitle">The right metrics for your stage. Part of the Execute phase — track these as you work through your playbooks.</p>
    </div>

    <!-- Contextual banner (JS populated) -->
    <div id="metrics-context-banner" data-show-if-assessed style="display:none;"></div>

    <!-- CTA for non-assessed -->
    <div class="assess-cta-banner" data-hide-if-assessed>
      <p>Take the assessment to see which metrics are highest priority for your stage.</p>
      <a href="/assess/" class="cta-link">Take the Assessment &rarr;</a>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all" type="button">All</button>
      {categories.map(cat => (
        <button class="filter-btn" data-filter={cat} type="button">{categoryLabels[cat] || cat}</button>
      ))}
    </div>

    <!-- Metrics grid -->
    <div class="metrics-grid" id="metrics-grid">
      {metrics.map(metric => (
        <a href={`/metrics/${metric.id}/`} class="metric-card" data-metric-id={metric.id} data-category={metric.category} data-priorities={JSON.stringify(metric.priority_by_stage)}>
          <div class="metric-card-top">
            <span class={`category-tag cat-${metric.category}`}>{categoryLabels[metric.category] || metric.category}</span>
            <span class="priority-indicator" data-priority-slot={metric.id}></span>
          </div>
          <h2 class="metric-name">{metric.name}</h2>
          <p class="metric-def">{metric.definition.length > 120 ? metric.definition.slice(0, 120) + '...' : metric.definition}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .metrics-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
  }

  .metrics-loop-indicator {
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
  }

  /* CTA banner */
  .assess-cta-banner {
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .assess-cta-banner p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .cta-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    padding: 0.375rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: transparent;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .filter-btn:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
  }

  .filter-btn.active {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  /* Metrics grid */
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .metrics-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .metric-card {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease-out, transform 0.2s ease-out;
    display: flex;
    flex-direction: column;
  }

  .metric-card:hover {
    border-color: var(--color-accent);
    color: inherit;
    transform: translateY(-2px);
  }

  .metric-card.dimmed {
    opacity: 0.5;
  }

  .metric-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .category-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border-radius: 0.25rem;
  }

  .cat-revenue { background: var(--color-accent-subtle); color: var(--color-accent); }
  .cat-retention { background: color-mix(in srgb, var(--color-stage-crawl) 14%, transparent); color: var(--color-stage-crawl); }
  .cat-onboarding { background: color-mix(in srgb, var(--color-stage-run) 14%, transparent); color: var(--color-stage-run); }
  .cat-health { background: color-mix(in srgb, var(--color-stage-fly) 14%, transparent); color: var(--color-stage-fly); }
  .cat-sentiment { background: color-mix(in srgb, #CE93D8 14%, transparent); color: #CE93D8; }
  .cat-usage { background: color-mix(in srgb, var(--color-stage-walk) 14%, transparent); color: var(--color-stage-walk); }
  .cat-ai { background: color-mix(in srgb, #7986CB 14%, transparent); color: #7986CB; }

  .metric-name {
    font-size: 1.0625rem;
    font-family: var(--font-display);
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .metric-def {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    flex: 1;
  }

  :global(.priority-pill) {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.priority-high) { background: color-mix(in srgb, var(--color-stage-run) 18%, transparent); color: var(--color-stage-run); }
  :global(.priority-medium) { background: color-mix(in srgb, var(--color-stage-walk) 18%, transparent); color: var(--color-stage-walk); }
  :global(.priority-low) { background: color-mix(in srgb, var(--color-text-muted) 10%, transparent); color: var(--color-text-muted); }

  :global(.context-banner) {
    padding: 0.875rem 1.25rem;
    border-radius: 0.75rem;
    margin-bottom: 2rem;
    font-size: 0.9375rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: color-mix(in srgb, var(--stage-color, var(--color-accent)) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--stage-color, var(--color-accent)) 30%, transparent);
  }

  :global(.context-banner-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--stage-color, var(--color-accent));
  }

  :global(.context-banner-stage) {
    color: var(--stage-color, var(--color-accent));
  }
</style>

<script>
  import { isAssessmentCompleted, getScores } from '../../scripts/context-manager.js';

  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run', fly: 'Fly' };

  // Category filtering
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.metric-card').forEach(card => {
        const cat = (card as HTMLElement).getAttribute('data-category');
        (card as HTMLElement).style.display = (filter === 'all' || cat === filter) ? '' : 'none';
      });
    });
  });

  // Contextual overlay
  if (isAssessmentCompleted()) {
    const scores = getScores();
    if (scores && scores.stage) {
      const stage = scores.stage;

      // Show/hide assessed elements
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => (el as HTMLElement).style.display = '');
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => (el as HTMLElement).style.display = 'none');

      // Banner
      const banner = document.getElementById('metrics-context-banner');
      if (banner) {
        banner.innerHTML = `<div class="context-banner stage-${stage}">
          <span class="context-banner-dot"></span>
          Showing priorities for your stage: <strong class="context-banner-stage">${stageLabels[stage]}</strong>
        </div>`;
      }

      // Priority indicators on cards
      document.querySelectorAll('.metric-card').forEach(card => {
        const priorities = JSON.parse((card as HTMLElement).getAttribute('data-priorities') || '{}');
        const priority = priorities[stage];
        const metricId = (card as HTMLElement).getAttribute('data-metric-id');
        const slot = card.querySelector(`[data-priority-slot="${metricId}"]`);
        if (slot && priority) {
          slot.innerHTML = `<span class="priority-pill priority-${priority}">${priority}</span>`;
        }
        if (priority === 'low') {
          card.classList.add('dimmed');
        }
      });

      // Sort: high > medium > low
      const grid = document.getElementById('metrics-grid');
      if (grid) {
        const cards = [...grid.querySelectorAll('.metric-card')];
        const order: Record<string, number> = { high: 0, medium: 1, low: 2 };
        cards.sort((a, b) => {
          const pa = JSON.parse(a.getAttribute('data-priorities') || '{}')[stage] || 'low';
          const pb = JSON.parse(b.getAttribute('data-priorities') || '{}')[stage] || 'low';
          return (order[pa] ?? 3) - (order[pb] ?? 3);
        });
        cards.forEach(c => grid.appendChild(c));
      }
    }
  }
</script>
