---
import BaseLayout from '../../layouts/BaseLayout.astro';
import frameworkData from '../../data/lean-cs-data.json';

export function getStaticPaths() {
  return frameworkData.metrics_directory.metrics.map(metric => ({
    params: { id: metric.id },
    props: { metric },
  }));
}

const { metric } = Astro.props;

const categoryLabels: Record<string, string> = {
  revenue: 'Revenue',
  retention: 'Retention',
  onboarding: 'Onboarding',
  health: 'Health',
  sentiment: 'Sentiment',
  usage: 'Usage',
  ai: 'AI & Automation',
};

const allMetrics = frameworkData.metrics_directory.metrics;
const relatedMetrics = (metric.related_metrics || [])
  .map((id: string) => allMetrics.find((m: any) => m.id === id))
  .filter(Boolean);

const benchmarkEntries = Object.entries(metric.benchmarks_by_context || {});

const segmentLabels: Record<string, string> = {
  seg_smb: 'SMB',
  seg_midmarket: 'Mid-Market',
  seg_enterprise: 'Enterprise',
  complexity_low: 'Low Complexity',
  complexity_moderate: 'Moderate Complexity',
  complexity_high: 'High Complexity',
  _default: 'All Segments',
};

const stageOrder = ['crawl', 'walk', 'run', 'fly'];
const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run', fly: 'Fly' };

// Health score components (only for health_score metric)
const healthComponents = metric.health_score_components_by_stage || null;

// Build reverse lookup: which playbooks reference this metric?
const playbooks = frameworkData.playbooks as Record<string, any[]>;
const usedInPlaybooks: { id: string; title: string; stageId: string }[] = [];
for (const stageId of stageOrder) {
  for (const pb of (playbooks[stageId] || [])) {
    if (pb.metrics_to_watch && pb.metrics_to_watch.includes(metric.id)) {
      usedInPlaybooks.push({ id: pb.id, title: pb.title, stageId });
    }
  }
}
---

<BaseLayout title={metric.name} description={metric.definition}>
  <div class="container metric-detail-page">

    <!-- Back link -->
    <a href="/metrics/" class="back-link">&larr; All Metrics</a>

    <!-- Metric header -->
    <div class="metric-header">
      <span class={`category-tag cat-${metric.category}`}>{categoryLabels[metric.category] || metric.category}</span>
      <h1 class="metric-title">{metric.name}</h1>
      {metric.also_known_as && metric.also_known_as.length > 0 && (
        <p class="also-known">Also known as: {metric.also_known_as.join(', ')}</p>
      )}
    </div>

    <!-- Definition -->
    <section class="metric-section">
      <p class="metric-definition">{metric.definition}</p>
    </section>

    <!-- Formula -->
    <section class="metric-section">
      <h2 class="section-heading">Formula</h2>
      <div class="formula-block">
        <code>{metric.formula}</code>
      </div>
    </section>

    <!-- Audience -->
    {metric.audience && metric.audience.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Who Is This Metric For?</h2>
        <div class="audience-list">
          {metric.audience.map((entry: { role: string; relevance: string }) => (
            <div class="audience-item">
              <span class="audience-role">{entry.role}</span>
              <p class="audience-relevance">{entry.relevance}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Contextual panel placeholder (JS populated) -->
    <section class="metric-section contextual-panel-section" id="contextual-panel" data-contextual="metric-panel" data-metric-id={metric.id}>
    </section>

    <!-- Priority by stage (static) -->
    <section class="metric-section">
      <h2 class="section-heading">Priority by Stage</h2>
      <div class="priority-stages">
        {stageOrder.map(stageId => {
          const priority = metric.priority_by_stage[stageId];
          const why = metric.why_priority?.[stageId];
          return (
            <div class={`priority-stage-row stage-${stageId}`} data-stage={stageId}>
              <div class="priority-stage-header">
                <span class="stage-dot"></span>
                <span class="stage-label-text">{stageLabels[stageId]}</span>
                <span class={`priority-pill priority-${priority}`}>{priority}</span>
              </div>
              {why && <p class="priority-why">{why}</p>}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Benchmarks -->
    {benchmarkEntries.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Benchmarks</h2>
        <div class="benchmarks-table-wrap">
          <table class="benchmarks-table">
            <thead>
              <tr>
                <th>Segment</th>
                <th>Good</th>
                <th>Great</th>
                <th>World Class</th>
              </tr>
            </thead>
            <tbody>
              {benchmarkEntries.map(([key, values]: [string, any]) => (
                <tr data-benchmark-segment={key}>
                  <td>{segmentLabels[key] || key}</td>
                  <td>{values.good}</td>
                  <td>{values.great}</td>
                  <td class="world-class-cell">{values.world_class}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Health Score Components (only for health_score metric) -->
    {healthComponents && (
      <section class="metric-section">
        <h2 class="section-heading">Health Score Components by Stage</h2>
        <div class="health-components">
          {stageOrder.map(stageId => {
            const comp = healthComponents[stageId];
            if (!comp) return null;
            return (
              <div class={`health-stage-block stage-${stageId}`} data-health-stage={stageId}>
                <h3 class="health-stage-title">
                  <span class="stage-dot"></span>
                  <span class="health-stage-label">{stageLabels[stageId]}</span>
                </h3>
                <div class="health-detail">
                  <h4>Recommended Inputs</h4>
                  <ul>
                    {comp.recommended_inputs.map((input: string) => <li>{input}</li>)}
                  </ul>
                </div>
                <div class="health-detail">
                  <h4>Scoring Method</h4>
                  <p>{comp.scoring_method}</p>
                </div>
                <div class="health-detail skip-detail">
                  <h4>What to Skip</h4>
                  <p>{comp.what_to_skip}</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Common mistakes -->
    {metric.common_mistakes && metric.common_mistakes.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Common Mistakes</h2>
        <ul class="mistakes-list">
          {metric.common_mistakes.map((mistake: string) => (
            <li>{mistake}</li>
          ))}
        </ul>
      </section>
    )}

    <!-- Used in Playbooks -->
    {usedInPlaybooks.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Used in Playbooks</h2>
        <div class="playbook-refs">
          {usedInPlaybooks.map(pb => (
            <a href={`/playbooks/${pb.id}/`} class={`playbook-ref-card stage-${pb.stageId}`}>
              <span class="playbook-ref-badge">{stageLabels[pb.stageId]}</span>
              <span class="playbook-ref-title">{pb.title}</span>
              <svg class="playbook-ref-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related metrics -->
    {relatedMetrics.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Related Metrics</h2>
        <div class="related-grid">
          {relatedMetrics.map((rm: any) => (
            <a href={`/metrics/${rm.id}/`} class="related-card">
              <span class={`category-tag cat-${rm.category}`} style="font-size:0.625rem;">{categoryLabels[rm.category] || rm.category}</span>
              <span class="related-name">{rm.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .metric-detail-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 48rem;
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .metric-header {
    margin-bottom: 2rem;
  }

  .category-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border-radius: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .cat-revenue { background: var(--color-accent-subtle); color: var(--color-accent); }
  .cat-retention { background: color-mix(in srgb, var(--color-stage-crawl) 14%, transparent); color: var(--color-stage-crawl); }
  .cat-onboarding { background: color-mix(in srgb, var(--color-stage-run) 14%, transparent); color: var(--color-stage-run); }
  .cat-health { background: color-mix(in srgb, var(--color-stage-fly) 14%, transparent); color: var(--color-stage-fly); }
  .cat-sentiment { background: color-mix(in srgb, #CE93D8 14%, transparent); color: #CE93D8; }
  .cat-usage { background: color-mix(in srgb, var(--color-stage-walk) 14%, transparent); color: var(--color-stage-walk); }
  .cat-ai { background: color-mix(in srgb, #7986CB 14%, transparent); color: #7986CB; }

  .metric-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    letter-spacing: -0.02em;
    margin-bottom: 0.375rem;
  }

  .also-known {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .metric-section {
    margin-bottom: 2.5rem;
  }

  .section-heading {
    font-size: 1.125rem;
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .metric-definition {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Formula */
  .formula-block {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  .formula-block code {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 0.9375rem;
    color: var(--color-accent);
    white-space: pre-wrap;
  }

  /* Priority by stage */
  .priority-stages {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .priority-stage-row {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: border-color 0.2s ease-out;
  }

  .priority-stage-row.user-stage {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  .priority-stage-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .stage-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--stage-color, var(--color-accent));
  }

  .stage-label-text {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--stage-color, var(--color-text-primary));
  }

  .health-stage-label {
    color: var(--stage-color, var(--color-text-primary));
  }

  .priority-pill {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: auto;
  }

  .priority-high { background: color-mix(in srgb, var(--color-stage-run) 18%, transparent); color: var(--color-stage-run); }
  .priority-medium { background: color-mix(in srgb, var(--color-stage-walk) 18%, transparent); color: var(--color-stage-walk); }
  .priority-low { background: color-mix(in srgb, var(--color-text-muted) 10%, transparent); color: var(--color-text-muted); }

  .priority-why {
    margin-top: 0.625rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Benchmarks table */
  .benchmarks-table-wrap {
    overflow-x: auto;
  }

  .benchmarks-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .benchmarks-table th {
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .benchmarks-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .benchmarks-table tr.user-segment td {
    background: var(--color-accent-subtle);
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .world-class-cell {
    color: var(--color-accent) !important;
    font-weight: 500;
  }

  /* Health components */
  .health-components {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .health-stage-block {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .health-stage-block.user-health-stage {
    border-color: var(--color-accent);
  }

  .health-stage-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: 0.875rem;
  }

  .health-detail {
    margin-bottom: 0.75rem;
  }

  .health-detail h4 {
    font-size: 0.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .health-detail ul {
    padding-left: 1.25rem;
    margin: 0;
  }

  .health-detail li, .health-detail p {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .skip-detail p {
    color: var(--color-warning);
    font-style: italic;
  }

  /* Audience */
  .audience-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .audience-item {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .audience-role {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.375rem;
  }

  .audience-relevance {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Contextual panel fade-in */
  .contextual-panel-section {
    opacity: 0;
    transform: translateY(1rem);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .contextual-panel-section.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .contextual-panel-section {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Common mistakes */
  .mistakes-list {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mistakes-list li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Related metrics */
  .related-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s ease-out;
  }

  .related-card:hover {
    border-color: var(--color-accent);
  }

  .related-name {
    font-size: 0.8125rem;
    color: var(--color-text-primary);
  }

  /* Used in Playbooks */
  .playbook-refs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .playbook-ref-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .playbook-ref-card:hover {
    border-color: var(--stage-color, var(--color-accent));
    background: var(--color-surface-hover);
  }

  .playbook-ref-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .playbook-ref-badge {
    padding: 0.15rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    border-radius: 9999px;
    flex-shrink: 0;
    background: var(--stage-color, var(--color-accent));
    color: var(--color-on-stage);
  }

  :global(.contextual-panel-box) {
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--stage-color, var(--color-accent)) 30%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--stage-color, var(--color-accent)) 8%, transparent);
  }

  :global(.contextual-panel-title) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  :global(.contextual-panel-row) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  :global(.contextual-panel-label) {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  :global(.contextual-panel-row .priority-pill) {
    font-size: 0.75rem;
  }

  :global(.contextual-panel-why) {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .playbook-ref-title {
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    flex: 1;
  }

  .playbook-ref-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
</style>

<script>
  import { isAssessmentCompleted, getScores, getProfile } from '../../scripts/context-manager.js';

  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run', fly: 'Fly' };

  const panel = document.getElementById('contextual-panel');

  if (isAssessmentCompleted()) {
    const scores = getScores();
    const profile = getProfile();

    if (scores && scores.stage && panel) {
      const stage = scores.stage;
      panel.classList.add(`stage-${stage}`);
      const metricId = panel.getAttribute('data-metric-id');

      // Highlight user's stage row
      const userRow = document.querySelector(`.priority-stage-row[data-stage="${stage}"]`);
      if (userRow) userRow.classList.add('user-stage');

      // Highlight user's benchmark segment
      const segment = profile?.customer_segment;
      const complexity = profile?.product_complexity;
      [segment, complexity].forEach(key => {
        if (key) {
          const row = document.querySelector(`tr[data-benchmark-segment="${key}"]`);
          if (row) row.classList.add('user-segment');
        }
      });

      // Highlight user's health stage
      const healthBlock = document.querySelector(`.health-stage-block[data-health-stage="${stage}"]`);
      if (healthBlock) healthBlock.classList.add('user-health-stage');

      // Build contextual panel
      const metricEl = panel;
      const priorityData = JSON.parse(
        document.querySelector(`[data-metric-id]`)?.closest('[data-priorities]')?.getAttribute('data-priorities') || '{}'
      );

      // Read from data embedded in the page's priority-stage-row
      const priorityRow = document.querySelector(`.priority-stage-row[data-stage="${stage}"]`);
      const priorityPill = priorityRow?.querySelector('.priority-pill');
      const priority = priorityPill?.textContent?.trim() || '';
      const why = priorityRow?.querySelector('.priority-why')?.textContent?.trim() || '';

      panel.innerHTML = `
        <div class="contextual-panel-box">
          <h2 class="contextual-panel-title">For your context</h2>
          <div class="contextual-panel-row">
            <span class="contextual-panel-label">Priority at ${stageLabels[stage]}:</span>
            <span class="priority-pill priority-${priority}">${priority}</span>
          </div>
          ${why ? `<p class="contextual-panel-why">${why}</p>` : ''}
        </div>
      `;
    }
  } else if (panel) {
    // Show CTA
    panel.innerHTML = `
      <div style="padding:1.5rem;border:1px solid var(--color-border);border-radius:0.75rem;background:var(--color-surface);text-align:center;">
        <p style="font-family:var(--font-display);font-size:1.125rem;margin-bottom:0.75rem;">Take the assessment for personalized guidance</p>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-bottom:1rem;">See which priority this metric is for your stage, plus benchmarks for your segment.</p>
        <a href="/assess/" style="display:inline-block;padding:0.625rem 1.5rem;background:var(--color-accent);color:var(--color-bg);border-radius:0.5rem;font-weight:500;font-size:0.875rem;text-decoration:none;">Take the Assessment</a>
      </div>
    `;
  }

  // Fade-in animation for contextual panel via Intersection Observer
  const panelSection = document.querySelector('.contextual-panel-section');
  if (panelSection) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      panelSection.classList.add('visible');
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      observer.observe(panelSection);
    }
  }
</script>
