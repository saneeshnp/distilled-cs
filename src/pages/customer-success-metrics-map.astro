---
import BaseLayout from '../layouts/BaseLayout.astro';
import frameworkData from '../data/lean-cs-data.json';

const stages = frameworkData.maturity_stages.stages;

const rows = frameworkData.metrics_directory.metrics.map(m => ({
  id: m.id,
  name: m.name,
  category: m.category,
  priorities: m.priority_by_stage as Record<string, string>,
  why: m.why_priority as Record<string, string>,
}));

const categoryLabels: Record<string, string> = {
  revenue: 'Revenue',
  retention: 'Retention',
  onboarding: 'Onboarding',
  health: 'Health',
  sentiment: 'Sentiment',
  usage: 'Usage',
  ai: 'AI & Automation',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://distilledcs.org/' },
    { '@type': 'ListItem', position: 2, name: 'Customer Success Metrics', item: 'https://distilledcs.org/customer-success-metrics/' },
    { '@type': 'ListItem', position: 3, name: 'Metrics Priority Map', item: 'https://distilledcs.org/customer-success-metrics-map/' },
  ],
};

// Map-specific FAQ (distinct from the directory FAQ): stage-priority questions.
const faqItems = [
  {
    q: 'Which customer success metrics matter most at each maturity stage?',
    a: 'At Crawl, focus on foundational retention and onboarding metrics: gross revenue retention, logo retention, and time to first value. At Walk, add net revenue retention and a composite health score. At Run, operationalize expansion metrics, leading indicators of churn, and predictive signals. The map above shows the priority of all 24 customer success metrics across the three stages.',
  },
  {
    q: 'When does net revenue retention become a priority?',
    a: 'Net revenue retention is low priority at Crawl, where gross retention matters more. It becomes a medium priority at Walk as you build the case for customer success as a revenue function, and a primary metric at Run, where expansion and risk management directly influence the number.',
  },
  {
    q: 'How should metric priorities change as a customer success team matures?',
    a: 'Priority should rise with capability. Early teams track fewer, foundational customer success metrics reliably before layering on health scoring and predictive analytics. Adding advanced metrics before the basics are clean measures the wrong thing first, which is why each metric carries a different priority at Crawl, Walk, and Run.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title="Customer Success Metrics Priority Map"
  description="See which customer success metrics matter at each maturity stage. A single map of all 24 metrics with their priority across Crawl, Walk, and Run."
  structuredData={[breadcrumbSchema, faqSchema]}
>
  <div class="container map-page">

    <a href="/customer-success-metrics/" class="back-link">&larr; Back to the metrics directory</a>

    <div class="page-header">
      <h1 class="page-title">Customer Success Metrics Priority Map</h1>
      <p class="page-subtitle">Every customer success metric in one view, with its priority at each maturity stage. See what to focus on now and what comes next.</p>
    </div>

    <!-- CTA for non-assessed -->
    <div class="assess-cta-banner" data-hide-if-assessed>
      <p>Take the assessment to highlight your stage and sort metrics by what matters most for your team.</p>
      <a href="/assess/" class="cta-link">Take the Assessment &rarr;</a>
    </div>

    <!-- Toolbar -->
    <div class="map-toolbar">
      <p class="toolbar-note" data-show-if-assessed hidden>
        Your stage column is highlighted, and metrics are sorted by priority for your stage.
      </p>
      <div class="toolbar-controls">
        <div class="control-group">
          <span class="control-label" id="group-label">Group by category</span>
          <div class="control-bar" id="group-toggle" role="group" aria-labelledby="group-label">
            <button class="control-btn active" data-group="off" type="button" aria-pressed="true">Off</button>
            <button class="control-btn" data-group="on" type="button" aria-pressed="false">On</button>
          </div>
        </div>
        <div class="control-group">
          <span class="control-label" id="display-label">Display</span>
          <div class="control-bar" id="display-toggle" role="group" aria-labelledby="display-label">
            <button class="control-btn active" data-display="chips" type="button" aria-pressed="true">Chips</button>
            <button class="control-btn" data-display="heatmap" type="button" aria-pressed="false">Heatmap</button>
          </div>
        </div>
        <div class="control-group">
          <span class="control-label" id="shift-label">Show priority shifts</span>
          <div class="control-bar" id="shift-toggle" role="group" aria-labelledby="shift-label">
            <button class="control-btn active" data-shift="off" type="button" aria-pressed="true">Off</button>
            <button class="control-btn" data-shift="on" type="button" aria-pressed="false">On</button>
          </div>
        </div>
      </div>
    </div>
    <p class="mode-hint" id="mode-hint" hidden></p>

    <!-- Table -->
    <div class="map-table-wrap">
      <table class="priority-map">
        <thead>
          <tr>
            <th scope="col" class="metric-col-head">
              <span class="metric-col-label">Metric</span>
              <span class="metric-col-count">{rows.length} metrics</span>
            </th>
            {stages.map(stage => (
              <th scope="col" class={`stage-col-head stage-${stage.id}`} data-col={stage.id}>
                <span class="stage-name">{stage.label}</span>
                <span class="stage-sub">{stage.subtitle}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody id="map-body">
          {rows.map(row => (
            <tr class="metric-row" data-id={row.id} data-category={row.category} data-priorities={JSON.stringify(row.priorities)}>
              <th scope="row" class="metric-cell">
                <span class="metric-cell-inner">
                  <a href={`/customer-success-metrics/${row.id}/`}>{row.name}</a>
                  <button class="why-toggle" type="button" data-metric-id={row.id} data-metric-name={row.name} aria-haspopup="dialog" aria-label={`Why these priorities for ${row.name}`}>
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M6.4 6.2a1.6 1.6 0 1 1 2.3 1.7c-.5.3-.7.5-.7 1.1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="11.2" r="0.75" fill="currentColor"/></svg>
                  </button>
                </span>
              </th>
              {stages.map(stage => (
                <td class={`prio-cell stage-${stage.id}`} data-col={stage.id} data-priority={row.priorities[stage.id]}>
                  <span class={`priority-pill priority-${row.priorities[stage.id]}`}>{row.priorities[stage.id]}</span>
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Hidden rationale sources, kept in static HTML for SEO; cloned into the modal on demand. -->
    <div id="why-data" hidden>
      {rows.map(row => (
        <div class="why-source" data-why-for={row.id} data-name={row.name}>
          <div class="why-grid">
            {stages.map(stage => (
              <div class={`why-block stage-${stage.id}`}>
                <span class="why-block-head">
                  <span class="why-stage-label">{stage.label}</span>
                  <span class={`priority-pill priority-${row.priorities[stage.id]}`}>{row.priorities[stage.id]}</span>
                </span>
                <p>{row.why[stage.id]}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Why modal -->
    <dialog id="why-modal" class="why-modal" aria-labelledby="why-modal-title">
      <div class="why-modal-head">
        <h2 id="why-modal-title"></h2>
        <button class="why-modal-close" type="button" aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <p class="why-modal-sub">How this metric's priority changes as your customer success function matures.</p>
      <div id="why-modal-body" class="why-modal-body"></div>
    </dialog>

    <section class="map-intro">
      <h2>How to read the customer success metrics map</h2>
      <p>This map ranks the customer success metrics that matter at each maturity stage. Priority rises as a team matures: a metric that is low priority at Crawl is often high priority at Run, because the team has the foundations in place to act on it. Reading a row left to right shows how the importance of each metric shifts as the customer success function grows.</p>
      <p>Two rules cut across every stage. Fewer metrics reviewed with discipline beat many tracked loosely, so start with the high-priority customer success metrics for your stage. And benchmarks must match your segment and ARR band. Each metric name links to its detail page, where you will find the formula, segment benchmarks, and common mistakes.</p>
    </section>

    <section class="pillar-faq">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <details class="faq-item">
            <summary class="faq-question">{item.q}</summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="pillar-related">
      <h2>Related topics</h2>
      <div class="related-grid">
        <a href="/customer-success-metrics/" class="related-card">
          <h3>Metrics directory</h3>
          <p>Browse all 24 customer success metrics with filters by category, role, and stage.</p>
        </a>
        <a href="/customer-success-maturity-model/" class="related-card">
          <h3>Maturity model</h3>
          <p>The three stages that set priority on each metric.</p>
        </a>
        <a href="/customer-success-playbooks/" class="related-card">
          <h3>Playbooks</h3>
          <p>Stage-specific plays that move the metrics in this map.</p>
        </a>
        <a href="/assess/" class="related-card">
          <h3>Take the assessment</h3>
          <p>Get a stage-specific priority list for your team.</p>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .map-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 40rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  /* CTA banner */
  .assess-cta-banner {
    max-width: 60rem;
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .assess-cta-banner p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .cta-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  /* Toolbar box */
  .map-toolbar {
    max-width: 60rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.125rem 1.25rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .toolbar-note {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .toolbar-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 1.125rem 2rem;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .control-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .control-bar {
    display: inline-flex;
    gap: 0.4rem;
  }

  .control-btn {
    padding: 0.375rem 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: transparent;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .control-btn:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
  }

  .control-btn.active {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  .mode-hint {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: 60rem;
  }

  /* Table — scroll container so the header can stick within it
     (horizontal scroll on mobile, vertical past max-height). */
  .map-table-wrap {
    overflow: auto;
    max-height: 80vh;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    max-width: 60rem;
  }

  table.priority-map {
    border-collapse: collapse;
    width: 100%;
    min-width: 540px;
    table-layout: fixed;
  }

  .metric-col-head,
  .metric-cell { width: 40%; }

  .stage-col-head,
  .prio-cell { width: 20%; }

  .priority-map th,
  .priority-map td {
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .priority-map tbody tr:last-child th,
  .priority-map tbody tr:last-child td {
    border-bottom: none;
  }

  /* Sticky header row (sticks within the scroll container) */
  .priority-map thead th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--color-surface);
  }

  /* Sticky metric column */
  .metric-col-head,
  .metric-cell {
    position: sticky;
    left: 0;
    text-align: left;
  }

  .metric-cell {
    z-index: 1;
    background: var(--color-bg);
    font-weight: 500;
  }

  /* Top-left corner cell sits above both the sticky row and column */
  .metric-col-head {
    z-index: 3;
    background: var(--color-surface);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    vertical-align: middle;
  }

  .metric-col-label {
    display: block;
  }

  .metric-col-count {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-text-muted);
  }

  .metric-cell-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .metric-cell-inner a {
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: 0.9375rem;
    line-height: 1.35;
  }

  .metric-cell-inner a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* "Why" trigger */
  .why-toggle {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    min-height: 0;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.2s ease-out, background 0.2s ease-out;
  }

  .why-toggle:hover {
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  @media (pointer: coarse) {
    .why-toggle { width: 2.25rem; height: 2.25rem; }
  }

  /* Stage column headers */
  .stage-col-head {
    text-align: center;
    background: var(--color-surface);
  }

  .stage-name {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1875rem;
    color: var(--stage-color);
  }

  .stage-sub {
    display: block;
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .prio-cell {
    text-align: center;
  }

  /* Active column highlight (assessed users) */
  .col-active {
    background: color-mix(in srgb, var(--stage-color, var(--color-accent)) 9%, transparent);
  }

  /* Row hover: full-row tint to guide the eye across the wide table.
     Both the sticky metric cell and the priority cells use the same opaque
     tint so the row highlights instantly and evenly (no fade). Heatmap-shaded
     cells keep their own background (higher specificity), which is intentional. */
  @media (hover: hover) {
    .metric-row:hover .metric-cell,
    .metric-row:hover .prio-cell {
      background: color-mix(in srgb, var(--color-text-muted) 8%, var(--color-bg));
    }
  }

  .your-stage-tag {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.45rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--stage-color) 18%, transparent);
    color: var(--stage-color);
  }

  /* Priority chips */
  .priority-pill {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .priority-high { background: color-mix(in srgb, var(--color-stage-run) 18%, transparent); color: var(--color-stage-run); }
  .priority-medium { background: color-mix(in srgb, var(--color-stage-walk) 18%, transparent); color: var(--color-stage-walk); }
  .priority-low { background: color-mix(in srgb, var(--color-text-muted) 10%, transparent); color: var(--color-text-muted); }

  /* Heatmap mode: single-hue intensity ramp (low→high = faint→strong) so the
     table reads as a gradient. Solid fills (mixed with the page bg) keep the
     steps consistent and stop the active-column tint bleeding through. */
  .priority-map.heatmap .prio-cell[data-priority="high"] { background: color-mix(in srgb, var(--color-stage-run) 52%, var(--color-bg)); }
  .priority-map.heatmap .prio-cell[data-priority="medium"] { background: color-mix(in srgb, var(--color-stage-run) 27%, var(--color-bg)); }
  .priority-map.heatmap .prio-cell[data-priority="low"] { background: color-mix(in srgb, var(--color-stage-run) 8%, var(--color-bg)); }

  .priority-map.heatmap .priority-pill {
    background: transparent;
    color: var(--color-text-primary);
    padding-inline: 0;
  }

  /* Priority-shift mode: recede the steady cells, spotlight the step-ups
     (the stage where each metric first rises). Mutes rather than using
     opacity, so text stays legible in both display modes. */
  .priority-map.show-shifts .prio-cell.shift-up .priority-pill::after {
    content: ' \2191';
    font-weight: 700;
  }

  /* Chips + shift: mute steady chips, keep step-up chips at full strength. */
  .priority-map.show-shifts:not(.heatmap) .prio-cell:not(.shift-up) .priority-pill {
    background: color-mix(in srgb, var(--color-text-muted) 9%, transparent);
    color: var(--color-text-muted);
  }

  /* Heatmap + shift: flatten steady cells so only the step-ups stay shaded. */
  .priority-map.show-shifts.heatmap .prio-cell:not(.shift-up) {
    background: var(--color-bg);
  }
  .priority-map.show-shifts.heatmap .prio-cell:not(.shift-up) .priority-pill {
    color: var(--color-text-muted);
  }

  /* Group header rows (injected by JS) */
  :global(.priority-map .group-header th) {
    position: sticky;
    left: 0;
    background: var(--color-accent-subtle);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    padding: 0.55rem 1.1rem;
    text-align: left;
  }

  /* Why modal */
  .why-modal {
    margin: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    padding: 0;
    width: min(40rem, calc(100% - 2rem));
    max-height: min(85vh, 44rem);
    overflow: auto;
    background: var(--color-bg);
    color: var(--color-text-primary);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
  }

  .why-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }

  .why-modal-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem 0;
  }

  .why-modal-head h2 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  .why-modal-close {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    min-height: 0;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .why-modal-close:hover {
    background: color-mix(in srgb, var(--color-text-muted) 14%, transparent);
    color: var(--color-text-primary);
  }

  .why-modal-sub {
    padding: 0.4rem 1.5rem 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .why-modal-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  /* Rationale grid: one stage card per row, stacked top to bottom in the modal */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .why-block {
    padding: 0.9rem 1rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--stage-color) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--stage-color) 22%, transparent);
  }

  .why-block-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.45rem;
  }

  .why-stage-label {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--stage-color);
  }

  .why-block p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* Intro + related */
  .map-intro {
    max-width: 44rem;
    margin-top: 3rem;
  }
  .map-intro h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .map-intro p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 0.875rem;
  }

  .pillar-faq {
    margin-top: 3.5rem;
    max-width: 44rem;
  }
  .pillar-faq h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .faq-question {
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    float: right;
    color: var(--color-text-muted);
    font-weight: 400;
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-question::after { content: '\2013'; }
  .faq-answer {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .pillar-related {
    margin-top: 3.5rem;
  }
  .pillar-related h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  @media (min-width: 640px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .related-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .related-card {
    padding: 1rem 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: inherit;
  }
  .related-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: 0.375rem;
    color: var(--color-text-primary);
  }
  .related-card p {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
</style>

<script>
  import { isAssessmentCompleted, getScores } from '../scripts/context-manager.js';

  const categoryLabels: Record<string, string> = {
    revenue: 'Revenue',
    retention: 'Retention',
    onboarding: 'Onboarding',
    health: 'Health',
    sentiment: 'Sentiment',
    usage: 'Usage',
    ai: 'AI & Automation',
  };

  const table = document.querySelector('.priority-map');
  const body = document.getElementById('map-body');
  const metricRows = body ? [...body.querySelectorAll('.metric-row')] : [];
  const categoryOrder = [...new Set(metricRows.map(r => (r as HTMLElement).dataset.category || ''))];

  const rank: Record<string, number> = { high: 0, medium: 1, low: 2 };
  const upRank: Record<string, number> = { low: 0, medium: 1, high: 2 };
  let grouping = 'off';
  let userStage = '';

  // --- Priority-shift classes (computed once; persist through reordering) ---
  // A cell is a "step-up" when its priority is higher than the stage to its left.
  // Crawl is compared against a 'low' baseline, so a metric that already matters
  // at Crawl is marked there (the stage it first becomes relevant).
  metricRows.forEach(row => {
    let prev = 'low';
    row.querySelectorAll('.prio-cell').forEach(cell => {
      const lvl = (cell as HTMLElement).dataset.priority || 'low';
      cell.classList.add((upRank[lvl] ?? 0) > (upRank[prev] ?? 0) ? 'shift-up' : 'shift-same');
      prev = lvl;
    });
  });

  function priorityRank(row: Element): number {
    const p = JSON.parse((row as HTMLElement).dataset.priorities || '{}')[userStage];
    return rank[p] ?? 3;
  }

  function sortRows(rows: Element[]): Element[] {
    if (!userStage) return rows;
    return [...rows].sort((a, b) => priorityRank(a) - priorityRank(b));
  }

  function render() {
    if (!body) return;
    body.querySelectorAll('.group-header').forEach(h => h.remove());

    if (grouping === 'off') {
      sortRows(metricRows).forEach(r => body.appendChild(r));
    } else {
      categoryOrder.forEach(cat => {
        const rows = metricRows.filter(r => (r as HTMLElement).dataset.category === cat);
        if (!rows.length) return;
        const header = document.createElement('tr');
        header.className = 'group-header';
        header.innerHTML = `<th scope="colgroup" colspan="4">${categoryLabels[cat] || cat}</th>`;
        body.appendChild(header);
        sortRows(rows).forEach(r => body.appendChild(r));
      });
    }
  }

  function highlightColumn(stage: string) {
    document.querySelectorAll(`[data-col="${stage}"]`).forEach(el => el.classList.add('col-active'));
    const head = document.querySelector(`.stage-col-head[data-col="${stage}"]`);
    if (head && !head.querySelector('.your-stage-tag')) {
      head.insertAdjacentHTML('beforeend', '<span class="your-stage-tag">Your stage</span>');
    }
  }

  // Generic single-select toggle wiring
  function wireToggle(id: string, attr: string, cb: (value: string) => void) {
    const bar = document.getElementById(id);
    bar?.querySelectorAll('.control-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        bar.querySelectorAll('.control-btn').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        cb(btn.getAttribute(attr) || '');
      });
    });
  }

  let display = 'chips';
  let shifts = 'off';

  function updateHint() {
    const hint = document.getElementById('mode-hint');
    if (!hint) return;
    const parts: string[] = [];
    if (shifts === 'on') parts.push('Highlighted cells mark the stage where each metric first rises in priority.');
    if (display === 'heatmap') parts.push('Cell shading shows priority intensity at each stage.');
    if (parts.length) {
      hint.textContent = parts.join(' ');
      hint.removeAttribute('hidden');
    } else {
      hint.setAttribute('hidden', '');
    }
  }

  wireToggle('group-toggle', 'data-group', v => { grouping = v; render(); });
  wireToggle('display-toggle', 'data-display', v => { display = v; table?.classList.toggle('heatmap', v === 'heatmap'); updateHint(); });
  wireToggle('shift-toggle', 'data-shift', v => { shifts = v; table?.classList.toggle('show-shifts', v === 'on'); updateHint(); });

  // --- Why modal ---
  const modal = document.getElementById('why-modal') as HTMLDialogElement | null;
  const modalTitle = document.getElementById('why-modal-title');
  const modalBody = document.getElementById('why-modal-body');

  function openWhy(id: string, name: string) {
    if (!modal || !modalTitle || !modalBody) return;
    const grid = document.querySelector(`.why-source[data-why-for="${id}"] .why-grid`);
    if (!grid) return;
    modalTitle.textContent = name;
    modalBody.replaceChildren(grid.cloneNode(true));
    if (typeof modal.showModal === 'function') modal.showModal();
    else modal.setAttribute('open', '');
  }

  document.querySelectorAll('.why-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      openWhy(el.dataset.metricId || '', el.dataset.metricName || '');
    });
  });

  document.querySelector('.why-modal-close')?.addEventListener('click', () => modal?.close());
  // Close when the backdrop (the dialog element itself) is clicked
  modal?.addEventListener('click', e => {
    if (e.target === modal) modal.close();
  });

  // Contextual enhancement
  if (isAssessmentCompleted()) {
    const scores = getScores();
    if (scores && scores.stage) {
      userStage = scores.stage;
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => (el as HTMLElement).style.display = 'none');
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => el.removeAttribute('hidden'));
      highlightColumn(userStage);
    }
  }

  render();
</script>
