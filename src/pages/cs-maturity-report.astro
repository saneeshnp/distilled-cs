---
import BaseLayout from '../layouts/BaseLayout.astro';
import frameworkData from '../data/lean-cs-data.json';
import logoRaw from '../assets/logo-mark.svg?raw';

const stages = frameworkData.maturity_stages.stages;
const domains = frameworkData.assessment_domains.domains;
const playbooks = frameworkData.playbooks;
const metrics = frameworkData.metrics_directory.metrics;
const stageTransitions = frameworkData.stage_transitions;
const contextualRecs = frameworkData.contextual_recommendations;
---

<BaseLayout title="CS Maturity Report" description="Your personalized Customer Success maturity report with domain breakdown, priority actions, and recommended playbooks." noindex={true}>

  <!-- ═══ Loading overlay (shown only when redirected from assess) ═══ -->
  <div id="report-loading" style="display:none;" aria-live="polite" aria-label="Building your report">
    <div class="report-loading-inner">
      <p class="report-loading-title" id="report-loading-title">Building your report…</p>
      <div class="report-loading-progress" aria-hidden="true">
        <div class="report-loading-fill" id="report-loading-fill"></div>
      </div>
      <span class="report-loading-spinner" aria-hidden="true"></span>
    </div>
  </div>
  <script is:inline>
    (function () {
      var flag = sessionStorage.getItem('distilledcs_just_assessed');
      if (flag) {
        var overlay = document.getElementById('report-loading');
        var title = document.getElementById('report-loading-title');
        if (overlay) overlay.style.display = '';
        if (title) title.textContent = flag === 'update' ? 'Updating your report…' : 'Building your report…';
      }
    })();
  </script>

  <!-- ═══ Shared-view banner (shown only when viewing ?d=… payload) ═══ -->
  <div class="shared-banner" id="report-shared-banner" role="complementary" aria-label="Shared report context" hidden>
    <div class="container shared-banner-inner">
      <div class="shared-banner-text">
        <span class="shared-banner-eyebrow">Shared report</span>
        <span class="shared-banner-headline" id="shared-banner-headline"></span>
      </div>
      <a href="/assess/" class="shared-banner-cta">Take your own assessment →</a>
    </div>
  </div>

  <div class="container report-page">

    <!-- ═══ Not-assessed fallback ═══ -->
    <div id="report-not-assessed" data-hide-if-assessed>
      <div class="not-assessed-content">
        <h1 class="not-assessed-headline">Complete your assessment to unlock your report</h1>
        <p class="not-assessed-body">
          The CS Maturity Report consolidates your domain scores, priority actions, playbooks, and metric benchmarks into a single view you can download and share. Take the assessment first to generate your personalized report.
        </p>
        <a href="/assess/" class="btn btn-primary btn-large">Take the Assessment</a>
      </div>
    </div>

    <!-- ═══ Report content (JS-populated) ═══ -->
    <div id="report-assessed" data-show-if-assessed style="display:none;">

      <!-- Report toolbar -->
      <div class="report-toolbar">
        <div class="report-overflow-menu" id="report-overflow-menu">
          <button type="button" class="report-overflow-trigger" id="report-overflow-trigger" aria-haspopup="true" aria-expanded="false" aria-label="Report options">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <circle cx="3.5" cy="8" r="1.5"/>
              <circle cx="8" cy="8" r="1.5"/>
              <circle cx="12.5" cy="8" r="1.5"/>
            </svg>
            <span class="report-overflow-label">Options</span>
          </button>
          <ul class="report-overflow-dropdown" id="report-overflow-dropdown" role="menu">
            <li role="none">
              <a href="/assess/?mode=update" class="report-menu-item" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M9.5 2.5l2 2-6.5 6.5H3v-2l6.5-6.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8.5 3.5l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Update My Answers
              </a>
            </li>
            <li class="report-menu-divider" role="separator"></li>
            <li role="none">
              <button type="button" class="report-menu-item report-menu-item--danger" id="report-restart-btn" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M11.8 5A5 5 0 1 0 12 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  <path d="M12 2.5V6H8.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Retake Assessment
              </button>
            </li>
            <li role="none">
              <button type="button" class="report-menu-item report-menu-item--danger" id="report-clear-btn" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 4h9M5 4V2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V4M10.5 4l-.6 6.8a.7.7 0 0 1-.7.7H4.8a.7.7 0 0 1-.7-.7L3.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Clear Assessment
              </button>
            </li>
          </ul>
        </div>

        <div class="report-toolbar-right">
          <button type="button" class="report-share-btn" id="report-share-btn" aria-label="Share report">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="12" cy="3.5" r="1.75" stroke="currentColor" stroke-width="1.3"/>
              <circle cx="4" cy="8" r="1.75" stroke="currentColor" stroke-width="1.3"/>
              <circle cx="12" cy="12.5" r="1.75" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5.5 7.2L10.5 4.3M5.5 8.8L10.5 11.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            <span class="report-btn-label">Share</span>
          </button>

          <button type="button" class="report-download-btn" id="download-pdf-btn" aria-label="Save report as PDF">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 2.5A1.5 1.5 0 0 1 4.5 1h4.25L13 5.25V13.5A1.5 1.5 0 0 1 11.5 15h-7A1.5 1.5 0 0 1 3 13.5v-11z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              <path d="M8.75 1v4.25H13" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              <path d="M8 7.75v4.25M6 10l2 2 2-2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="report-btn-label">Save as PDF</span>
          </button>
        </div>
      </div>

<!-- Report body — populated by JS -->
      <div id="report-content"></div>
    </div>

    <!-- ═══ Share modal ═══ -->
    <div class="share-modal" id="share-modal" role="dialog" aria-modal="true" aria-labelledby="share-modal-title" hidden>
      <div class="share-modal-backdrop" id="share-modal-backdrop"></div>
      <div class="share-modal-panel" role="document">
        <div class="share-modal-header">
          <h2 class="share-modal-title" id="share-modal-title">Share your CS report</h2>
          <button type="button" class="share-modal-close" id="share-modal-close" aria-label="Close share dialog">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.5 3.5l9 9M12.5 3.5l-9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="share-modal-tabs" role="tablist">
          <button type="button" class="share-modal-tab is-active" role="tab" id="share-tab-report" aria-selected="true" aria-controls="share-panel-report" data-share-tab="report">
            Share this report
          </button>
          <button type="button" class="share-modal-tab" role="tab" id="share-tab-score" aria-selected="false" aria-controls="share-panel-score" data-share-tab="score">
            Share your score
          </button>
        </div>

        <div class="share-modal-panel-body" role="tabpanel" id="share-panel-report" aria-labelledby="share-tab-report">
          <p class="share-modal-blurb">
            Anyone with this link can view your full report — domain scores, priority actions, and the answers behind them.
          </p>

          <label class="share-modal-toggle">
            <input type="checkbox" id="share-include-company" checked />
            <span>Include my company name in the shared report</span>
          </label>

          <div class="share-modal-link-row">
            <input type="text" id="share-report-url" class="share-modal-link" readonly />
            <button type="button" class="share-modal-copy" id="share-copy-report" data-copy-target="share-report-url">
              <span class="share-copy-default">Copy link</span>
              <span class="share-copy-done">Copied</span>
            </button>
          </div>
        </div>

        <div class="share-modal-panel-body" role="tabpanel" id="share-panel-score" aria-labelledby="share-tab-score" hidden>
          <p class="share-modal-blurb">
            Invite others to take the assessment. Your individual answers are <strong>not</strong> included.
          </p>

          <div class="share-modal-suggested">
            <span class="share-modal-suggested-label">Suggested post</span>
            <textarea id="share-score-text" class="share-modal-textarea" readonly rows="3"></textarea>
            <button type="button" class="share-modal-copy share-modal-copy--text" id="share-copy-text" data-copy-target="share-score-text">
              <span class="share-copy-default">Copy text</span>
              <span class="share-copy-done">Copied</span>
            </button>
          </div>

          <div class="share-modal-socials">
            <a href="#" class="share-modal-social" id="share-linkedin" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M14 1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM5 13H3V6h2v7zM4 5a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm9 8h-2V9.5c0-.83-.67-1.5-1.5-1.5S8 8.67 8 9.5V13H6V6h2v1c.42-.6 1.18-1 2-1 1.66 0 3 1.34 3 3v4z"/>
              </svg>
              Share on LinkedIn
            </a>
            <a href="#" class="share-modal-social" id="share-x" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M11.9 1.5h2.3l-5.05 5.77L15 14.5h-4.65l-3.64-4.76L2.5 14.5H.2l5.4-6.17L0 1.5h4.77l3.3 4.35L11.9 1.5zm-.8 11.6h1.27L4.97 2.82H3.6l7.5 10.28z"/>
              </svg>
              Share on X
            </a>
          </div>
        </div>

        <div class="share-modal-footer">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="3" y="6.5" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
            <path d="M4.5 6.5V4.5a2.5 2.5 0 0 1 5 0v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span>We don't store/track any of your report data, it stays only in your browser and the share link itself.</span>
        </div>
      </div>
    </div>

  </div>

  <script is:inline define:vars={{ logoRaw }}>
    window.__reportLogoSvg = logoRaw;
  </script>
</BaseLayout>

<style>
  .report-page {
    max-width: 56rem;
    margin: 0 auto;
    padding-top: 0;
    padding-bottom: 4rem;
  }

  /* ── Not-assessed fallback ── */
  .not-assessed-content {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-top: 1.5rem;
  }

  .not-assessed-headline {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .not-assessed-body {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 32rem;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .btn {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.2s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
  }

  .btn-large {
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }

  /* ── Report assessed wrapper: establishes stacking context for floating toolbar ── */
  #report-assessed {
    position: relative;
  }

  /* ── Report toolbar — floats over the full-bleed header image ── */
  .report-toolbar {
    position: absolute;
    top: 1.25rem;
    left: 0;
    right: 0;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    background: transparent;
    margin-bottom: 0;
    padding: 0;
  }

  /* ── Overflow menu ── */
  .report-overflow-menu {
    position: relative;
  }

  .report-overflow-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease-out;
    min-height: 0;
  }

  .report-overflow-trigger:hover,
  .report-overflow-menu.is-open .report-overflow-trigger {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  .report-overflow-label {
    font-size: inherit;
  }

  .report-overflow-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    min-width: 200px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    z-index: 50;
    padding: 0.375rem 0;
    list-style: none;
    margin: 0;
  }

  .report-overflow-menu.is-open .report-overflow-dropdown {
    display: block;
  }

  .report-menu-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--color-text-primary);
    background: transparent;
    border: none;
    text-decoration: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    min-height: 0;
  }

  .report-menu-item:hover {
    background: var(--color-surface-hover);
  }

  .report-menu-item--danger {
    color: var(--color-danger);
  }

  .report-menu-item--danger:hover {
    background: rgba(229, 57, 53, 0.06);
  }

  .report-menu-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.375rem 0;
  }

  .report-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease-out;
    min-height: 0;
  }

  .report-download-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  /* ── Toolbar right cluster: Share + Save ── */
  .report-toolbar-right {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .report-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease-out;
    min-height: 0;
  }

  .report-share-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  /* Mobile: icon-only toolbar to prevent three labeled buttons from wrapping
     onto a second row and overlapping the header content below.
     Kept after all base button rules so equal-specificity overrides win on source order. */
  @media (max-width: 639px) {
    .report-toolbar {
      flex-wrap: nowrap;
      gap: 0.375rem;
    }
    .report-overflow-label,
    .report-btn-label {
      display: none;
    }
    .report-overflow-trigger,
    .report-share-btn,
    .report-download-btn {
      padding: 0.5rem 0.625rem;
      gap: 0;
    }
    .report-toolbar-right {
      gap: 0.375rem;
    }
  }

  /* ── Shared-view banner — tinted callout with stage stripe ── */
  .shared-banner {
    background: var(--color-accent-subtle);
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    border-left: 4px solid var(--stage-color, var(--color-accent));
  }

  .shared-banner[hidden] {
    display: none;
  }

  .shared-banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.25rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    color: var(--color-text-primary);
    flex-wrap: wrap;
  }

  .shared-banner-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .shared-banner-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--stage-color, var(--color-accent));
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--stage-color, var(--color-accent)) 14%, transparent);
    flex-shrink: 0;
    align-self: center;
  }

  .shared-banner-headline {
    font-size: 0.9375rem;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .shared-banner-headline strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .shared-banner-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    background: var(--color-bg);
    border: 1px solid color-mix(in srgb, var(--color-accent) 45%, transparent);
    border-radius: 0.375rem;
    text-decoration: none;
    transition: all 0.18s ease-out;
    flex-shrink: 0;
    min-height: 0;
  }

  .shared-banner-cta:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  @media (pointer: coarse) {
    .shared-banner-cta {
      min-height: 44px;
      padding: 0.5rem 0.875rem;
    }
  }

  /* ── Version mismatch footnote (sits at top of report body) ── */
  .report-version-notice {
    background: color-mix(in srgb, var(--color-warning) 12%, var(--color-bg));
    border: 1px solid color-mix(in srgb, var(--color-warning) 40%, transparent);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .report-version-notice strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* ── Share modal ── */
  .share-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .share-modal[hidden] {
    display: none;
  }

  .share-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.18s ease-out;
  }

  .share-modal.is-open .share-modal-backdrop {
    opacity: 1;
  }

  .share-modal-panel {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.22);
    width: 100%;
    max-width: 32rem;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    transform: translateY(8px);
    opacity: 0;
    transition: opacity 0.18s ease-out, transform 0.18s ease-out;
  }

  .share-modal.is-open .share-modal-panel {
    opacity: 1;
    transform: translateY(0);
  }

  .share-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.25rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
  }

  .share-modal-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text-secondary);
    letter-spacing: -0.005em;
  }

  .share-modal-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    background: transparent;
    border: 1px solid transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s ease-out;
    min-height: 0;
  }

  .share-modal-close:hover {
    background: var(--color-surface);
    color: var(--color-text-primary);
  }

  @media (pointer: coarse) {
    .share-modal-close {
      min-width: 44px;
      min-height: 44px;
      width: 44px;
      height: 44px;
    }
  }

  .share-modal-tabs {
    display: flex;
    gap: 0;
    padding: 0 1.25rem;
