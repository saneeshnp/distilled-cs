---
import BaseLayout from '../layouts/BaseLayout.astro';
import frameworkData from '../data/lean-cs-data.json';
import logoRaw from '../assets/logo-mark.svg?raw';

const stages = frameworkData.maturity_stages.stages;
const domains = frameworkData.assessment_domains.domains;
const playbooks = frameworkData.playbooks;
const metrics = frameworkData.metrics_directory.metrics;
const stageTransitions = frameworkData.stage_transitions;
const contextualRecs = frameworkData.contextual_recommendations;
---

<BaseLayout title="CS Maturity Report" description="Your personalized Customer Success maturity report with domain breakdown, priority actions, and recommended playbooks." noindex={true}>

  <!-- ═══ Loading overlay (shown only when redirected from assess) ═══ -->
  <div id="report-loading" style="display:none;" aria-live="polite" aria-label="Building your report">
    <div class="report-loading-inner">
      <p class="report-loading-title" id="report-loading-title">Building your report…</p>
      <div class="report-loading-progress" aria-hidden="true">
        <div class="report-loading-fill" id="report-loading-fill"></div>
      </div>
      <span class="report-loading-spinner" aria-hidden="true"></span>
    </div>
  </div>
  <script is:inline>
    (function () {
      var flag = sessionStorage.getItem('distilledcs_just_assessed');
      if (flag) {
        var overlay = document.getElementById('report-loading');
        var title = document.getElementById('report-loading-title');
        if (overlay) overlay.style.display = '';
        if (title) title.textContent = flag === 'update' ? 'Updating your report…' : 'Building your report…';
      }
    })();
  </script>

  <div class="container report-page">

    <!-- ═══ Not-assessed fallback ═══ -->
    <div id="report-not-assessed" data-hide-if-assessed>
      <div class="not-assessed-content">
        <h1 class="not-assessed-headline">Complete your assessment to unlock your report</h1>
        <p class="not-assessed-body">
          The CS Maturity Report consolidates your domain scores, priority actions, playbooks, and metric benchmarks into a single view you can download and share. Take the assessment first to generate your personalized report.
        </p>
        <a href="/assess/" class="btn btn-primary btn-large">Take the Assessment</a>
      </div>
    </div>

    <!-- ═══ Report content (JS-populated) ═══ -->
    <div id="report-assessed" data-show-if-assessed style="display:none;">

      <!-- Report toolbar -->
      <div class="report-toolbar">
        <div class="report-overflow-menu" id="report-overflow-menu">
          <button type="button" class="report-overflow-trigger" id="report-overflow-trigger" aria-haspopup="true" aria-expanded="false" aria-label="Report options">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <circle cx="3.5" cy="8" r="1.5"/>
              <circle cx="8" cy="8" r="1.5"/>
              <circle cx="12.5" cy="8" r="1.5"/>
            </svg>
            <span class="report-overflow-label">Options</span>
          </button>
          <ul class="report-overflow-dropdown" id="report-overflow-dropdown" role="menu">
            <li role="none">
              <a href="/assess/?mode=update" class="report-menu-item" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M9.5 2.5l2 2-6.5 6.5H3v-2l6.5-6.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8.5 3.5l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Update My Answers
              </a>
            </li>
            <li class="report-menu-divider" role="separator"></li>
            <li role="none">
              <button type="button" class="report-menu-item report-menu-item--danger" id="report-restart-btn" role="menuitem">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 4h9M5 4V2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V4M10.5 4l-.6 6.8a.7.7 0 0 1-.7.7H4.8a.7.7 0 0 1-.7-.7L3.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Clear &amp; Restart
              </button>
            </li>
          </ul>
        </div>

        <button type="button" class="report-download-btn" id="download-pdf-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4.5 1h5l3.5 3.5V13a2 2 0 0 1-2 2H4.5A1.5 1.5 0 0 1 3 13.5v-11A1.5 1.5 0 0 1 4.5 1z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9.5 1v3.5H13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Print / Save PDF
        </button>
      </div>

<!-- Report body — populated by JS -->
      <div id="report-content"></div>
    </div>

  </div>

  <script is:inline define:vars={{ logoRaw }}>
    window.__reportLogoSvg = logoRaw;
  </script>
</BaseLayout>

<style>
  .report-page {
    max-width: 56rem;
    margin: 0 auto;
    padding-top: 0;
    padding-bottom: 4rem;
  }

  /* ── Not-assessed fallback ── */
  .not-assessed-content {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-top: 1.5rem;
  }

  .not-assessed-headline {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .not-assessed-body {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 32rem;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .btn {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.2s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
  }

  .btn-large {
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }

  /* ── Report assessed wrapper: establishes stacking context for floating toolbar ── */
  #report-assessed {
    position: relative;
  }

  /* ── Report toolbar — floats over the full-bleed header image ── */
  .report-toolbar {
    position: absolute;
    top: 1.25rem;
    left: 0;
    right: 0;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    background: transparent;
    margin-bottom: 0;
    padding: 0;
  }

  /* ── Overflow menu ── */
  .report-overflow-menu {
    position: relative;
  }

  .report-overflow-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease-out;
    min-height: 0;
  }

  .report-overflow-trigger:hover,
  .report-overflow-menu.is-open .report-overflow-trigger {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  .report-overflow-label {
    font-size: inherit;
  }

  .report-overflow-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    min-width: 200px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    z-index: 50;
    padding: 0.375rem 0;
    list-style: none;
    margin: 0;
  }

  .report-overflow-menu.is-open .report-overflow-dropdown {
    display: block;
  }

  .report-menu-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--color-text-primary);
    background: transparent;
    border: none;
    text-decoration: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    min-height: 0;
  }

  .report-menu-item:hover {
    background: var(--color-surface-hover);
  }

  .report-menu-item--danger {
    color: var(--color-danger);
  }

  .report-menu-item--danger:hover {
    background: rgba(229, 57, 53, 0.06);
  }

  .report-menu-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.375rem 0;
  }

  .report-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s ease-out;
    min-height: 0;
  }

  .report-download-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  /* ── Loading overlay ── */
  #report-loading {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    transition: opacity 0.35s ease-out;
  }

  #report-loading.is-done {
    opacity: 0;
    pointer-events: none;
  }

  .report-loading-inner {
    text-align: center;
    width: 100%;
    max-width: 360px;
    padding: 0 1.5rem;
  }

  .report-loading-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
  }

  .report-loading-progress {
    width: 100%;
    height: 4px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-radius: 999px;
    overflow: hidden;
  }

  .report-loading-fill {
    width: 0%;
    height: 100%;
    background: var(--color-accent);
    border-radius: 999px;
  }

  .report-loading-fill.is-running {
    animation: report-load 1.5s ease-out forwards;
  }

  @keyframes report-load {
    0%   { width: 0%; }
    20%  { width: 38%; }
    45%  { width: 38%; }
    100% { width: 100%; }
  }

  .report-loading-spinner {
    display: block;
    width: 44px;
    height: 44px;
    border: 4px solid;
    border-color: var(--color-accent) transparent;
    border-radius: 50%;
    margin: 2.25rem auto 0;
    box-sizing: border-box;
    animation: report-spin 0.9s linear infinite;
  }

  @keyframes report-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .report-loading-spinner {
      animation: none;
      opacity: 0.4;
    }
  }

  @media print {
    #report-loading { display: none !important; }
  }

  @media print {
    .report-download-btn {
      display: none !important;
    }
  }

</style>

<style is:global>
  /* ── Styles for JS-injected report content ── */

  /* Section spacing */
  .report-section {
    margin-bottom: 2.5rem;
  }

  .report-section-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Section 1: Header ── */
  .report-header {
    margin-bottom: 2.5rem;
    border-radius: 0;
    overflow: hidden;
    position: relative;
    background-image: url('/images/cs-report-header.png');
    background-size: cover;
    background-position: center 30%;
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  /* Stage-tinted overlay — inherits --stage-color from the outer .stage-* class */
  .report-header-tint {
    position: absolute;
    inset: 0;
    background: var(--stage-color, #2D6A5A);
    opacity: 0.62;
  }

  /* Dark mode: pastels would lighten the image — replace with a near-black overlay instead.
     Extra .report-header in the selector raises specificity to (0,4,0), beating all
     per-stage overrides (0,3,0) that follow in the file. */
  :root[data-theme="dark"] .report-header .report-header-tint {
    background: rgba(0, 0, 0, 0.65);
    opacity: 1;
  }

  /* Dark mode: use pastel stage colors for key data points — vivid on near-black */
  :root[data-theme="dark"] .report-header .report-stage-name {
    color: var(--stage-color);
  }

  :root[data-theme="dark"] .report-header .report-score {
    color: var(--stage-color);
  }

  :root[data-theme="dark"] .report-score-ring-fill {
    stroke: var(--stage-color);
  }

  /* Walk stage: amber is inherently lighter than teal/red — use deeper burnt amber */
  .report-header.stage-walk .report-header-tint {
    background: #e07100;
    opacity: 0.75;
  }

  /* Run stage: Material 700 green is too light at base opacity — use Material 800 */
  .report-header.stage-run .report-header-tint {
    background: #2e7d32;
    opacity: 0.72;
  }

  /* All logo/title/cards sit above the tint */
  .report-header-content {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem 1.75rem;
    text-align: center;
    max-width: 56rem;
    margin-inline: auto;
  }

  .report-header-logo {
    display: none; /* hidden on screen — site nav already shows the logo */
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .report-header-logo-mark svg {
    display: block;
    height: 28px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .report-header-logo-wordmark {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1;
  }

  .report-header-logo-accent {
    color: rgba(255, 255, 255, 0.95);
  }

  .report-header-label {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  /* ── Two-card row ── */
  .report-header-cards {
    display: flex;
    gap: 1rem;
    align-items: stretch;
    margin-bottom: 0.75rem;
  }

  .report-header-stage-card {
    flex: 1;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 0.75rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .report-header-score-card {
    flex: 1;
    padding: 1.25rem 1rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .report-header-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.375rem;
  }

  .report-header .report-stage-name {
    font-family: var(--font-body);
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 0.375rem;
    color: #fff;
  }

  .report-header .report-stage-subtitle {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .report-score-ring-wrap {
    position: relative;
    width: 90px;
    height: 90px;
    margin: 0.75rem auto 0.5rem;
  }

  .report-score-ring {
    width: 90px;
    height: 90px;
    display: block;
  }

  .report-score-ring-track {
    fill: none;
    stroke: rgba(255, 255, 255, 0.2);
    stroke-width: 10;
  }

  .report-score-ring-fill {
    fill: none;
    stroke: rgba(255, 255, 255, 0.9);
    stroke-width: 10;
    stroke-linecap: round;
    transform: rotate(-90deg);
    transform-origin: 60px 60px;
    stroke-dasharray: 339.29;
    stroke-dashoffset: 339.29;
  }

  .report-score-ring-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .report-header .report-score {
    font-family: var(--font-body);
    font-size: 1.625rem;
    font-weight: 600;
    color: #fff;
    line-height: 1;
  }

  .report-score-unit {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ── Profile strip ── */
  .report-header-profile {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: 0;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .report-header-profile-label {
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 0.2rem;
  }

  .report-header-profile-company {
    font-weight: 700;
    color: #fff;
    font-size: 0.8125rem;
  }

  .report-header-profile-sep {
    margin: 0 0.3rem;
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.75rem;
  }

  .report-header-attribution {
    display: block;
    text-align: center;
    margin-top: 0.5rem;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.75rem;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  .report-header-attribution:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  /* ── Section 2: Executive Summary ── */
  .report-summary-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }

  .report-profile-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .report-profile-item {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .report-profile-item strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* ── Section 3: Domain Breakdown ── */
  .report-domain-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .report-domain-row:last-child {
    border-bottom: none;
  }

  .report-domain-label {
    flex: 0 0 14rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .report-header-content {
      padding-inline: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .report-header-content {
      padding-inline: 3rem;
    }
  }

  @media (max-width: 640px) {
    .report-header-content {
      padding: 5.5rem 1.5rem 1.25rem;
    }

    .report-header-cards {
      flex-direction: column;
    }

    .report-header .report-stage-name {
      font-size: 1.625rem;
    }

    .report-header .report-score {
      font-size: 1.625rem;
    }

    .report-header-profile {
      flex-wrap: wrap;
      gap: 0.2rem 0;
    }

    .report-domain-row {
      flex-wrap: wrap;
    }

    .report-domain-label {
      flex: 1 1 100%;
    }
  }

  .report-domain-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .report-domain-tag-strong {
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  .report-domain-tag-weak {
    background: color-mix(in srgb, var(--color-warning) 15%, transparent);
    color: var(--color-warning);
  }

  .report-domain-tag-new {
    background: color-mix(in srgb, var(--color-text-muted) 15%, transparent);
    color: var(--color-text-muted);
  }

  .report-domain-bar-wrap {
    flex: 1;
    height: 0.5rem;
    background: var(--color-border);
    border-radius: 999px;
    overflow: hidden;
    min-width: 6rem;
  }

  .report-domain-bar {
    height: 100%;
    border-radius: 999px;
    background: var(--stage-color, var(--color-accent));
    transition: width 0.3s ease-out;
  }

  .report-domain-score {
    flex: 0 0 3rem;
    text-align: right;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .report-domain-delta {
    flex: 0 0 3.5rem;
    text-align: right;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .report-delta-up { color: #388E3C; }
  .report-delta-down { color: #D32F2F; }
  .report-delta-same { color: var(--color-text-secondary); }

