<script>
  import { getProfile, getScores, isAssessmentCompleted, resetAll } from '../scripts/context-manager.js';
  import frameworkData from '../data/lean-cs-data.json';
  import {
    composePriorityActions,
    composeStrengths,
    composePlaybookRecommendations,
    composeMetricPriorities,
  } from '../scripts/recommendation-engine.js';
  import { toDisplayScore } from '../scripts/scoring-engine.js';

  const stages = (frameworkData as any).maturity_stages.stages;
  const domains = (frameworkData as any).assessment_domains.domains;
  const allPlaybooks = (frameworkData as any).playbooks;
  const allMetrics = (frameworkData as any).metrics_directory.metrics;
  const stageTransitions = (frameworkData as any).stage_transitions;
  const contextParams = (frameworkData as any).context_parameters.parameters;

  const stageOrder = ['crawl', 'walk', 'run'];
  const domainLabels: Record<string, string> = {};
  domains.forEach((d: any) => { domainLabels[d.id] = d.label; });

  // ── Toggle assessed/not-assessed views ──
  const completed = isAssessmentCompleted();

  if (completed) {
    const reportData = getReportData();
    if (reportData) {
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => (el as HTMLElement).style.display = '');
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => (el as HTMLElement).style.display = 'none');
      renderReport(reportData);
      const hadOverlay = dismissLoadingOverlay();
      if (!hadOverlay) animateScoreCountUp();
    }
    // If completed flag is set but data is corrupt/missing, fallback CTA stays visible
  }

  function dismissLoadingOverlay(): boolean {
    const overlay = document.getElementById('report-loading');
    if (!overlay || overlay.style.display === 'none') return false;

    const fill = document.getElementById('report-loading-fill');
    const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;

    sessionStorage.removeItem('distilledcs_just_assessed');

    if (reduced) {
      overlay.style.display = 'none';
      animateScoreCountUp();
      return true;
    }

    if (fill) fill.classList.add('is-running');

    setTimeout(() => {
      overlay.classList.add('is-done');
      setTimeout(() => {
        overlay.style.display = 'none';
        animateScoreCountUp();
      }, 350);
    }, 1500);

    return true;
  }

  // ── Data layer ──
  interface ReportData {
    companyName: string;
    profile: Record<string, string>;
    domainScores: Record<string, number>;
    overallScore: number;
    stage: string;
    responses: Record<string, number>;
    timestamp: string;
    previousScores: any | null;
    checklistProgress: Record<string, boolean> | null;
  }

  function getReportData(): ReportData | null {
    // Future: const urlData = parseURLParams(); if (urlData) return urlData;
    return buildFromLocalStorage();
  }

  function buildFromLocalStorage(): ReportData | null {
    const scores = getScores();
    const profile = getProfile();
    if (!scores || !scores.domainScores) return null;

    let previousScores = null;
    try {
      const raw = localStorage.getItem('distilledcs_previous_scores');
      if (raw) previousScores = JSON.parse(raw);
    } catch {}

    let checklistProgress = null;
    try {
      const raw = localStorage.getItem('distilledcs_checklist');
      if (raw) checklistProgress = JSON.parse(raw);
    } catch {}

    return {
      companyName: profile?.company_name || '',
      profile: profile || {},
      domainScores: scores.domainScores,
      overallScore: scores.overallScore,
      stage: scores.stage,
      responses: scores.responses || {},
      timestamp: scores.timestamp || '',
      previousScores,
      checklistProgress,
    };
  }

  // ── Helpers ──
  function getStageData(stageId: string) {
    return stages.find((s: any) => s.id === stageId);
  }

  function getProfileLabel(paramId: string, optionId: string): string {
    const param = contextParams.find((p: any) => p.id === paramId);
    if (!param) return optionId;
    const opt = param.options.find((o: any) => o.id === optionId);
    return opt?.label || optionId;
  }

  function barStageClass(score: number): string {
    if (score >= 3.0) return 'run';
    if (score >= 2.0) return 'walk';
    return 'crawl';
  }

  function joinList(items: string[]): string {
    if (items.length === 0) return '';
    if (items.length === 1) return items[0];
    if (items.length === 2) return `${items[0]} and ${items[1]}`;
    return `${items.slice(0, -1).join(', ')}, and ${items[items.length - 1]}`;
  }

  function formatDate(iso: string): string {
    if (!iso) return '';
    try {
      const d = new Date(iso);
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    } catch { return ''; }
  }

  // ── Render ──
  function renderReport(data: ReportData) {
    const el = document.getElementById('report-content');
    if (!el) return;

    const stage = getStageData(data.stage);
    const currentIdx = stageOrder.indexOf(data.stage);
    const nextStageId = currentIdx < 2 ? stageOrder[currentIdx + 1] : null;
    const nextStage = nextStageId ? getStageData(nextStageId) : null;
    const transitionKey = nextStageId ? `${data.stage}_to_${nextStageId}` : null;
    const transition = transitionKey ? (stageTransitions as any)[transitionKey] : null;

    // Phase 1: render header immediately — no fade, visible on first paint
    el.innerHTML = renderHeader(data, stage);

    // Phase 2: build body sections into a reveal wrapper that fades in after the header
    const bodySections: string[] = [];

    // Summary needs stage data
    if (stage) bodySections.push(renderSummary(data, stage));

    // Strengths: response-composed, only renders when ≥ 2 high-score fragments exist
    const strengthsHtml = renderStrengths(data);
    if (strengthsHtml) bodySections.push(strengthsHtml);

    // Domain breakdown needs scores
    if (data.domainScores && Object.keys(data.domainScores).length) {
      bodySections.push(renderDomainBreakdown(data));
    }

    // Priority actions: response-composed, falls back to stage actions gracefully
    bodySections.push(renderPriorityActions(data));

    // Playbooks need a valid stage
    if (data.stage) bodySections.push(renderPlaybooks(data, nextStageId));

    // Metrics need a valid stage
    if (data.stage) bodySections.push(renderMetrics(data));

    // Maturity model always renders
    bodySections.push(renderMaturityModel(data));

    // Transition guide only if not at Run (Run is the top stage — no next transition)
    if (transition) bodySections.push(renderTransitionGuide(data, nextStage, transition));

    // Footer — generation timestamp + link to re-assess
    bodySections.push(renderFooter(data));

    // Append body wrapper (starts invisible)
    const bodyEl = document.createElement('div');
    bodyEl.className = 'report-body-reveal';
    bodyEl.innerHTML = bodySections.join('');
    el.appendChild(bodyEl);

    // Build ToC — inserts card as first child of .report-body-reveal so it fades in with the body
    buildToc();

    const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
    const headerContent = el.querySelector<HTMLElement>('.report-header-content-reveal');

    if (reduced) {
      // Reduced motion: show everything immediately, no transitions
      if (headerContent) headerContent.classList.add('is-visible');
      bodyEl.classList.add('is-visible');
    } else {
      // Header content slides up on the next paint (double-RAF so the browser registers the initial opacity:0 state)
      requestAnimationFrame(() => requestAnimationFrame(() => {
        if (headerContent) headerContent.classList.add('is-visible');
      }));
      // Body fades in 500ms later — after the header animation has fully settled
      setTimeout(() => bodyEl.classList.add('is-visible'), 500);
    }
  }

  function animateScoreCountUp() {
    const el = document.querySelector('.report-header-score-card .report-score') as HTMLElement | null;
    const ring = document.querySelector('.report-score-ring-fill') as SVGCircleElement | null;
    if (!el) return;

    const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;

    const targetText = el.textContent?.trim() ?? '';
    const targetNum = parseFloat(targetText);
    if (!isFinite(targetNum)) return;

    const decimals = targetText.includes('.') ? targetText.split('.')[1].length : 0;
    const circumference = 339.29;
    const targetOffset = circumference - (targetNum / 10) * circumference;

    if (reduced) {
      if (ring) ring.style.strokeDashoffset = String(targetOffset);
      return;
    }

    el.textContent = (0).toFixed(decimals);
    if (ring) ring.style.strokeDashoffset = String(circumference);

    const duration = 800;
    const startTime = performance.now();

    const tick = (now: number) => {
      const t = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3);
      el.textContent = (targetNum * eased).toFixed(decimals);
      if (ring) ring.style.strokeDashoffset = String(circumference - eased * (targetNum / 10) * circumference);
      if (t < 1) requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  }

  // ── Table of contents ──
  function buildToc() {
    const content = document.getElementById('report-content');
    if (!content) return;

    const sectionEls = Array.from(content.querySelectorAll('.report-section[id]')) as HTMLElement[];
    if (!sectionEls.length) return;

    const itemsHtml = sectionEls.map(s => {
      const label = s.querySelector('h2.report-section-title')?.textContent?.trim() || '';
      return label ? `<li class="report-toc-item"><a href="#${s.id}" class="report-toc-link">${label}</a></li>` : '';
    }).filter(Boolean).join('');

    const card = document.createElement('div');
    card.className = 'report-toc-card';
    card.innerHTML = `<p class="report-toc-card-label">In this report</p><ol class="report-toc-list">${itemsHtml}</ol>`;

    // Prepend into .report-body-reveal so the ToC fades in with the body content
    const bodyReveal = content.querySelector('.report-body-reveal');
    if (bodyReveal) {
      bodyReveal.insertBefore(card, bodyReveal.firstChild);
    } else {
      // Fallback: insert after header (matches original behaviour)
      const reportHeader = content.querySelector('.report-header');
      if (reportHeader) reportHeader.insertAdjacentElement('afterend', card);
    }

    // Offset for sticky header
    sectionEls.forEach(s => { s.style.scrollMarginTop = '5rem'; });
  }

  function renderFooter(data: ReportData): string {
    const generated = formatDateTime(data.timestamp);
    return `
      <div class="report-footer">
        <p>
          This report was generated on
          <a href="https://distilledcs.org" target="_blank" rel="noopener noreferrer">DistilledCS.org</a>${generated ? ` on ${generated}` : ''}.
        </p>
        <p>
          For an updated report, please visit
          <a href="/assess/">distilledcs.org/assess</a>.
        </p>
      </div>
    `;
  }

  function formatDateTime(iso?: string): string {
    if (!iso) return '';
    try {
      const d = new Date(iso);
      return d.toLocaleString('en-US', {
        year: 'numeric', month: 'long', day: 'numeric',
        hour: 'numeric', minute: '2-digit'
      });
    } catch { return ''; }
  }

  // ── Section 1: Header ──
  function renderHeader(data: ReportData, stage: any): string {
    const score = typeof data.overallScore === 'number' ? toDisplayScore(data.overallScore) : '—';
    return `
      <div class="report-header stage-${data.stage}">
        <div class="report-header-tint" aria-hidden="true"></div>
        <div class="report-header-content report-header-content-reveal">
          <a href="/" class="report-header-logo" aria-label="Distilled CS home">
            <span class="report-header-logo-mark" aria-hidden="true">${(window as any).__reportLogoSvg || ''}</span>
            <span class="report-header-logo-wordmark"><span>Distilled</span><span class="report-header-logo-accent">CS</span></span>
          </a>
          <h1 class="report-header-label">Customer Success Assessment Report</h1>
          <div class="report-header-cards stage-${data.stage}">
            <div class="report-header-stage-card">
              <div class="report-header-eyebrow">${data.companyName ? `${data.companyName}'s CS Stage` : 'Your CS Stage'}</div>
              <div class="report-stage-name">${stage?.label || data.stage}</div>
              <p class="report-stage-subtitle">${stage?.subtitle || ''}</p>
            </div>
            <div class="report-header-score-card stage-${data.stage}">
              <div class="report-header-eyebrow">Overall Score</div>
              <div class="report-score-ring-wrap">
                <svg class="report-score-ring" viewBox="0 0 120 120" aria-hidden="true">
                  <circle class="report-score-ring-track" cx="60" cy="60" r="54"/>
                  <circle class="report-score-ring-fill" cx="60" cy="60" r="54"/>
                </svg>
                <div class="report-score-ring-inner">
                  <div class="report-score">${score}</div>
                </div>
              </div>
              <div class="report-score-unit">out of 10</div>
            </div>
          </div>
          ${renderProfileTags(data)}
          <a href="/" class="report-header-attribution">distilledcs.org</a>
        </div>
      </div>
    `;
  }

  function renderProfileTags(data: ReportData): string {
    const displayParams = [
      { key: 'company_arr',       label: 'ARR'       },
      { key: 'customer_segment',  label: 'Segment'   },
      { key: 'cs_team_size',      label: 'Team'      },
      { key: 'industry_vertical', label: 'Industry'  },
    ];
    const items = displayParams
      .map(p => {
        const val = data.profile[p.key];
        return val
          ? `<span class="report-header-profile-item"><span class="report-header-profile-label">${p.label}</span> ${getProfileLabel(p.key, val)}</span>`
          : '';
      })
      .filter(Boolean);
    return items.length
      ? `<div class="report-header-profile">${items.join('<span class="report-header-profile-sep" aria-hidden="true">·</span>')}</div>`
      : '';
  }

  // ── Section 2: Executive Summary ──
  function renderSummary(data: ReportData, stage: any): string {
    const arr       = data.profile?.company_arr;
    const segment   = data.profile?.customer_segment;
    const teamSize  = data.profile?.cs_team_size;
    const industry  = data.profile?.industry_vertical;
    const teamAge   = data.profile?.cs_team_age;
    const opsExists = data.profile?.cs_ops_exists;

    const arrLabel      = arr     ? getProfileLabel('company_arr', arr)       : null;
    const industryLabel = (industry && industry !== 'ind_other')
      ? getProfileLabel('industry_vertical', industry) : null;
    const teamSizeLabel = teamSize ? getProfileLabel('cs_team_size', teamSize) : null;
    const teamAgeLabel  = teamAge  ? getProfileLabel('cs_team_age', teamAge)   : null;

    // "Mixed segments" reads poorly as "serving Mixed segments customers" — skip in prose,
    // it still appears in the profile metadata row below.
    const segmentProseMap: Record<string, string> = {
      seg_smb: 'SMB', seg_midmarket: 'Mid-Market', seg_enterprise: 'Enterprise',
    };
    const segProseLabel = segment ? (segmentProseMap[segment] ?? null) : null;

    const paragraphs: string[] = [];

    // ── Para 1: Company identity ──
    const nameRef = data.companyName || null;
    let identitySentence = '';

    if (nameRef) {
      // Named company: use active verb form to avoid fragments when industry is absent
      if (industryLabel && segProseLabel && arrLabel) {
        identitySentence = `${nameRef} is a ${industryLabel} company serving ${segProseLabel} customers with ${arrLabel} in ARR.`;
      } else if (industryLabel && segProseLabel) {
        identitySentence = `${nameRef} is a ${industryLabel} company serving ${segProseLabel} customers.`;
      } else if (industryLabel && arrLabel) {
        identitySentence = `${nameRef} is a ${industryLabel} company with ${arrLabel} in ARR.`;
      } else if (industryLabel) {
        identitySentence = `${nameRef} is a ${industryLabel} company.`;
      } else if (segProseLabel && arrLabel) {
        identitySentence = `${nameRef} serves ${segProseLabel} customers with ${arrLabel} in ARR.`;
      } else if (segProseLabel) {
        identitySentence = `${nameRef} serves ${segProseLabel} customers.`;
      } else if (arrLabel) {
        identitySentence = `${nameRef} has ${arrLabel} in ARR.`;
      }
      // name only → skip; it's already prominent in the report header
    } else {
      if (industryLabel && segProseLabel && arrLabel) {
        identitySentence = `Your company is a ${industryLabel} business serving ${segProseLabel} customers with ${arrLabel} in ARR.`;
      } else if (industryLabel && segProseLabel) {
        identitySentence = `Your company is a ${industryLabel} business serving ${segProseLabel} customers.`;
      } else if (industryLabel && arrLabel) {
        identitySentence = `Your company is a ${industryLabel} business with ${arrLabel} in ARR.`;
      } else if (industryLabel) {
        identitySentence = `Your company operates in the ${industryLabel} space.`;
      } else if (segProseLabel && arrLabel) {
        identitySentence = `Your company serves ${segProseLabel} customers with ${arrLabel} in ARR.`;
      } else if (segProseLabel) {
        identitySentence = `Your company serves ${segProseLabel} customers.`;
      } else if (arrLabel) {
        identitySentence = `Your company has ${arrLabel} in ARR.`;
      }
    }

    // Team sentence: team age only makes sense as a modifier on team size, so it's
    // only included when team size is known.
    let teamSentence = '';
    if (teamSizeLabel) {
      const teamParts: string[] = [`a CS team of ${teamSizeLabel.toLowerCase()}`];
      if (opsExists === 'ops_yes') teamParts.push('a dedicated CS Ops function');

      teamSentence = `You have ${joinList(teamParts)}`;

      if (teamAge === 'age_under_1y') {
        teamSentence += ', established less than a year ago';
      } else if (teamAgeLabel) {
        teamSentence += `, with ${teamAgeLabel.toLowerCase()} of operating history`;
      }
      teamSentence += '.';
    } else if (opsExists === 'ops_yes') {
      // CS Ops context without team size — still worth surfacing
      teamSentence = 'You have a dedicated CS Ops function in place.';
    }

    const para1 = [identitySentence, teamSentence].filter(Boolean).join(' ');
    if (para1) paragraphs.push(`<p class="report-summary-text">${para1}</p>`);

    // ── Para 2: Stage verdict ──
    if (stage) {
      paragraphs.push(`<p class="report-summary-text">Your assessment places your CS function at the <strong>${stage.label}</strong> stage (${stage.subtitle}). ${stage.description}</p>`);
    }

    // ── Para 3: Overall score + domain picture ──
    const domainEntries = Object.entries(data.domainScores || {})
      .sort((a: any, b: any) => b[1] - a[1]);
    if (typeof data.overallScore === 'number' && domainEntries.length >= 2) {
      const scoreDisplay = toDisplayScore(data.overallScore);
      const [strongId, strongScore] = domainEntries[0] as [string, number];
      const [weakId,   weakScore]   = domainEntries[domainEntries.length - 1] as [string, number];
      const strongLabel = domainLabels[strongId] || strongId;
      const weakLabel   = domainLabels[weakId]   || weakId;

      const scoreContext = data.overallScore >= 3.0
        ? 'strong foundations and active optimisation across most domains'
        : data.overallScore >= 2.0
          ? 'solid structures in place, not yet operating at full scale'
          : 'early-stage foundations still being built';

      let para3 = `Your overall score of <strong>${scoreDisplay} / 10</strong> reflects ${scoreContext}. <strong>${strongLabel}</strong> is your highest-performing domain at ${toDisplayScore(strongScore as number)}/10, while <strong>${weakLabel}</strong> (${toDisplayScore(weakScore as number)}/10) is where focused work will have the most impact.`;

      const lowCount = domainEntries.filter(([_, s]: any) => (s as number) < 2.0).length;
      if (lowCount >= 3) {
        para3 += ` ${lowCount} of your ${domainEntries.length} domains scored below 5/10, pointing to a broad foundational gap rather than an isolated weakness.`;
      }

      paragraphs.push(`<p class="report-summary-text">${para3}</p>`);
    }

    // ── Para 4: Segment + team-size template from JSON ──
    // Key mapping: profile stores size_1_3/size_4_10 etc., templates use team_1_3/team_4_10 etc.
    const sizeKeyMap: Record<string, string> = {
      size_1_3: 'team_1_3', size_4_10: 'team_4_10',
      size_11_25: 'team_10plus', size_over_25: 'team_10plus',
    };
    const segKeyMap: Record<string, string> = {
      seg_smb: 'seg_smb', seg_midmarket: 'seg_midmarket', seg_enterprise: 'seg_enterprise',
    };
    const segKey  = segment  ? segKeyMap[segment]   : null;
    const sizeKey = teamSize ? sizeKeyMap[teamSize] : null;
    const profileSentence = segKey && sizeKey
      ? (frameworkData as any).executive_summary_templates?.[segKey]?.[sizeKey] ?? null
      : null;
    if (profileSentence) paragraphs.push(`<p class="report-summary-text">${profileSentence}</p>`);

    return `
      <div id="report-section-summary" class="report-section">
        <h2 class="report-section-title">Executive Summary</h2>
        ${paragraphs.join('\n')}
      </div>
    `;
  }

  // ── Section 3: Domain Breakdown ──
  function renderDomainBreakdown(data: ReportData): string {
    const sorted = Object.entries(data.domainScores).sort((a, b) => b[1] - a[1]);
    const strongestId = sorted[0]?.[0];
    const weakestId = sorted[sorted.length - 1]?.[0];
    const hasPrevious = data.previousScores?.domainScores;

    const rows = sorted.map(([id, score]) => {
      const pct = ((score / 4) * 100).toFixed(0);
      const stageClass = barStageClass(score);
      const isStrong = id === strongestId;
      const isWeak = id === weakestId;

      let deltaHtml = '';
      if (hasPrevious) {
        if (data.previousScores.domainScores[id] !== undefined) {
          const prev = data.previousScores.domainScores[id];
          const delta = score - prev;
          if (Math.abs(delta) >= 0.05) {
            const cls = delta > 0 ? 'report-delta-up' : 'report-delta-down';
            const arrow = delta > 0 ? '&#9650;' : '&#9660;';
            deltaHtml = `<span class="report-domain-delta ${cls}">${arrow} ${(Math.abs(delta) * 2.5).toFixed(1)}</span>`;
          } else {
            deltaHtml = `<span class="report-domain-delta report-delta-same">—</span>`;
          }
        } else {
          deltaHtml = `<span class="report-domain-delta"><span class="report-domain-tag report-domain-tag-new">New</span></span>`;
        }
      }

      const label = domainLabels[id] || id;
      return `
        <div class="report-domain-row stage-${stageClass}" role="group" aria-label="${label}: ${toDisplayScore(score)} out of 10">
          <span class="report-domain-label">
            ${label}
            ${isStrong ? '<span class="report-domain-tag report-domain-tag-strong">Strongest</span>' : ''}
            ${isWeak ? '<span class="report-domain-tag report-domain-tag-weak">Needs Focus</span>' : ''}
          </span>
          <div class="report-domain-bar-wrap" role="progressbar" aria-valuenow="${toDisplayScore(score)}" aria-valuemin="0" aria-valuemax="10" aria-label="${label} score">
            <div class="report-domain-bar" style="width:${pct}%"></div>
          </div>
          <span class="report-domain-score">${toDisplayScore(score)}</span>
          ${deltaHtml}
        </div>
      `;
    }).join('');

    return `
      <div id="report-section-domains" class="report-section">
        <h2 class="report-section-title">Domain Breakdown</h2>
        ${rows}
      </div>
    `;
  }

  // ── Section 4: Priority Actions ──
  function renderPriorityActions(data: ReportData): string {
    const actions = composePriorityActions(data.profile as any, data.responses, frameworkData as any);
    if (!actions.length) return '';

    const items = actions.map((a: any, i: number) => {
      const sourceHtml = a.source_question_id
        ? `<div class="report-action-source">Suggested based on your answer in <span class="report-action-domain">${a.domain_label}</span>: ${a.title}</div>`
        : '';
      const timeHtml = a.estimated_time
        ? `<span class="report-action-time">${a.estimated_time}</span>`
        : '';

      return `
        <li class="report-action-item">
          <span class="report-action-num">${i + 1}</span>
          <div class="report-action-body">
            <div class="report-action-text">${a.body}</div>
            ${timeHtml || sourceHtml ? `<div class="report-action-meta">${timeHtml}</div>` : ''}
            ${sourceHtml}
          </div>
        </li>
      `;
    }).join('');

    return `
      <div id="report-section-actions" class="report-section">
        <h2 class="report-section-title">Priority Actions</h2>
        <ol class="report-actions-list">${items}</ol>
      </div>
    `;
  }

  // ── Section: Strengths (response-composed, between Summary and Domain Breakdown) ──
  function renderStrengths(data: ReportData): string {
    const strengths = composeStrengths(data.profile as any, data.responses, frameworkData as any);
    if (!strengths.length) return '';

    const items = strengths.map((s: any) => `
      <li class="report-strength-item">
        <div class="report-strength-body">${s.body}</div>
      </li>
    `).join('');

    return `
      <div id="report-section-strengths" class="report-section">
        <h2 class="report-section-title">What You're Doing Well</h2>
        <ul class="report-strengths-list">${items}</ul>
      </div>
    `;
  }

  // ── Section 5: Playbooks ──
  function renderPlaybooks(data: ReportData, nextStageId: string | null): string {
    const { currentStage: currentPlaybooks, weakestDomain, comingNext: nextPlaybooks } =
      composePlaybookRecommendations(data.profile as any, data.responses, frameworkData as any, allPlaybooks as any);

    const renderCard = (pb: any, modifier = '') => `
      <div class="report-playbook-card${modifier}">
        <div class="report-playbook-title"><a href="/customer-success-playbooks/${pb.id}/">${pb.title}</a></div>
        <p class="report-playbook-obj">${pb.objective}</p>
        <span class="report-playbook-duration">${pb.estimated_duration}</span>
      </div>
    `;

    const currentCards = currentPlaybooks.map((pb: any) => renderCard(pb)).join('');

    const weakestHtml = weakestDomain.length
      ? `<h3 class="report-subsection-label">Strengthen Your Weakest Area</h3>
         <div class="report-playbooks-grid">${weakestDomain.map((pb: any) => renderCard(pb, ' is-weak-domain')).join('')}</div>`
      : '';

    const nextCards = nextPlaybooks.length
      ? `<h3 class="report-subsection-label">Coming Next</h3>
         <div class="report-playbooks-grid">${nextPlaybooks.map((pb: any) => renderCard(pb, ' is-next-stage')).join('')}</div>`
      : '';

    return `
      <div id="report-section-playbooks" class="report-section">
        <h2 class="report-section-title">Recommended Playbooks</h2>
        <div class="report-playbooks-grid">${currentCards}</div>
        ${weakestHtml}
        ${nextCards}
      </div>
    `;
  }

  // ── Section 6: Metrics ──
  function renderMetrics(data: ReportData): string {
    const annotated = composeMetricPriorities(data.profile as any, data.responses, frameworkData as any, allMetrics);

    const grouped: Record<string, any[]> = { high: [], medium: [], low: [] };
    for (const entry of annotated) {
      (grouped[entry.relevance] = grouped[entry.relevance] || []).push(entry);
    }

    const renderGroup = (priority: string, label: string, entries: any[]) => {
      if (!entries.length) return '';

      const rows = entries.map(({ metric: m, segmentBenchmark: b }: any) => {
        const benchmarkHtml = b?.good
          ? `<span class="report-metric-benchmark">Target: ${b.good}</span>`
          : '';
        return `
          <div class="report-metric-row">
            <span class="report-metric-name"><a href="/customer-success-metrics/${m.id}/">${m.name}</a></span>
            ${benchmarkHtml}
          </div>
        `;
      }).join('');

      return `
        <div class="report-metric-group">
          <h3 class="report-metric-group-title">
            <span class="priority-dot priority-dot-${priority}"></span>
            ${label} Priority
          </h3>
          ${rows}
        </div>
      `;
    };

    return `
      <div id="report-section-metrics" class="report-section">
        <h2 class="report-section-title">Metric Priorities</h2>
        ${renderGroup('high', 'High', grouped.high || [])}
        ${renderGroup('medium', 'Medium', grouped.medium || [])}
        ${renderGroup('low', 'Low', grouped.low || [])}
      </div>
    `;
  }

  // ── Section 7: Maturity Model ──
  function renderMaturityModel(data: ReportData): string {
    const currentIdx = stageOrder.indexOf(data.stage);

    const cards = stages.map((s: any) => {
      const idx = stageOrder.indexOf(s.id);
      const isCurrent = s.id === data.stage;
      const isCompleted = idx < currentIdx;

      const characteristics = s.key_characteristics?.length
        ? `<ul class="report-characteristics-list">
            ${s.key_characteristics.map((c: string) => `<li>${c}</li>`).join('')}
          </ul>`
        : '';

      let badge = '';
      if (isCurrent) {
        badge = '<span class="report-stage-card-badge">You are here</span>';
      } else if (isCompleted) {
        badge = '<span class="report-stage-card-badge-completed">✓ Completed</span>';
      }

      return `
        <div class="report-stage-card stage-${s.id}${isCurrent ? ' is-current' : ''}">
          <div class="report-stage-card-label">${s.label}</div>
          <div class="report-stage-card-subtitle">${s.subtitle}</div>
          ${badge}
          ${characteristics}
        </div>
      `;
    }).join('');

    return `
      <div id="report-section-journey" class="report-section">
        <h2 class="report-section-title">Your CS Maturity Journey</h2>
        <div class="report-stages-track">${cards}</div>
      </div>
    `;
  }

  // ── Print / Save as PDF (Task 7) ──
  // Uses window.print() with @media print CSS (Task 6) instead of html2pdf.js.
  // html2pdf.js was removed because html2canvas clones the entire document into
  // iframes, which triggers cascading page loads with Astro's dev server/toolbar,
  // crashes Vite HMR, and leaves the page unresponsive. window.print() is zero-
  // dependency, works on all modern browsers (including iOS Safari 15+), and
  // leverages the comprehensive @media print styles already defined above.
  // ── Options overflow menu ──
  const overflowMenu = document.getElementById('report-overflow-menu');
  const overflowTrigger = document.getElementById('report-overflow-trigger');
  const overflowDropdown = document.getElementById('report-overflow-dropdown');

  overflowTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = overflowMenu?.classList.toggle('is-open');
    overflowTrigger.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('click', (e) => {
    if (overflowMenu && !overflowMenu.contains(e.target as Node)) {
      overflowMenu.classList.remove('is-open');
      overflowTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overflowMenu?.classList.contains('is-open')) {
      overflowMenu.classList.remove('is-open');
      overflowTrigger?.setAttribute('aria-expanded', 'false');
      overflowTrigger?.focus();
    }
  });

  const downloadBtn = document.getElementById('download-pdf-btn');
  if (downloadBtn) {
    downloadBtn.addEventListener('click', () => window.print());
  }

  document.getElementById('report-restart-btn')?.addEventListener('click', () => {
    if (confirm('This will permanently clear your assessment results, company profile, and any progress. This cannot be undone. Continue?')) {
      resetAll();
      window.location.href = '/assess/';
    }
  });

  // ── Section 8: Transition Guide ──
  function renderTransitionGuide(data: ReportData, nextStage: any, transition: any): string {
    const title = nextStage
      ? `Transition Guide: ${getStageData(data.stage)?.label} → ${nextStage.label}`
      : 'Transition Guide';

    const renderList = (items: string[]) =>
      items?.length
        ? `<ul class="report-transition-list">${items.map((t: string) => `<li>${t}</li>`).join('')}</ul>`
        : '';

    return `
      <div id="report-section-transition" class="report-section">
        <h2 class="report-section-title">${title}</h2>
        <div class="report-transition-columns">
          <div class="report-transition-block">
            <h3 class="report-transition-block-title">Trigger Signals</h3>
            ${renderList(transition.trigger_signals)}
          </div>
          <div class="report-transition-block">
            <h3 class="report-transition-block-title">Key Shifts</h3>
            ${renderList(transition.key_shifts)}
          </div>
          <div class="report-transition-block">
            <h3 class="report-transition-block-title">New Capabilities</h3>
            ${renderList(transition.new_capabilities)}
          </div>
        </div>
      </div>
    `;
  }
</script>
