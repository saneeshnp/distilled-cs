---
import BaseLayout from '../layouts/BaseLayout.astro';
import roadmapData from '../data/roadmap.json';
const lastUpdated = 'June 2026';
const lastUpdatedISO = '2026-06';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://distilledcs.org/' },
    { '@type': 'ListItem', position: 2, name: 'Roadmap', item: 'https://distilledcs.org/roadmap/' },
  ],
};

const statusMeta: Record<string, { label: string; className: string }> = {
  planned: { label: 'Planned', className: 'status-planned' },
  exploring: { label: 'Exploring', className: 'status-exploring' },
  'in-progress': { label: 'In progress', className: 'status-in-progress' },
  shipped: { label: 'Shipped', className: 'status-done' },
};

type RoadmapItem = {
  title: string;
  description: string;
  status: string;
  note?: string;
  pageUrl?: string;
  links?: { label: string; url: string }[];
};

const items = roadmapData.items as RoadmapItem[];
const buildingItems = items.filter((i) => i.status !== 'shipped');
const shippedItems = items.filter((i) => i.status === 'shipped');
---

<BaseLayout
  title="Roadmap"
  description="What we're building next for the Distilled CS framework, and why. We share our direction openly so CS teams can follow along and help shape what gets built."
  structuredData={[breadcrumbSchema]}
>

  <div class="container roadmap-page">

    <header class="page-header">
      <p class="eyebrow">Last updated: <time datetime={lastUpdatedISO}>{lastUpdated}</time></p>
      <h1 class="page-title">Distilled CS Roadmap</h1>
      <p class="page-subtitle">
        We believe in being open about what we're building and why. This page is where we share what's coming next, so customer success practitioners using this framework can follow along, push back, and help shape what gets built.
      </p>
    </header>

    <div class="page-body">

      <section class="content-section">
        <h2>What we're building</h2>
        <p>
          One of the principles we try to hold ourselves to is transparency: not just in the framework content, but in how we develop it. That means sharing direction early, being clear about what we're prioritising and why, and letting the needs of real CS teams drive what comes next.
        </p>
        <div class="roadmap-grid">
          {buildingItems.map((item) => (
            <article class={`roadmap-card accent-${item.status}`}>
              <div class="roadmap-card-head">
                <h3 class="roadmap-card-title">{item.title}</h3>
                <span class={`status ${statusMeta[item.status]?.className ?? 'status-planned'}`}>
                  {statusMeta[item.status]?.label ?? item.status}
                </span>
              </div>
              <p class="roadmap-card-desc">{item.description}</p>
              {item.note && <p class="roadmap-note">{item.note}</p>}
            </article>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>What we've recently shipped</h2>
        <p>
          Items that have moved from the plan into the live framework. We keep them here so the history of the framework stays visible.
        </p>
        <div class="roadmap-grid">
          {shippedItems.map((item) => (
            <article class={`roadmap-card accent-${item.status}`}>
              <div class="roadmap-card-head">
                <h3 class="roadmap-card-title">{item.title}</h3>
                <span class={`status ${statusMeta[item.status]?.className ?? 'status-done'}`}>
                  {statusMeta[item.status]?.label ?? item.status}
                </span>
              </div>
              <p class="roadmap-card-desc">{item.description}</p>
              {item.pageUrl && (
                <a class="roadmap-card-cta" href={item.pageUrl}>View it on the site →</a>
              )}
              {item.links && item.links.length > 0 && (
                <div class="roadmap-card-links">
                  {item.links.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>How we decide what to build</h2>
        <p>
          Every addition to Distilled CS starts with the same question: does this help a CS team do their job better? Not more comprehensively, not more impressively, but more usefully. We weigh that against the stage the team is at and the constraints they're actually working under.
        </p>
        <p>
          If you have something specific you'd like to see, or want to tell us what's missing from the framework, the <a href="/contact/">contact page</a> is the right place.
        </p>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
  .roadmap-page {
    padding-block: 3rem 5rem;
    max-width: 56rem;
    margin-inline: auto;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    padding: 1.25rem;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .page-subtitle::before {
    content: '';
    display: block;
    width: 2.5rem;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
    margin-bottom: 0.875rem;
  }

  .page-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .content-section h2 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-text-primary);
    margin-bottom: 0.625rem;
    letter-spacing: -0.02em;
  }

  .content-section p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .content-section p:last-child {
    margin-bottom: 0;
  }

  .roadmap-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  @media (min-width: 640px) {
    .roadmap-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .roadmap-card {
    --card-accent: var(--color-accent);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    transition: border-color 0.2s ease-out, transform 0.2s ease-out;
  }

  .roadmap-card::before {
    content: '';
    display: block;
    width: 2.5rem;
    height: 3px;
    background: var(--card-accent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .roadmap-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 25%, transparent);
    transform: translateY(-2px);
  }

  .accent-planned { --card-accent: #F57C00; }
  .accent-in-progress { --card-accent: var(--color-accent); }
  .accent-exploring { --card-accent: var(--color-text-muted); }
  .accent-shipped { --card-accent: #388E3C; }

  .roadmap-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .roadmap-card-head .status {
    flex-shrink: 0;
  }

  .roadmap-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .roadmap-card-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .roadmap-card-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .roadmap-card-cta {
    align-self: flex-start;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .roadmap-card-cta:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .roadmap-card-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .roadmap-card-links a {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .status {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .status-planned {
    background: color-mix(in srgb, #F57C00 15%, transparent);
    color: #F57C00;
  }

  .status-in-progress {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
  }

  .status-exploring {
    background: color-mix(in srgb, var(--color-text-muted) 15%, transparent);
    color: var(--color-text-secondary);
  }

  .status-done {
    background: color-mix(in srgb, #388E3C 15%, transparent);
    color: #388E3C;
  }
</style>
