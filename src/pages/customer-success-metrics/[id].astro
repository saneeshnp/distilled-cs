  /* Benchmarks table */
  .benchmarks-table-wrap {
    overflow-x: auto;
  }

  .benchmarks-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .benchmarks-table th {
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .benchmarks-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .benchmarks-table tr.user-segment td {
    background: var(--color-accent-subtle);
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .world-class-cell {
    color: var(--color-accent) !important;
    font-weight: 500;
  }

  /* Health components */
  .health-components {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .health-stage-block {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .health-stage-block.user-health-stage {
    border-color: var(--color-accent);
  }

  .health-stage-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: 0.875rem;
  }

  .health-detail {
    margin-bottom: 0.75rem;
  }

  .health-detail h4 {
    font-size: 0.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .health-detail ul {
    padding-left: 1.25rem;
    margin: 0;
  }

  .health-detail li, .health-detail p {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  .skip-detail p {
    color: var(--color-warning);
    font-style: italic;
  }

  /* Audience */
  .audience-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .audience-item {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .audience-role {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.375rem;
  }

  .audience-relevance {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Contextual panel fade-in */
  .contextual-panel-section {
    opacity: 0;
    transform: translateY(1rem);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .contextual-panel-section.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .contextual-panel-section {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Common mistakes */
  .mistakes-list {
    list-style: none;
    padding-left: 0;
    counter-reset: mistakes-counter;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mistakes-list li {
    counter-increment: mistakes-counter;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .mistakes-list li::before {
    content: counter(mistakes-counter);
    flex-shrink: 0;
    width: 1.375rem;
    height: 1.375rem;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    font-size: 0.6875rem;
    font-weight: 700;
    border-radius: 50%;
    display: grid;
    place-items: center;
    margin-top: 0.4rem;
  }

  /* Related metrics */
  .related-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s ease-out;
  }

  .related-card:hover {
    border-color: var(--color-accent);
  }

  .related-name {
    font-size: 0.8125rem;
    color: var(--color-text-primary);
  }

  /* Used in Playbooks */
  .playbook-refs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .playbook-ref-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .playbook-ref-card:hover {
    border-color: var(--stage-color, var(--color-accent));
    background: var(--color-surface-hover);
  }

  .playbook-ref-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .playbook-ref-badge {
    padding: 0.15rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    border-radius: 9999px;
    flex-shrink: 0;
    background: var(--stage-color, var(--color-accent));
    color: var(--color-on-stage);
  }

  :global(.contextual-panel-box) {
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--stage-color, var(--color-accent)) 30%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--stage-color, var(--color-accent)) 8%, transparent);
  }

  :global(.contextual-panel-title) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  :global(.contextual-panel-row) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  :global(.contextual-panel-label) {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  :global(.contextual-panel-row .priority-pill) {
    font-size: 0.75rem;
  }

  :global(.contextual-panel-why) {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .playbook-ref-title {
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    flex: 1;
  }

  .playbook-ref-arrow {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
</style>

<script>
  import { isAssessmentCompleted, getScores, getProfile } from '../../scripts/context-manager.js';
  import { calculators } from '../../scripts/metric-calculators.js';

  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };

  // ── Metric calculator (progressive enhancement) ──────────────────────────────
  // The form and a worked-example result are already server-rendered. JS makes it
  // recompute live as the user edits, and reveals the (otherwise useless) reset.
  (function initCalculator() {
    const section = document.querySelector<HTMLElement>('.calc-section');
    if (!section) return;

    const metricId = section.dataset.calcId || '';
    const fn = (calculators as Record<string, (v: any) => number>)[metricId];
    const output = section.querySelector<HTMLOutputElement>('[data-calc-output]');
    if (!fn || !output) return;

    const unit = section.dataset.resultUnit || '';
    const precision = parseInt(section.dataset.resultPrecision || '0', 10);
    const inputs = Array.from(section.querySelectorAll<HTMLInputElement>('.calc-input'));

    function formatResult(value: number | null): string {
      if (value == null || !Number.isFinite(value)) return '—';
      const rounded = Number(value).toFixed(precision);
      if (unit === '$') {
        return (
          '$' +
          Number(rounded).toLocaleString('en-US', {
            minimumFractionDigits: precision,
            maximumFractionDigits: precision,
          })
        );
      }
      if (unit === '%') return `${rounded}%`;
      if (unit === 'days') return `${rounded} days`;
      if (unit === 'months') return `${rounded} months`;
      return rounded;
    }

    function recompute() {
      const values: Record<string, number | string> = {};
      let complete = true;
      for (const input of inputs) {
        const key = input.dataset.key || '';
        if (input.dataset.type === 'date') {
          if (!input.value) complete = false;
          values[key] = input.value;
        } else {
          if (input.value === '') {
            complete = false;
            continue;
          }
          const num = parseFloat(input.value);
          if (Number.isNaN(num)) complete = false;
          values[key] = num;
        }
      }
      if (!complete) {
        output!.textContent = '—';
        return;
      }
      let result: number | null = null;
      try {
        result = fn(values);
      } catch {
        result = null;
      }
      output!.textContent = formatResult(result);
    }

    inputs.forEach((input) => input.addEventListener('input', recompute));

    const actions = section.querySelector<HTMLElement>('[data-calc-actions]');
    if (actions) actions.hidden = false;
    const resetBtn = section.querySelector<HTMLButtonElement>('[data-calc-reset]');
    resetBtn?.addEventListener('click', () => {
      inputs.forEach((input) => {
        input.value = input.defaultValue;
      });
      recompute();
    });

    // "How you compare" is server-rendered from the default segment. For assessed
    // users, swap in their own segment's targets, read straight from the
    // already-rendered benchmarks row. No parsing and no verdict — the user
    // compares their calculated number against the targets.
    const compare = section.querySelector<HTMLElement>('[data-calc-compare]');
    if (compare && isAssessmentCompleted()) {
      const profile = getProfile();
      const keys = [profile?.customer_segment, profile?.product_complexity].filter(
        Boolean,
      ) as string[];
      let row: Element | null = null;
      for (const key of keys) {
        row = document.querySelector(`tr[data-benchmark-segment="${key}"]`);
        if (row) break;
      }
      const cells = row ? Array.from(row.querySelectorAll('td')) : [];
      if (cells.length >= 4) {
        const segment = cells[0].textContent?.trim() || '';
        const caption = compare.querySelector('[data-calc-compare-caption]');
        if (caption) {
          caption.textContent =
            segment && segment !== 'All Segments' ? `Targets for ${segment}` : 'Typical targets';
        }
        const setTier = (tier: string, value: string) => {
          const el = compare.querySelector(`[data-tier-value="${tier}"]`);
          if (el) el.textContent = value;
        };
        setTier('good', cells[1].textContent?.trim() || '');
        setTier('great', cells[2].textContent?.trim() || '');
        setTier('world', cells[3].textContent?.trim() || '');
      }
    }
  })();

  const panel = document.getElementById('contextual-panel');

  if (isAssessmentCompleted()) {
    const scores = getScores();
    const profile = getProfile();

    if (scores && scores.stage && panel) {
      const stage = scores.stage;
      panel.classList.add(`stage-${stage}`);
      const metricId = panel.getAttribute('data-metric-id');

      // Highlight user's stage row
      const userRow = document.querySelector(`.priority-stage-row[data-stage="${stage}"]`);
      if (userRow) userRow.classList.add('user-stage');

      // Highlight user's benchmark segment
      const segment = profile?.customer_segment;
      const complexity = profile?.product_complexity;
      [segment, complexity].forEach(key => {
        if (key) {
          const row = document.querySelector(`tr[data-benchmark-segment="${key}"]`);
          if (row) row.classList.add('user-segment');
        }
      });

      // Highlight user's health stage
      const healthBlock = document.querySelector(`.health-stage-block[data-health-stage="${stage}"]`);
      if (healthBlock) healthBlock.classList.add('user-health-stage');

      // Build contextual panel
      const metricEl = panel;
      const priorityData = JSON.parse(
        document.querySelector(`[data-metric-id]`)?.closest('[data-priorities]')?.getAttribute('data-priorities') || '{}'
      );

      // Read from data embedded in the page's priority-stage-row
      const priorityRow = document.querySelector(`.priority-stage-row[data-stage="${stage}"]`);
      const priorityPill = priorityRow?.querySelector('.priority-pill');
      const priority = priorityPill?.textContent?.trim() || '';
      const why = priorityRow?.querySelector('.priority-why')?.textContent?.trim() || '';

      panel.innerHTML = `
        <div class="contextual-panel-box">
          <h2 class="contextual-panel-title">For your context</h2>
          <div class="contextual-panel-row">
            <span class="contextual-panel-label">Priority at ${stageLabels[stage]}:</span>
            <span class="priority-pill priority-${priority}">${priority}</span>
          </div>
          ${why ? `<p class="contextual-panel-why">${why}</p>` : ''}
        </div>
      `;
    }
  } else if (panel) {
    // Show CTA
    panel.innerHTML = `
      <div style="padding:1.5rem;border:1px solid var(--color-border);border-radius:0.75rem;background:var(--color-surface);text-align:center;">
        <p style="font-family:var(--font-display);font-size:1.125rem;margin-bottom:0.75rem;">Take the assessment for personalized guidance</p>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-bottom:1rem;">See which priority this metric is for your stage, plus benchmarks for your segment.</p>
        <a href="/assess/" style="display:inline-block;padding:0.625rem 1.5rem;background:var(--color-accent);color:var(--color-bg);border-radius:0.5rem;font-weight:500;font-size:0.875rem;text-decoration:none;">Take the Assessment</a>
      </div>
    `;
  }

  // Fade-in animation for contextual panel via Intersection Observer
  const panelSection = document.querySelector('.contextual-panel-section');
  if (panelSection) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      panelSection.classList.add('visible');
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      observer.observe(panelSection);
    }
  }
</script>
