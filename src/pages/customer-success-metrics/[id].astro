  }

  /* Priority by stage */
  .priority-stages {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .priority-stage-row {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
