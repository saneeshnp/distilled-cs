  }

  .calc-tip {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 32rem;
  }

  .calc-actions {
    display: flex;
    margin-left: auto;
  }

  .calc-reset {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
