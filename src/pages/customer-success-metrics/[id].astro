---
import BaseLayout from '../../layouts/BaseLayout.astro';
import frameworkData from '../../data/lean-cs-data.json';
import calculatorSpecs from '../../data/metric-calculators.json';
import { calculators } from '../../scripts/metric-calculators.js';

export function getStaticPaths() {
  return frameworkData.metrics_directory.metrics.map(metric => ({
    params: { id: metric.id },
    props: { metric },
  }));
}

const { metric } = Astro.props;

const categoryLabels: Record<string, string> = {
  revenue: 'Revenue',
  retention: 'Retention',
  onboarding: 'Onboarding',
  health: 'Health',
  sentiment: 'Sentiment',
  usage: 'Usage',
  ai: 'AI & Automation',
};

const allMetrics = frameworkData.metrics_directory.metrics;
const relatedMetrics = (metric.related_metrics || [])
  .map((id: string) => allMetrics.find((m: any) => m.id === id))
  .filter(Boolean);

const benchmarkEntries = Object.entries(metric.benchmarks_by_context || {});

// Calculator: build-time lookup of this metric's spec (only ~19 of 24 metrics
// have one). The current metric's entry is inlined; the rest of the JSON never
// ships to the client.
const calcSpec = (calculatorSpecs as Record<string, any>)[metric.id] || null;
const calcFn = (calculators as Record<string, (v: any) => number>)[metric.id];

// Render input props per variable type and pre-fill with the worked example.
const calcFields = calcSpec
  ? calcSpec.variables.map((v: any) => {
      const isDate = v.type === 'date';
      const isInteger = v.type === 'integer';
      return {
        ...v,
        inputType: isDate ? 'date' : 'number',
        inputmode: isDate ? undefined : isInteger ? 'numeric' : 'decimal',
        step: isDate ? undefined : isInteger ? '1' : 'any',
        prefix: v.unit === '$' ? '$' : null,
        suffix: v.unit === '%' ? '%' : null,
        exampleValue: calcSpec.example[v.key],
      };
    })
  : [];

// The example result, computed at build time so the static (no-JS) page shows a
// real worked answer rather than an empty calculator.
const calcExampleResult = calcSpec && calcFn ? calcFn(calcSpec.example) : null;

function formatResult(value: number | null, unit: string, precision: number): string {
  if (value == null || !Number.isFinite(value)) return '—';
  const rounded = Number(value).toFixed(precision);
  if (unit === '$') {
    return (
      '$' +
      Number(rounded).toLocaleString('en-US', {
        minimumFractionDigits: precision,
        maximumFractionDigits: precision,
      })
    );
  }
  if (unit === '%') return `${rounded}%`;
  if (unit === 'days') return `${rounded} days`;
  if (unit === 'months') return `${rounded} months`;
  return rounded;
}

const segmentLabels: Record<string, string> = {
  seg_smb: 'SMB',
  seg_midmarket: 'Mid-Market',
  seg_enterprise: 'Enterprise',
  complexity_low: 'Low Complexity',
  complexity_moderate: 'Moderate Complexity',
  complexity_high: 'High Complexity',
  _default: 'All Segments',
};

// "How you compare" baseline for the calculator. Server-rendered from _default
// (or the first segment) so crawlers and non-assessed users see real targets;
// JS swaps in the assessed user's own segment at runtime.
const calcBenchmarkEntry: [string, any] | null = calcSpec
  ? ((metric.benchmarks_by_context && metric.benchmarks_by_context._default)
      ? ['_default', metric.benchmarks_by_context._default]
      : (benchmarkEntries[0] as [string, any]) || null)
  : null;
const calcBenchmark = calcBenchmarkEntry
  ? { key: calcBenchmarkEntry[0], values: calcBenchmarkEntry[1] }
  : null;
const calcBenchmarkCaption = calcBenchmark
  ? (calcBenchmark.key === '_default'
      ? 'Typical targets'
      : `Targets for ${segmentLabels[calcBenchmark.key] || calcBenchmark.key}`)
  : '';

const stageOrder = ['crawl', 'walk', 'run'];
const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };

// Health score components (only for health_score metric)
const healthComponents = metric.health_score_components_by_stage || null;

// Build reverse lookup: which playbooks reference this metric?
const playbooks = frameworkData.playbooks as Record<string, any[]>;
const usedInPlaybooks: { id: string; title: string; stageId: string }[] = [];
for (const stageId of stageOrder) {
  for (const pb of (playbooks[stageId] || [])) {
    if (pb.metrics_to_watch && pb.metrics_to_watch.includes(metric.id)) {
      usedInPlaybooks.push({ id: pb.id, title: pb.title, stageId });
    }
  }
}

const siteUrl = 'https://distilledcs.org';
const metricUrl = `${siteUrl}/customer-success-metrics/${metric.id}/`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Metrics', item: `${siteUrl}/customer-success-metrics/` },
    { '@type': 'ListItem', position: 3, name: metric.name, item: metricUrl },
  ],
};
---

<BaseLayout title={metric.name} description={metric.definition} structuredData={[breadcrumbSchema]}>
  <div class="container metric-detail-page">

    <!-- Back link -->
    <a href="/customer-success-metrics/" class="back-link">&larr; All Metrics</a>

    <!-- Metric header -->
    <div class="metric-header">
      <span class={`category-tag cat-${metric.category}`}>{categoryLabels[metric.category] || metric.category}</span>
      <h1 class="metric-title">{metric.name}</h1>
      {metric.also_known_as && metric.also_known_as.length > 0 && (
        <p class="also-known">Also known as: {metric.also_known_as.join(', ')}</p>
      )}
    </div>

    <!-- Definition -->
    <section class="metric-section">
      <p class="metric-definition">{metric.definition}</p>
    </section>

    <!-- Formula -->
    <section class="metric-section">
      <h2 class="section-heading">Formula</h2>
      <div class="formula-block">
        <code>{metric.formula}</code>
      </div>
      {metric.formula_note && (
        <p class="formula-note">{metric.formula_note}</p>
      )}
    </section>

    <!-- Calculator (server-rendered; enhanced to live calculation by JS later) -->
    {calcSpec && (
      <section
        class="metric-section calc-section"
        data-calc-id={metric.id}
        data-result-unit={calcSpec.result_unit}
        data-result-precision={calcSpec.result_precision}
      >
        <form class="calc-form">
          <div class="calc-header">
            <span class="calc-header-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="2" width="16" height="20" rx="2"/>
                <line x1="8" y1="6" x2="16" y2="6"/>
                <line x1="8" y1="14" x2="8" y2="14"/>
                <line x1="12" y1="14" x2="12" y2="14"/>
                <line x1="16" y1="14" x2="16" y2="18"/>
                <line x1="8" y1="18" x2="12" y2="18"/>
              </svg>
            </span>
            <div class="calc-header-text">
              <h2 class="section-heading calc-title">{metric.name} calculator</h2>
              <p class="calc-intro">
                Enter your own numbers to calculate {calcSpec.result_label}. It uses the formula above and updates as you type, starting from a worked example so you see a realistic calculation first.
              </p>
            </div>
          </div>
          <div class="calc-grid">
            <div class="calc-col calc-inputs">
              <h3 class="calc-col-heading">Enter your numbers</h3>
              <div class="calc-fields">
                {calcFields.map((f: any) => (
                  <div class="calc-field">
                    <label class="calc-label" for={`calc-${metric.id}-${f.key}`}>{f.label}</label>
                    <div class={`calc-input-wrap${f.prefix ? ' has-prefix' : ''}${f.suffix ? ' has-suffix' : ''}`}>
                      {f.prefix && <span class="calc-affix calc-prefix" aria-hidden="true">{f.prefix}</span>}
                      <input
                        class="calc-input"
                        id={`calc-${metric.id}-${f.key}`}
                        name={f.key}
                        data-key={f.key}
                        data-type={f.type}
                        type={f.inputType}
                        inputmode={f.inputmode}
                        step={f.step}
                        min={f.min}
                        max={f.max}
                        value={f.exampleValue}
                        autocomplete="off"
                      />
                      {f.suffix && <span class="calc-affix calc-suffix" aria-hidden="true">{f.suffix}</span>}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="calc-col calc-output-col">
              <h3 class="calc-col-heading">Your result</h3>
              <div class="calc-result">
                <span class="calc-result-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="2" width="16" height="20" rx="2"/>
                    <line x1="8" y1="6" x2="16" y2="6"/>
                    <line x1="8" y1="14" x2="8" y2="14"/>
                    <line x1="12" y1="14" x2="12" y2="14"/>
                    <line x1="16" y1="14" x2="16" y2="18"/>
                    <line x1="8" y1="18" x2="12" y2="18"/>
                  </svg>
                </span>
                <div class="calc-result-body">
                  <output
                    class="calc-result-value"
                    data-calc-output
                    aria-labelledby={`calc-result-label-${metric.id}`}
                    aria-live="polite"
                    aria-atomic="true"
                  >
                    {formatResult(calcExampleResult, calcSpec.result_unit, calcSpec.result_precision)}
                  </output>
                  <span class="calc-result-label" id={`calc-result-label-${metric.id}`}>{calcSpec.result_label}</span>
                </div>
              </div>

              {calcBenchmark && (
                <div class="calc-compare" data-calc-compare>
                  <h4 class="calc-compare-heading">How you compare</h4>
                  <p class="calc-compare-caption" data-calc-compare-caption>{calcBenchmarkCaption}</p>
                  <ul class="calc-compare-list">
                    <li class="calc-compare-row">
                      <span class="calc-compare-icon calc-icon-good" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      </span>
                      <span class="calc-compare-tier">Good</span>
                      <span class="calc-compare-value" data-tier-value="good">{calcBenchmark.values.good}</span>
                    </li>
                    <li class="calc-compare-row">
                      <span class="calc-compare-icon calc-icon-great" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l2.9 6.3 6.6.6-5 4.3 1.6 6.6L12 17l-6.1 3.7L7.5 13.2l-5-4.3 6.6-.6z"/></svg>
                      </span>
                      <span class="calc-compare-tier">Great</span>
                      <span class="calc-compare-value" data-tier-value="great">{calcBenchmark.values.great}</span>
                    </li>
                    <li class="calc-compare-row">
                      <span class="calc-compare-icon calc-icon-world" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18"/></svg>
                      </span>
                      <span class="calc-compare-tier">World class</span>
                      <span class="calc-compare-value" data-tier-value="world">{calcBenchmark.values.world_class}</span>
                    </li>
                  </ul>
                </div>
              )}
            </div>
          </div>

          <div class="calc-footer">
            <p class="calc-tip">Use this to set expectations, align stakeholders, and track improvement over time.</p>
            <div class="calc-actions" hidden data-calc-actions>
              <button type="button" class="calc-reset" data-calc-reset>Reset to example</button>
            </div>
          </div>
        </form>
      </section>
    )}

    <!-- Audience -->
    {metric.audience && metric.audience.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Who Is This Metric For?</h2>
        <div class="audience-list">
          {metric.audience.map((entry: { role: string; relevance: string }) => (
            <div class="audience-item">
              <span class="audience-role">
                <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                  <circle cx="7" cy="4.5" r="2.5" fill="currentColor"/>
                  <path d="M1.5 13c0-3 2.5-5 5.5-5s5.5 2 5.5 5z" fill="currentColor"/>
                </svg>
                {entry.role}
              </span>
              <p class="audience-relevance">{entry.relevance}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Contextual panel placeholder (JS populated) -->
    <section class="metric-section contextual-panel-section" id="contextual-panel" data-contextual="metric-panel" data-metric-id={metric.id}>
    </section>

    <!-- Priority by stage (static) -->
    <section class="metric-section">
      <h2 class="section-heading">Priority by Stage</h2>
      <div class="priority-stages">
        {stageOrder.map(stageId => {
          const priority = metric.priority_by_stage[stageId];
          const why = metric.why_priority?.[stageId];
          return (
            <div class={`priority-stage-row stage-${stageId}`} data-stage={stageId}>
              <div class="priority-stage-header">
                <span class="stage-dot"></span>
                <span class="stage-label-text">{stageLabels[stageId]}</span>
                <span class={`priority-pill priority-${priority}`}>{priority}</span>
              </div>
              {why && <p class="priority-why">{why}</p>}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Benchmarks -->
    {benchmarkEntries.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Benchmarks</h2>
        <div class="benchmarks-table-wrap">
          <table class="benchmarks-table">
            <thead>
              <tr>
                <th>Segment</th>
                <th>Good</th>
                <th>Great</th>
                <th>World Class</th>
              </tr>
            </thead>
            <tbody>
              {benchmarkEntries.map(([key, values]: [string, any]) => (
                <tr data-benchmark-segment={key}>
                  <td>{segmentLabels[key] || key}</td>
                  <td>{values.good}</td>
                  <td>{values.great}</td>
                  <td class="world-class-cell">{values.world_class}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Health Score Components (only for health_score metric) -->
    {healthComponents && (
      <section class="metric-section">
        <h2 class="section-heading">Health Score Components by Stage</h2>
        <div class="health-components">
          {stageOrder.map(stageId => {
            const comp = healthComponents[stageId];
            if (!comp) return null;
            return (
              <div class={`health-stage-block stage-${stageId}`} data-health-stage={stageId}>
                <h3 class="health-stage-title">
                  <span class="stage-dot"></span>
                  <span class="health-stage-label">{stageLabels[stageId]}</span>
                </h3>
                <div class="health-detail">
                  <h4>Recommended Inputs</h4>
                  <ul>
                    {comp.recommended_inputs.map((input: string) => <li>{input}</li>)}
                  </ul>
                </div>
                <div class="health-detail">
                  <h4>Scoring Method</h4>
                  <p>{comp.scoring_method}</p>
                </div>
                <div class="health-detail skip-detail">
                  <h4>What to Skip</h4>
                  <p>{comp.what_to_skip}</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Common mistakes -->
    {metric.common_mistakes && metric.common_mistakes.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Common Mistakes</h2>
        <ol class="mistakes-list">
          {metric.common_mistakes.map((mistake: string) => (
            <li>{mistake}</li>
          ))}
        </ol>
      </section>
    )}

    <!-- Used in Playbooks -->
    {usedInPlaybooks.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Used in Playbooks</h2>
        <div class="playbook-refs">
          {usedInPlaybooks.map(pb => (
            <a href={`/customer-success-playbooks/${pb.id}/`} class={`playbook-ref-card stage-${pb.stageId}`}>
              <span class="playbook-ref-badge">{stageLabels[pb.stageId]}</span>
              <span class="playbook-ref-title">{pb.title}</span>
              <svg class="playbook-ref-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related metrics -->
    {relatedMetrics.length > 0 && (
      <section class="metric-section">
        <h2 class="section-heading">Related Metrics</h2>
        <div class="related-grid">
          {relatedMetrics.map((rm: any) => (
            <a href={`/customer-success-metrics/${rm.id}/`} class="related-card">
              <span class={`category-tag cat-${rm.category}`} style="font-size:0.625rem;">{categoryLabels[rm.category] || rm.category}</span>
              <span class="related-name">{rm.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .metric-detail-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 48rem;
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .metric-header {
    margin-bottom: 2rem;
  }

  .category-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border-radius: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .cat-revenue { background: var(--color-accent-subtle); color: var(--color-accent); }
  .cat-retention { background: color-mix(in srgb, var(--color-stage-crawl) 14%, transparent); color: var(--color-stage-crawl); }
  .cat-onboarding { background: color-mix(in srgb, var(--color-stage-run) 14%, transparent); color: var(--color-stage-run); }
  .cat-health { background: color-mix(in srgb, var(--color-category-health) 14%, transparent); color: var(--color-category-health); }
  .cat-sentiment { background: color-mix(in srgb, #CE93D8 14%, transparent); color: #CE93D8; }
  .cat-usage { background: color-mix(in srgb, var(--color-stage-walk) 14%, transparent); color: var(--color-stage-walk); }
  .cat-ai { background: color-mix(in srgb, #7986CB 14%, transparent); color: #7986CB; }

  .metric-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    letter-spacing: -0.02em;
    margin-bottom: 0.375rem;
  }

  .also-known {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .metric-section {
    margin-bottom: 2.5rem;
  }

  .section-heading {
    font-size: 1.125rem;
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .metric-definition {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* Formula */
  .formula-note {
    margin-top: 0.625rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: pre-line;
  }

  .formula-block {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  .formula-block code {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 0.9375rem;
    color: var(--color-accent);
    white-space: pre-wrap;
  }

  /* Calculator */
  .calc-header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.5rem 1.5rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .calc-header-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  .calc-title {
    margin-bottom: 0.25rem;
  }

  .calc-intro {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .calc-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .calc-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  .calc-col-heading {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .calc-fields {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .calc-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .calc-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .calc-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .calc-affix {
    position: absolute;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .calc-prefix { left: 0.75rem; }
  .calc-suffix { right: 0.75rem; }

  .calc-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-family: var(--font-body);
    color: var(--color-text-primary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
  }

  /* The default border is barely visible against the dark surface, so use the
     stronger border token to keep the inputs legible. */
  :root[data-theme="dark"] .calc-input {
    border-color: var(--color-border-hover);
  }

  .calc-input-wrap.has-prefix .calc-input { padding-left: 1.5rem; }
  .calc-input-wrap.has-suffix .calc-input { padding-right: 1.75rem; }

  .calc-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
    border-color: var(--color-accent);
  }

  /* Result box */
  .calc-result {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .calc-result-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
