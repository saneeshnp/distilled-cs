---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StrategyLoop from '../../components/StrategyLoop.astro';
import frameworkData from '../../data/lean-cs-data.json';

const metrics = frameworkData.metrics_directory.metrics;

const categories = [...new Set(metrics.map(m => m.category))];

const categoryLabels: Record<string, string> = {
  revenue: 'Revenue',
  retention: 'Retention',
  onboarding: 'Onboarding',
  health: 'Health',
  sentiment: 'Sentiment',
  usage: 'Usage',
  ai: 'AI & Automation',
};

const faqItems = [
  {
    q: "What's the difference between NRR and GRR?",
    a: 'Net Revenue Retention (NRR) includes expansion, upsell, and cross-sell on top of the starting ARR base. Gross Revenue Retention (GRR) excludes expansion and only measures what was kept: NRR can exceed 100%, GRR never can. Track both. NRR tells you how the book is growing from within; GRR tells you the true loss rate.',
  },
  {
    q: 'How often should customer success teams review metrics?',
    a: 'Leading indicators (usage, onboarding progress, sentiment) belong in a weekly cadence so the team can act within the renewal window. Lagging indicators (NRR, GRR, logo churn) belong in a monthly or quarterly review tied to board reporting. Health score thresholds should trigger an immediate playbook, not wait for a cadence.',
  },
  {
    q: 'What is a customer health score?',
    a: 'A weighted composite that combines product usage, outcome attainment, sentiment, and relationship signals into a single indicator per account. The components and weights should reflect what actually predicts renewal for your segment. A score is only useful if it drives a consistent next action at each threshold.',
  },
  {
    q: 'Which metric matters most for an early-stage CS team?',
    a: 'Gross retention and time to first value. Before optimizing expansion, the team has to prove it can keep customers and get them to value reliably. Layer NRR and health scoring in once the foundational funnel is clean.',
  },
  {
    q: 'How do benchmarks differ by segment?',
    a: 'SMB books typically run lower gross retention (80–88%) with faster churn cycles but higher expansion ceilings as customers scale. Enterprise books run higher gross retention (92–97%) with slower, larger expansion motions. Mid-market sits between. Segment-specific benchmarks appear on each metric detail page.',
  },
  {
    q: 'Can a single metric predict churn on its own?',
    a: 'No. Usage drop alone misses customers churning on strategic misalignment. Sentiment alone misses silent churners. A composite health score that weighs three or four signals catches more cases than any single input, and human judgment still closes the loop.',
  },
  {
    q: 'What role do AI-assisted metrics play in customer success?',
    a: 'AI can summarize call transcripts into sentiment deltas, flag at-risk patterns earlier than rule-based scoring, and auto-generate QBR narratives. The AI & Automation category in this directory tracks the leverage metrics (hours saved, coverage ratio, prediction accuracy) rather than the models themselves.',
  },
  {
    q: 'Should revenue metrics sit with CS or with sales?',
    a: 'Expansion and renewal revenue belong to whichever team owns the customer relationship at that moment. In many organizations that is CS for renewals and a hybrid for expansion. The metric itself is neutral. The ownership decision should be explicit so the number does not get double-counted or disowned.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout title="Customer Success Metrics" description="The customer success metrics that matter by maturity stage: NRR, GRR, health score, onboarding time to value, and more — with benchmarks by segment." structuredData={[faqSchema]}>
  <div class="container metrics-page">

    <!-- Strategy Loop wayfinding -->
    <div class="metrics-loop-indicator">
      <StrategyLoop activePhase="execute" size="sm" interactive={false} />
    </div>

    <div class="page-header">
      <h1 class="page-title">Customer Success Metrics</h1>
      <p class="page-subtitle">The right metrics for your stage. Part of the Execute phase. Track these as you work through your playbooks.</p>
    </div>

    <!-- Contextual banner (JS populated) -->
    <div id="metrics-context-banner" data-show-if-assessed style="display:none;"></div>

    <!-- CTA for non-assessed -->
    <div class="assess-cta-banner" data-hide-if-assessed>
      <p>Take the assessment to see which metrics are highest priority for your stage.</p>
      <a href="/assess/" class="cta-link">Take the Assessment &rarr;</a>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all" type="button">All</button>
      {categories.map(cat => (
        <button class="filter-btn" data-filter={cat} type="button">{categoryLabels[cat] || cat}</button>
      ))}
    </div>

    <!-- Metrics grid -->
    <h2 class="grid-heading">Browse the directory</h2>
    <div class="metrics-grid" id="metrics-grid">
      {metrics.map(metric => (
        <a href={`/customer-success-metrics/${metric.id}/`} class="metric-card" data-metric-id={metric.id} data-category={metric.category} data-priorities={JSON.stringify(metric.priority_by_stage)}>
          <div class="metric-card-top">
            <span class={`category-tag cat-${metric.category}`}>{categoryLabels[metric.category] || metric.category}</span>
            <span class="priority-indicator" data-priority-slot={metric.id}></span>
          </div>
          <h2 class="metric-name">{metric.name}</h2>
          <p class="metric-def">{metric.definition.length > 120 ? metric.definition.slice(0, 120) + '...' : metric.definition}</p>
        </a>
      ))}
    </div>

    <section class="pillar-intro" data-hide-if-assessed>
      <h2>What customer success metrics actually measure</h2>
      <p>Customer success metrics quantify how a customer is moving toward their outcomes and how likely they are to stay, expand, or churn. They fall into a few families: revenue (NRR, GRR, expansion), retention (logo churn, gross retention), onboarding (time to first value, activation rate), health (composite score, usage, sentiment), and increasingly AI-leverage signals as automation enters the stack. Each metric answers a specific operational question. Used together, they tell the story of the customer relationship.</p>
      <p>The right metrics depend on where the team is in its maturity journey. A Crawl-stage team tracking predictive churn probability before it has a clean onboarding funnel is measuring the wrong thing first. A Fly-stage team still reporting only logo churn is leaving insight on the table. Each metric page below carries a priority-by-stage rating so the directory re-sorts once you complete the assessment.</p>
      <h3>How to choose metrics at each stage</h3>
      <p>At <strong>Crawl</strong>, focus on foundational signals: onboarding completion, logo retention, and gross retention. The priority is a reliable source of truth before layering complexity. At <strong>Walk</strong>, introduce net revenue retention and a basic health score. At <strong>Run</strong>, operationalize expansion metrics, leading indicators of churn, and cohort analysis by segment. At <strong>Fly</strong>, predictive metrics, AI-assisted churn scoring, and outcome attribution become table stakes.</p>
      <p>Two rules cut across every stage. Fewer metrics reviewed with discipline beat many tracked loosely. Pick the three or four that drive the most decisions and instrument them reliably before adding a fifth. And benchmarks must match segment and ARR band. A 110% NRR is strong for a down-market SMB book and weak for an enterprise motion with large expansion headroom. The segment benchmarks on each metric page reflect that.</p>
    </section>

    <section class="pillar-faq">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <details class="faq-item">
            <summary class="faq-question">{item.q}</summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="pillar-related">
      <h2>Related topics</h2>
      <div class="related-grid">
        <a href="/customer-success-principles/" class="related-card">
          <h3>Customer success principles</h3>
          <p>The six beliefs that shape which metrics are worth tracking in the first place.</p>
        </a>
        <a href="/customer-success-playbooks/" class="related-card">
          <h3>Customer success playbooks</h3>
          <p>Stage-specific plays that drive the metrics in this directory.</p>
        </a>
        <a href="/customer-success-maturity-model/" class="related-card">
          <h3>Maturity model</h3>
          <p>The four stages that set priority on each metric.</p>
        </a>
        <a href="/assess/" class="related-card">
          <h3>Take the assessment</h3>
          <p>Get a stage-specific metric priority list for your team.</p>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .metrics-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
  }

  .metrics-loop-indicator {
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
  }

  /* CTA banner */
  .assess-cta-banner {
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .assess-cta-banner p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .cta-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    padding: 0.375rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: transparent;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .filter-btn:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
  }

  .filter-btn.active {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  /* Metrics grid */
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .metrics-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .metric-card {
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease-out, transform 0.2s ease-out;
    display: flex;
    flex-direction: column;
  }

  .metric-card:hover {
    border-color: var(--color-accent);
    color: inherit;
    transform: translateY(-2px);
  }

  .metric-card.dimmed {
    opacity: 0.5;
  }

  .metric-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .category-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border-radius: 0.25rem;
  }

  .cat-revenue { background: var(--color-accent-subtle); color: var(--color-accent); }
  .cat-retention { background: color-mix(in srgb, var(--color-stage-crawl) 14%, transparent); color: var(--color-stage-crawl); }
  .cat-onboarding { background: color-mix(in srgb, var(--color-stage-run) 14%, transparent); color: var(--color-stage-run); }
  .cat-health { background: color-mix(in srgb, var(--color-stage-fly) 14%, transparent); color: var(--color-stage-fly); }
  .cat-sentiment { background: color-mix(in srgb, #CE93D8 14%, transparent); color: #CE93D8; }
  .cat-usage { background: color-mix(in srgb, var(--color-stage-walk) 14%, transparent); color: var(--color-stage-walk); }
  .cat-ai { background: color-mix(in srgb, #7986CB 14%, transparent); color: #7986CB; }

  .metric-name {
    font-size: 1.0625rem;
    font-family: var(--font-display);
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .metric-def {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    flex: 1;
  }

  :global(.priority-pill) {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.priority-high) { background: color-mix(in srgb, var(--color-stage-run) 18%, transparent); color: var(--color-stage-run); }
  :global(.priority-medium) { background: color-mix(in srgb, var(--color-stage-walk) 18%, transparent); color: var(--color-stage-walk); }
  :global(.priority-low) { background: color-mix(in srgb, var(--color-text-muted) 10%, transparent); color: var(--color-text-muted); }

  :global(.context-banner) {
    padding: 0.875rem 1.25rem;
    border-radius: 0.75rem;
    margin-bottom: 2rem;
    font-size: 0.9375rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: color-mix(in srgb, var(--stage-color, var(--color-accent)) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--stage-color, var(--color-accent)) 30%, transparent);
  }

  :global(.context-banner-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--stage-color, var(--color-accent));
  }

  :global(.context-banner-stage) {
    color: var(--stage-color, var(--color-accent));
  }

  /* Pillar content */
  .pillar-intro {
    max-width: 44rem;
    margin-top: 3.5rem;
    margin-bottom: 2.5rem;
  }
  .pillar-intro h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .pillar-intro h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }
  .pillar-intro p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 0.875rem;
  }
  .pillar-intro strong {
    color: var(--color-text-primary);
  }

  .grid-heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: 1.5rem 0 1rem;
    color: var(--color-text-primary);
  }

  .pillar-faq {
    margin-top: 4rem;
    max-width: 44rem;
  }
  .pillar-faq h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    color: var(--color-text-primary);
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item {
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .faq-question {
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    float: right;
    color: var(--color-text-muted);
    font-weight: 400;
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-question::after { content: '–'; }
  .faq-answer {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .pillar-related {
    margin-top: 4rem;
  }
  .pillar-related h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  @media (min-width: 640px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .related-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .related-card {
    padding: 1rem 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: inherit;
  }
  .related-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: 0.375rem;
    color: var(--color-text-primary);
  }
  .related-card p {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
</style>

<script>
  import { isAssessmentCompleted, getScores } from '../../scripts/context-manager.js';

  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run', fly: 'Fly' };

  // Category filtering
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.metric-card').forEach(card => {
        const cat = (card as HTMLElement).getAttribute('data-category');
        (card as HTMLElement).style.display = (filter === 'all' || cat === filter) ? '' : 'none';
      });
    });
  });

  // Contextual overlay
  if (isAssessmentCompleted()) {
    const scores = getScores();
    if (scores && scores.stage) {
      const stage = scores.stage;

      // Show/hide assessed elements
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => (el as HTMLElement).style.display = '');
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => (el as HTMLElement).style.display = 'none');

      // Banner
      const banner = document.getElementById('metrics-context-banner');
      if (banner) {
        banner.innerHTML = `<div class="context-banner stage-${stage}">
          <span class="context-banner-dot"></span>
          Showing priorities for your stage: <strong class="context-banner-stage">${stageLabels[stage]}</strong>
        </div>`;
      }

      // Priority indicators on cards
      document.querySelectorAll('.metric-card').forEach(card => {
        const priorities = JSON.parse((card as HTMLElement).getAttribute('data-priorities') || '{}');
        const priority = priorities[stage];
        const metricId = (card as HTMLElement).getAttribute('data-metric-id');
        const slot = card.querySelector(`[data-priority-slot="${metricId}"]`);
        if (slot && priority) {
          slot.innerHTML = `<span class="priority-pill priority-${priority}">${priority}</span>`;
        }
        if (priority === 'low') {
          card.classList.add('dimmed');
        }
      });

      // Sort: high > medium > low
      const grid = document.getElementById('metrics-grid');
      if (grid) {
        const cards = [...grid.querySelectorAll('.metric-card')];
        const order: Record<string, number> = { high: 0, medium: 1, low: 2 };
        cards.sort((a, b) => {
          const pa = JSON.parse(a.getAttribute('data-priorities') || '{}')[stage] || 'low';
          const pb = JSON.parse(b.getAttribute('data-priorities') || '{}')[stage] || 'low';
          return (order[pa] ?? 3) - (order[pb] ?? 3);
        });
        cards.forEach(c => grid.appendChild(c));
      }
    }
  }
</script>
