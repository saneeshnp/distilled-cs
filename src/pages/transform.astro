---
import BaseLayout from '../layouts/BaseLayout.astro';
import StrategyLoop from '../components/StrategyLoop.astro';
import DataBackup from '../components/DataBackup.astro';
import frameworkData from '../data/lean-cs-data.json';

const stageTransitions = frameworkData.stage_transitions;
const stages = frameworkData.maturity_stages.stages;
const domains = frameworkData.assessment_domains.domains;

const stageOrder = ['crawl', 'walk', 'run'];
const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };
const transitionKeys: Record<string, string> = {
  crawl: 'crawl_to_walk',
  walk: 'walk_to_run',
};

const domainLabels: Record<string, string> = {};
domains.forEach((d: any) => { domainLabels[d.id] = d.label; });
---

<BaseLayout title="Transform: Track CS Maturity Progress" description="Track CS maturity progress over time, re-assess to validate growth, and review the trigger signals for moving to the next stage.">
  <div class="container">
  <div class="transform-page">

    <!-- Strategy Loop wayfinding -->
    <div class="transform-loop-indicator">
      <StrategyLoop activePhase="transform" size="sm" />
    </div>

    <div class="page-header">
      <h1 class="page-title">Transform</h1>
      <p class="page-subtitle">Measure your progress. Re-assess to validate growth. Cross into your next maturity stage.</p>
    </div>

    <!-- Why Transform callout (visible to all users) -->
    <div class="principle-callout">
      <span class="principle-callout-eyebrow">Why Transform?</span>
      <p class="principle-callout-text">Customer Success maturity is built through deliberate iteration. This phase closes the loop by measuring impact, capturing learnings, and preparing your team for the next cycle. Read our CS principle to know more: <a href="/customer-success-principles/maturity-requires-iteration/" class="principle-callout-link">Maturity Requires Iteration</a>.</p>
    </div>

    <!-- ═══ Assessed user view (JS-populated) ═══ -->
    <div id="transform-assessed" data-show-if-assessed style="display:none;">

      <!-- Progress dashboard -->
      <div class="dashboard-grid">
        <!-- Current stage card -->
        <div class="dash-card dash-card-stage" id="dash-stage-card">
          <span class="dash-label">Current Stage</span>
          <div class="dash-stage-display">
            <span class="dash-stage-badge" id="dash-stage-badge"></span>
            <span class="dash-score" id="dash-score"></span>
          </div>
        </div>

        <!-- Assessment age -->
        <div class="dash-card">
          <span class="dash-label">Last Assessment</span>
          <span class="dash-value" id="dash-age"></span>
        </div>

        <!-- Checklist progress -->
        <a href="/checklist/" class="dash-card dash-card-link" id="dash-checklist-card">
          <span class="dash-label">Checklist Progress</span>
          <div class="dash-checklist-row">
            <div class="dash-progress-bar-wrap">
              <div class="dash-progress-bar" id="dash-checklist-bar"></div>
            </div>
            <span class="dash-value dash-value-sm" id="dash-checklist-pct"></span>
          </div>
          <span class="dash-checklist-items" id="dash-checklist-items"></span>
          <span class="dash-card-cta">View checklist →</span>
        </a>
      </div>

      <!-- Domain breakdown -->
      <section class="transform-section" id="domain-breakdown-section">
        <h2 class="section-heading">Scores Across CS Domains</h2>
        <div class="domain-bars" id="domain-bars"></div>
      </section>

      <!-- Previous assessment comparison (if exists) -->
      <section class="transform-section" id="comparison-section" style="display:none;">
        <h2 class="section-heading">Progress Since Last Assessment</h2>
        <div class="comparison-summary" id="comparison-summary"></div>
        <div class="comparison-grid" id="comparison-grid"></div>
      </section>

      <!-- Stage transition guide -->
      <section class="transform-section" id="transition-section">
        <h2 class="section-heading" id="transition-heading"></h2>
        <div class="transition-content" id="transition-content"></div>
      </section>

      <!-- Re-assess CTA -->
      <div class="reassess-cta">
        <h2 class="reassess-headline">Ready to validate your growth?</h2>
        <p class="reassess-body">Re-take the assessment to see how far you've come. Your previous results will be saved for comparison.</p>
        <div class="reassess-actions">
          <a href="/assess/?mode=update" class="btn btn-primary btn-large">Re-Assess Now</a>
          <button type="button" id="download-ics-btn" class="btn btn-outline btn-large">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="3" width="12" height="11" rx="1.5"/>
              <path d="M5 1v3M11 1v3M2 7h12"/>
            </svg>
            Download 90-day reminder
          </button>
        </div>
        <p class="reassess-ics-hint">Adds a calendar event 90 days from your last assessment.</p>
      </div>

      <DataBackup />
    </div>

    <!-- ═══ Not-assessed user view ═══ -->
    <div id="transform-not-assessed" data-hide-if-assessed>

      <!-- Hero -->
      <div class="na-hero">
        <h2 class="na-headline">Transform begins with knowing <em class="na-headline-accent">where you stand</em></h2>
        <p class="na-body">Track progress, compare results, and prepare for your next maturity stage. But first, you need a baseline.</p>
        <div class="na-cta-group">
          <a href="/assess/" class="btn btn-primary btn-large">Take the Assessment</a>
          <p class="na-hint">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Takes just 5 minutes
          </p>
        </div>
      </div>

      <!-- Steps -->
      <div class="na-steps-section">
        <p class="na-steps-label">Your path to progress</p>
        <div class="na-steps-grid">

          <div class="na-step-card">
            <span class="na-step-num">01</span>
            <div class="na-step-icon-wrap" aria-hidden="true">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </div>
            <strong class="na-step-title">Assess</strong>
            <p class="na-step-desc">Take the 5-minute maturity assessment to establish your baseline.</p>
          </div>

          <div class="na-step-connector" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>

          <div class="na-step-card">
            <span class="na-step-num">02</span>
            <div class="na-step-icon-wrap" aria-hidden="true">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" y1="9" x2="6" y2="21"/></svg>
            </div>
            <strong class="na-step-title">Execute</strong>
            <p class="na-step-desc">Follow your stage-specific playbooks and track the right metrics.</p>
          </div>

          <div class="na-step-connector" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>

          <div class="na-step-card na-step-card--current">
            <span class="na-step-num">03</span>
            <div class="na-step-icon-wrap" aria-hidden="true">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
            <strong class="na-step-title">Transform</strong>
            <p class="na-step-desc">Come back here to measure your progress and re-assess when ready.</p>
          </div>

        </div>
      </div>

      <DataBackup />

      <div class="transform-explainer">
          <h2>What the Transform phase does</h2>
          <p>
            The Distilled CS framework runs on a continuous improvement loop: Assess, Execute, Transform. Transform is the closing step that turns one cycle into the next. Once you have a baseline and have worked through a round of stage-specific playbooks, Transform is where you measure whether the work moved the needle and decide when you are ready to operate at the next stage.
          </p>

          <h2>Re-assessment and stage transitions</h2>
          <p>
            Re-assessing uses the same eight-domain questionnaire you started with, but stored responses from your first pass are preloaded so you can edit only what has changed. When you submit, Transform renders a domain-by-domain delta against your previous scores. Stage transitions are treated as capability shifts, not score crossings. Each transition (Crawl to Walk, Walk to Run) has a published list of trigger signals, key operational shifts, and new capabilities the next stage assumes you have. If most of those apply, you are ready. If only one or two do, re-assess in another quarter.
          </p>

          <h2>What a healthy cadence looks like</h2>
          <p>
            For teams in Crawl or Walk, quarterly re-assessment is about right. Foundational changes take 8 to 12 weeks to show up in the questionnaire. For Run teams, semiannual re-assessment avoids the noise of short-term fluctuations. Pair re-assessment with a QBR or annual planning cycle so the outputs feed directly into goals and staffing decisions rather than sitting in a browser tab.
          </p>

          <p class="transform-explainer-followups">
            Related reading: the <a href="/customer-success-maturity-model/">customer success maturity model</a>, the <a href="/customer-success-principles/">seven guiding principles</a>, and stage-specific <a href="/customer-success-playbooks/">playbooks</a> and <a href="/customer-success-metrics/">metrics</a>.
          </p>
        </div>
      </div>
    </div>

  </div>
  </div>
</BaseLayout>

<style>
  .transform-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 52rem;
    margin-inline: auto;
  }

  .transform-loop-indicator {
    max-width: 48rem;
    margin-inline: auto;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    line-height: 1.6;
  }

  /* ── Dashboard grid ── */
  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .dashboard-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .dash-card {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dash-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dash-stage-display {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .dash-stage-badge {
    padding: 0.3rem 0.875rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 9999px;
    font-family: var(--font-body);
  }

  .dash-score {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .dash-value {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-text-primary);
  }

  .dash-value-sm {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .dash-progress-bar-wrap {
    height: 6px;
    background: var(--color-surface-hover);
    border-radius: 3px;
    overflow: hidden;
  }

  .dash-progress-bar {
    height: 100%;
    background: var(--color-accent);
    border-radius: 3px;
    transition: width 0.8s ease-out;
    width: 0%;
  }

  .dash-checklist-items {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .dash-card-link {
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .dash-card-link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .dash-card-cta {
    display: block;
    margin-top: auto;
    padding-top: 0.625rem;
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  /* ── Sections ── */
  .transform-section {
    margin-bottom: 3rem;
  }

  .section-heading {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    color: var(--color-text-primary);
  }

  #transition-heading {
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* Domain bars */
  .domain-bars {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* ── Comparison containers (static HTML, content populated by JS) ── */
  .comparison-summary {
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .comparison-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ── Transition guide container (static, grid layout) ── */
  .transition-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .transition-content {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Re-assess CTA ── */
  .reassess-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-top: 2rem;
  }

  .reassess-headline {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .reassess-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    max-width: 28rem;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .reassess-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .reassess-ics-hint {
    margin: 0.875rem auto 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .principle-callout {
    background: var(--color-accent-subtle);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .principle-callout-eyebrow {
    display: block;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.375rem;
  }

  .principle-callout-text {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.55;
  }

  .principle-callout-link {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .principle-callout-link:hover {
    text-decoration: underline;
  }

  /* ── Not-assessed view ── */
  .na-hero {
    text-align: center;
    padding: 3rem 1.5rem 2rem;
  }

  .na-headline {
    font-size: clamp(1.625rem, 4vw, 2.375rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 auto 1rem;
  }

  .na-headline-accent {
    font-style: normal;
    color: var(--color-accent);
  }

  .na-body {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 42rem;
    margin: 0 auto 1.75rem;
    line-height: 1.6;
  }

  .na-cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .na-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Step cards ── */
  .na-steps-section {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .na-steps-label {
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
  }

  .na-steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  .na-step-connector {
    display: none;
  }

  @media (min-width: 640px) {
    .na-steps-grid {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: 0;
      align-items: center;
    }

    .na-step-connector {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 0 0.625rem;
      color: var(--color-border);
    }
  }

  .na-step-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.375rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .na-step-card--current {
    border-color: var(--color-accent-subtle);
    background: var(--color-accent-subtle);
  }

  .na-step-num {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .na-step-icon-wrap {
    width: 2.625rem;
    height: 2.625rem;
    border-radius: 50%;
    background: var(--color-accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin: 0.375rem 0 0.5rem;
    flex-shrink: 0;
  }

  .na-step-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    display: block;
  }

  .na-step-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .na-step-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-accent);
    opacity: 0.75;
    margin-top: 0.625rem;
  }

  /* Expanded explainer (SEO fallback prose) */
  .transform-explainer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .transform-explainer h2 {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: 1.375rem;
    letter-spacing: -0.01em;
    margin: 1.75rem 0 0.5rem;
    color: var(--color-text);
  }

  .transform-explainer h2:first-child {
    margin-top: 0;
  }

  .transform-explainer p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem;
  }

  .transform-explainer a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .transform-explainer-followups {
    margin-top: 1.25rem !important;
    font-size: 0.875rem !important;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.2s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-accent);
    border: 1.5px solid var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-family: var(--font-body);
  }

  .btn-outline:hover {
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .btn-large {
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }
</style>

<!-- Global styles for JS-injected elements (innerHTML bypasses Astro scoping) -->
<style is:global>
  /* ── Domain bar rows (JS-generated) ── */
  .domain-bar-row {
    padding: 0.875rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }


  .domain-bar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .domain-bar-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .domain-bar-score {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--stage-color, var(--color-accent));
    white-space: nowrap;
    flex-shrink: 0;
  }

  .domain-bar-denom {
    font-weight: 400;
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  .domain-bar-track {
    height: 6px;
    background: var(--color-surface-hover);
    border-radius: 3px;
    overflow: hidden;
  }

  .domain-bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.8s ease-out;
    background: var(--stage-color, var(--color-accent));
  }


  /* ── Comparison rows (JS-generated) ── */
  .comparison-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-size: 0.875rem;
  }

  .comparison-domain {
    color: var(--color-text-secondary);
  }

  .comparison-delta {
    font-weight: 600;
    font-family: var(--font-body);
  }

  .delta-up { color: var(--color-success); }
  .delta-down { color: var(--color-danger); }
  .delta-same { color: var(--color-text-muted); }

  /* ── Transition blocks (JS-generated) ── */
  .transition-block {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
  }

  .transition-block-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--color-surface-hover);
    border-radius: 50%;
    color: var(--stage-color, var(--color-accent));
    margin-bottom: 0.875rem;
    flex-shrink: 0;
  }

  .transition-block h3 {
    font-size: 1.2rem;
    color: var(--color-text-primary);
    margin-bottom: 0.875rem;
  }

  .transition-block h3::before {
    content: '';
    display: block;
    width: 2.5rem;
    height: 3px;
    background: var(--stage-color, var(--color-accent));
    border-radius: 2px;
    margin-bottom: 0.625rem;
  }

  .transition-block ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .transition-block li {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    padding-left: 1.125rem;
    position: relative;
  }

  .transition-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.575em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--stage-color, var(--color-accent));
    opacity: 0.55;
  }
</style>

<script>
  import { toDisplayScore } from '../scripts/scoring-engine.js';
  import { animateDomainBars } from '../scripts/animate-domain-bars.js';
  import frameworkData from '../data/lean-cs-data.json';

  const stages = frameworkData.maturity_stages.stages;
  const stageOrder = ['crawl', 'walk', 'run'];
  const stageLabels = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };

  const domainLabels = {
    segmentation_coverage: 'Segmentation & Coverage',
    journey_lifecycle: 'Journey & Lifecycle',
    health_risk: 'Health Scoring & Risk',
    metrics_data: 'Metrics & Data',
    expansion_value: 'Expansion & Value',
    org_strategy: 'CS Organization & Strategy',
    cs_culture_alignment: 'CS Culture & Cross-Functional Alignment',
    ai_leverage: 'AI Leverage in CS',
  };

  const transitionKeys = {
    crawl: 'crawl_to_walk',
    walk: 'walk_to_run',
  };

  try {
    const completed = localStorage.getItem('distilledcs_completed');
    const scoresRaw = localStorage.getItem('distilledcs_scores');
    const previousRaw = localStorage.getItem('distilledcs_previous_scores');
    const profileRaw = localStorage.getItem('distilledcs_profile');
    const userProfile = profileRaw ? JSON.parse(profileRaw) : {};
    const companyName = userProfile?.company_name || '';

    if (completed === 'true' && scoresRaw) {
      const scores = JSON.parse(scoresRaw);
      const userStage = scores.stage;
      const currentIdx = stageOrder.indexOf(userStage);
      const nextStage = currentIdx < 2 ? stageOrder[currentIdx + 1] : null;

      // Show assessed view, hide not-assessed
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => el.style.display = '');
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => el.style.display = 'none');

      // Personalize stage card label with company name
      const stageLabelEl = document.querySelector('#dash-stage-card .dash-label');
      if (stageLabelEl && companyName) {
        stageLabelEl.textContent = `${companyName}'s Stage`;
      }

      // Apply stage class to the card so nested elements inherit --stage-color.
      const stageCard = document.getElementById('dash-stage-card');
      if (stageCard) stageCard.classList.add(`stage-${userStage}`);

      // Stage card — class-based badge (picks up --stage-color and --color-on-stage).
      const badge = document.getElementById('dash-stage-badge');
      if (badge) {
        badge.textContent = stageLabels[userStage] || userStage;
        badge.classList.add('stage-badge', `stage-${userStage}`);
      }
      const scoreEl = document.getElementById('dash-score');
      if (scoreEl) scoreEl.textContent = `Score: ${toDisplayScore(scores.overallScore) ?? '—'}`;

      // Assessment age
      const ageEl = document.getElementById('dash-age');
      if (ageEl && scores.timestamp) {
        const days = Math.floor((Date.now() - new Date(scores.timestamp).getTime()) / (1000 * 60 * 60 * 24));
        if (days === 0) ageEl.textContent = 'Today';
        else if (days === 1) ageEl.textContent = '1 day ago';
        else ageEl.textContent = `${days} days ago`;
      } else if (ageEl) {
        ageEl.textContent = '—';
      }

      // Checklist progress
      try {
        const checklistRaw = localStorage.getItem('distilledcs_checklist');
        const checklist = checklistRaw ? JSON.parse(checklistRaw) : {};

        // Compute total from actual stage items (same logic as checklist.astro)
        const allChecklistItems: string[] = [];
        if (currentIdx > 0) {
          const prev = stages[currentIdx - 1] as any;
          prev.priority_actions.forEach((_: any, i: number) => allChecklistItems.push(`${prev.id}_${i}`));
        }
        const cur = stages[currentIdx] as any;
        cur.priority_actions.forEach((_: any, i: number) => allChecklistItems.push(`${cur.id}_${i}`));
        if (currentIdx < stages.length - 1) {
          const next = stages[currentIdx + 1] as any;
          next.priority_actions.forEach((_: any, i: number) => allChecklistItems.push(`${next.id}_${i}`));
        }

        const total = allChecklistItems.length;
        const done = allChecklistItems.filter(id => checklist[id]).length;
        const pct = total > 0 ? Math.round((done / total) * 100) : 0;
        const checklistCard = document.getElementById('dash-checklist-card');
        const bar = document.getElementById('dash-checklist-bar');
        const pctEl = document.getElementById('dash-checklist-pct');
        const itemsEl = document.getElementById('dash-checklist-items');
        if (bar) bar.style.width = `${pct}%`;
        if (pctEl) pctEl.textContent = `${pct}%`;
        if (itemsEl) itemsEl.textContent = total > 0 ? `${done}/${total} items` : 'No items tracked yet';
        if (checklistCard) animateDomainBars({
          container: checklistCard,
          rowSelector: '.dash-checklist-row',
          fillSelector: '.dash-progress-bar',
          valueSelector: '#dash-checklist-pct',
        });
      } catch { /* ignore */ }

      // Domain breakdown bars
      const domainBarsEl = document.getElementById('domain-bars');
      if (domainBarsEl && scores.domainScores) {
        let html = '';
        for (const [domId, score] of Object.entries(scores.domainScores)) {
          const pct = ((score / 4) * 100).toFixed(1);
          const label = domainLabels[domId] || domId;
          html += `
            <div class="domain-bar-row stage-${userStage}">
              <div class="domain-bar-header">
                <span class="domain-bar-label">${label}</span>
                <span class="domain-bar-score">${toDisplayScore(score)}<span class="domain-bar-denom"> / 10</span></span>
              </div>
              <div class="domain-bar-track">
                <div class="domain-bar-fill" style="width: ${pct}%;"></div>
              </div>
            </div>
          `;
        }
        domainBarsEl.innerHTML = html;

        animateDomainBars({
          container: domainBarsEl,
          rowSelector: '.domain-bar-row',
          fillSelector: '.domain-bar-fill',
          valueSelector: '.domain-bar-score',
        });
      }

      // Previous assessment comparison
      if (previousRaw) {
        const prev = JSON.parse(previousRaw);
        const compSection = document.getElementById('comparison-section');
        const compSummary = document.getElementById('comparison-summary');
        const compGrid = document.getElementById('comparison-grid');

        if (compSection && compSummary && compGrid && prev.domainScores && scores.domainScores) {
          compSection.style.display = '';

          // Stage comparison
          const prevStageLabel = stageLabels[prev.stage] || prev.stage;
          const currStageLabel = stageLabels[userStage] || userStage;
          const rawDelta = scores.overallScore - (prev.overallScore || 0);
          const scoreDelta = (rawDelta * 2.5).toFixed(1);
          const stageChanged = prev.stage !== userStage;

          const prevIdx = stageOrder.indexOf(prev.stage);
          const stageAdvanced = stageChanged && currentIdx > prevIdx;
          const stageRegressed = stageChanged && currentIdx < prevIdx;

          let summaryHtml = '';
          if (stageAdvanced) {
            summaryHtml = `<strong>You advanced from ${prevStageLabel} to ${currStageLabel}!</strong> Overall score changed by <strong>${rawDelta >= 0 ? '+' : ''}${scoreDelta}</strong>.`;
          } else if (stageRegressed) {
            summaryHtml = `<strong>Your stage dropped from ${prevStageLabel} to ${currStageLabel}.</strong> Overall score changed by <strong>${scoreDelta}</strong>.`;
          } else {
            summaryHtml = `You're still in the <strong>${currStageLabel}</strong> stage. Overall score changed by <strong>${rawDelta >= 0 ? '+' : ''}${scoreDelta}</strong>.`;
          }

          // Find improved and declined domains (skip domains new to this assessment)
          const improved = [];
          const declined = [];
          for (const [domId, score] of Object.entries(scores.domainScores)) {
            if (prev.domainScores[domId] === undefined) continue;
            const delta = score - prev.domainScores[domId];
            if (delta > 0.1) improved.push(domainLabels[domId] || domId);
            else if (delta < -0.1) declined.push(domainLabels[domId] || domId);
          }

          if (improved.length > 0) summaryHtml += ` You improved in <strong>${improved.join(', ')}</strong>.`;
          if (declined.length > 0) summaryHtml += ` Focus next on <strong>${declined.join(', ')}</strong>.`;

          compSummary.innerHTML = summaryHtml;

          // Domain-by-domain comparison
          let gridHtml = '';
          for (const [domId, score] of Object.entries(scores.domainScores)) {
            const label = domainLabels[domId] || domId;
            let deltaClass = 'delta-same';
            let deltaText = '—';
            if (prev.domainScores[domId] === undefined) {
              deltaText = 'New';
            } else {
              const delta = score - prev.domainScores[domId];
              if (delta > 0.01) { deltaClass = 'delta-up'; deltaText = `+${(delta * 2.5).toFixed(1)} ↑`; }
              else if (delta < -0.01) { deltaClass = 'delta-down'; deltaText = `${(delta * 2.5).toFixed(1)} ↓`; }
              else { deltaText = 'No change'; }
            }

            gridHtml += `
              <div class="comparison-row">
                <span class="comparison-domain">${label}</span>
                <span class="comparison-delta ${deltaClass}">${deltaText}</span>
              </div>
            `;
          }
          compGrid.innerHTML = gridHtml;
        }
      }

      // Stage transition guide
      const transKey = transitionKeys[userStage];
      const transHeading = document.getElementById('transition-heading');
      const transContent = document.getElementById('transition-content');
      const transSection = document.getElementById('transition-section');

      if (transKey && transHeading && transContent) {
        // Fetch transition data from embedded JSON
        const transitionData = {
          crawl_to_walk: {
            trigger_signals: ["You have a reliable retention baseline (GRR tracked monthly for 3+ months)", "Basic customer segmentation is in place and being used to differentiate engagement", "At least one documented playbook exists (usually onboarding)", "CSMs are spending more time on proactive outreach than reactive firefighting", "Leadership asks about CS metrics beyond just churn count"],
            key_shifts: ["From gut-feel to data-informed decisions", "From one-size-fits-all to segmented engagement", "From individual heroics to repeatable processes", "From tracking churn to tracking leading indicators"],
            new_capabilities: ["Health scoring enables proactive risk intervention", "Segmentation unlocks differentiated engagement models", "Lifecycle journey maps create predictability", "QBR/EBR programs build executive relationships"],
          },
          walk_to_run: {
            trigger_signals: ["Health scores are established and CSMs use them daily", "Lifecycle journey maps exist and touchpoints are followed consistently", "GRR has stabilized or improved over 2+ quarters", "You're hitting CSM capacity limits", "Expansion revenue is happening but it's opportunistic"],
            key_shifts: ["From human-led to human-plus-digital", "From reactive risk management to predictive", "From cost center to revenue contributor", "From departmental function to cross-functional partner"],
            new_capabilities: ["Digital engagement allows 10x account coverage", "Predictive churn models surface risk 30-60 days earlier", "Formalized expansion motion creates predictable pipeline", "CS operations becomes a recognized function"],
          },
        };

        const trans = transitionData[transKey];
        if (trans) {
          const nextLabel = nextStage ? stageLabels[nextStage] : '';
          transHeading.textContent = `What changes when you move from ${stageLabels[userStage]} to ${nextLabel}`;

          // Apply next stage color to the transition blocks
          if (nextStage) transContent.classList.add(`stage-${nextStage}`);

          const iconCheck = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
          const iconArrow = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
          const iconStar = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M9 2L10.6 6.7L15.7 6.8L11.7 9.9L13.1 14.7L9 11.8L4.9 14.7L6.3 9.9L2.3 6.8L7.4 6.7Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`;

          let html = '';
          html += `<div class="transition-block"><div class="transition-block-icon">${iconCheck}</div><h3>Signs you're ready</h3><ul>${trans.trigger_signals.map(s => `<li>${s}</li>`).join('')}</ul></div>`;
          html += `<div class="transition-block"><div class="transition-block-icon">${iconArrow}</div><h3>Key shifts</h3><ul>${trans.key_shifts.map(s => `<li>${s}</li>`).join('')}</ul></div>`;
          html += `<div class="transition-block"><div class="transition-block-icon">${iconStar}</div><h3>New capabilities you'll unlock</h3><ul>${trans.new_capabilities.map(s => `<li>${s}</li>`).join('')}</ul></div>`;
          transContent.innerHTML = html;
        }
      } else if (transSection && userStage === 'run') {
        // Run is the top stage — no next transition
        transSection.innerHTML = `
          <h2 class="section-heading">You're at the Run stage</h2>
          <div class="transition-block">
            <p>Run is the destination stage. The work here is continuous refinement: sharpening predictive models, expanding AI-assisted workflows, and deepening cross-functional alignment. Re-assess semiannually to track domain-level progress and set priorities for the next cycle.</p>
          </div>
        `;
      }

    }

    // ── Calendar reminder download ──
    const icsBtn = document.getElementById('download-ics-btn');
    if (icsBtn) {
      icsBtn.addEventListener('click', () => {
        try {
          const scoresRaw = localStorage.getItem('distilledcs_scores');
          const scores = scoresRaw ? JSON.parse(scoresRaw) : {};
          const base = scores.timestamp ? new Date(scores.timestamp) : new Date();
          const remind = new Date(base.getTime() + 90 * 24 * 60 * 60 * 1000);

          function toIcsDate(d: Date): string {
            return d.toISOString().slice(0, 10).replace(/-/g, '');
          }

          const uid = `distilledcs-reassess-${base.getTime()}@distilledcs.org`;
          const dtstamp = new Date().toISOString().replace(/[-:.]/g, '').slice(0, 15) + 'Z';
          const dtstart = toIcsDate(remind);
          const dtend = toIcsDate(new Date(remind.getTime() + 24 * 60 * 60 * 1000));

          const lines = [
            'BEGIN:VCALENDAR',
            'VERSION:2.0',
            'PRODID:-//Distilled CS//Re-Assessment Reminder//EN',
            'CALSCALE:GREGORIAN',
            'METHOD:PUBLISH',
            'BEGIN:VEVENT',
            `UID:${uid}`,
            `DTSTAMP:${dtstamp}`,
            `DTSTART;VALUE=DATE:${dtstart}`,
            `DTEND;VALUE=DATE:${dtend}`,
            'SUMMARY:Re-take CS Maturity Assessment',
            'DESCRIPTION:90 days have passed since your last CS maturity assessment.' +
              ' Re-take it at https://distilledcs.org/assess/ to track your progress and plan your next improvement cycle.',
            'URL:https://distilledcs.org/assess/',
            'BEGIN:VALARM',
            'TRIGGER:-P1D',
            'ACTION:DISPLAY',
            'DESCRIPTION:CS Maturity Assessment reminder — due tomorrow',
            'END:VALARM',
            'END:VEVENT',
            'END:VCALENDAR',
          ];

          const blob = new Blob([lines.join('\r\n')], { type: 'text/calendar;charset=utf-8' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'cs-assessment-reminder.ics';
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        } catch {
          // ignore
        }
      });
    }

  } catch {
    // Ignore localStorage errors
  }
</script>
