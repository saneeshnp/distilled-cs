---
import BaseLayout from '../layouts/BaseLayout.astro';
import StrategyLoop from '../components/StrategyLoop.astro';
import frameworkData from '../data/lean-cs-data.json';

const stages = frameworkData.maturity_stages.stages;
const playbooks = frameworkData.playbooks;
const stageOrder = ['crawl', 'walk', 'run'];

const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };
---

<BaseLayout title="Execution Checklist" description="Track progress against the priority actions for your current maturity stage. Items map directly to playbooks and persist between visits.">
  <div class="container checklist-page">

    <!-- Strategy Loop wayfinding -->
    <div class="checklist-loop-indicator">
      <StrategyLoop activePhase="execute" size="sm" />
    </div>

    <!-- Assessed view (JS populated) -->
    <div id="checklist-assessed" data-show-if-assessed style="display:none;"></div>

    <!-- Non-assessed view -->
    <div id="checklist-default" data-hide-if-assessed>
      <div class="page-header">
        <h1 class="page-title">Execution Checklist</h1>
        <p class="page-subtitle">Track your progress on the priority actions from your stage playbooks. Take the assessment to get a personalized, interactive checklist.</p>
        <div class="checklist-header-actions">
          <a href="/assess/" class="btn btn-primary">Take the Assessment</a>
          <button type="button" class="checklist-export-btn" data-open-export>
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 1.5v8M5 6.5l3 3 3-3"/><path d="M2.5 11v2a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-2"/></svg>
            Export checklist
          </button>
        </div>
      </div>

      <div class="checklist-explainer">
        <h2>How this checklist works</h2>
        <p>
          The execution checklist is the Execute half of the Distilled CS improvement loop. It turns stage-specific recommendations into a concrete list of actions you can complete in the order that best fits your team. The items below are drawn directly from each maturity stage's priority actions in the framework, grouped by stage so you can see both your current scope and what sits one stage ahead.
        </p>

        <h2>How items map to stages and playbooks</h2>
        <p>
          Each action belongs to a specific maturity stage (Crawl, Walk, or Run) and traces back to one or more playbooks. The "Related Playbooks" row under each stage links out to the full playbook pages, which cover the objective, step-by-step structure, metrics to watch, and common pitfalls. Crawl-stage items focus on establishing a baseline: a defined onboarding motion, a working health score, a QBR cadence for high-ARR accounts. Walk-stage items layer on segmentation and measurement. Run items move the team toward predictive and proactive operations.
        </p>

        <h2>Why the order matters</h2>
        <p>
          Stage order is not cosmetic. Crawl actions build the foundation that Walk plays assume you already have; Walk builds the measurement discipline that Run automates. Skipping ahead tends to produce tooling-rich, outcomes-poor motions. Take the <a href="/assess/">five-minute assessment</a> first to confirm which stage you are actually operating at, then work your current stage's list before pulling items from the next.
        </p>

        <p class="checklist-explainer-followups">
          Related: the <a href="/customer-success-maturity-model/">customer success maturity model</a>, full <a href="/customer-success-playbooks/">playbook directory</a>, and stage-specific <a href="/customer-success-metrics/">metrics</a> to track alongside each action.
        </p>
      </div>

      {stages.map(stage => {
        const stagePlaybooks = (playbooks as any)[stage.id] || [];
        return (
          <div class={`stage-checklist-block stage-${stage.id}`}>
            <h2 class="stage-checklist-title">
              <span class="stage-dot"></span>
              <span class="stage-checklist-label">{stage.label}</span>
              <span class="stage-checklist-subtitle">{stage.subtitle}</span>
            </h2>
            {stagePlaybooks.length > 0 && (
              <div class="related-playbooks-row">
                <span class="related-label">Related Playbooks:</span>
                {stagePlaybooks.map((pb: any) => (
                  <a href={`/customer-success-playbooks/${pb.id}/`} class="related-playbook-link">{pb.title}</a>
                ))}
              </div>
            )}
            <ul class="checklist-static">
              {stage.priority_actions.map((action: any) => {
                const text = typeof action === 'string' ? action : action.text;
                const time = typeof action === 'object' ? action.estimated_time : null;
                const why = typeof action === 'object' ? action.why_it_matters : null;
                return (
                  <li>
                    <span class="action-text">{text}</span>
                    {time && <span class="action-time">{time}</span>}
                    {why && <p class="action-why">{why}</p>}
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })}
    </div>

    <!-- ═══ Export modal ═══ -->
    <div class="export-modal" id="export-modal" role="dialog" aria-modal="true" aria-labelledby="export-modal-title" hidden>
      <div class="export-modal-backdrop" id="export-modal-backdrop"></div>
      <div class="export-modal-panel" role="document">
        <div class="export-modal-header">
          <h2 class="export-modal-title" id="export-modal-title">Export checklist</h2>
          <button type="button" class="export-modal-close" id="export-modal-close" aria-label="Close export dialog">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.5 3.5l9 9M12.5 3.5l-9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </button>
        </div>

        <div class="export-modal-body">
          <div>
            <span class="export-field-label">Format</span>
            <div class="export-format-options">
              <label class="export-format-option">
                <input type="radio" name="export-format" value="md" checked />
                <span>Markdown</span>
              </label>
              <label class="export-format-option">
                <input type="radio" name="export-format" value="txt" />
                <span>Plain text</span>
              </label>
            </div>
          </div>

          <div>
            <span class="export-field-label">Sections</span>
            <div class="export-sections" id="export-sections"></div>
          </div>

          <label class="export-toggle">
            <input type="checkbox" id="export-include-notes" checked />
            <span>Include "why it matters" notes</span>
          </label>

          <div>
            <span class="export-field-label">Preview</span>
            <textarea class="export-preview" id="export-preview" readonly spellcheck="false" rows="8"></textarea>
          </div>

          <div class="export-actions">
            <button type="button" class="export-action-btn export-action-secondary" id="export-download">Download file</button>
            <button type="button" class="export-action-btn export-action-primary" id="export-copy">Copy</button>
          </div>
        </div>

        <div class="export-modal-footer">
          Exports the sections you select. Everything happens in your browser, nothing is uploaded.
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .checklist-page {
    padding-top: 2rem;
    padding-bottom: 6rem;
    max-width: 48rem;
    margin-inline: auto;
  }

  .checklist-loop-indicator {
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  /* SEO fallback explainer */
  .checklist-explainer {
    max-width: 40rem;
    margin: 0 auto 3rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .checklist-explainer h2 {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: 1.375rem;
    letter-spacing: -0.01em;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-text);
  }

  .checklist-explainer h2:first-child {
    margin-top: 0;
  }

  .checklist-explainer p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem;
  }

  .checklist-explainer a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .checklist-explainer-followups {
    margin-top: 1.25rem !important;
    font-size: 0.875rem !important;
  }

  /* Related playbooks row */
  .related-playbooks-row,
  :global(.related-playbooks-row) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.625rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .related-label,
  :global(.related-label) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .related-playbook-link,
  :global(.related-playbook-link) {
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--color-accent-subtle);
    border-radius: 0.25rem;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .related-playbook-link:hover,
  :global(.related-playbook-link:hover) {
    background: var(--color-accent-subtle);
    border-color: var(--color-accent);
  }


  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease-out;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  /* Stage checklist blocks (non-assessed static view) */
  .stage-checklist-block {
    margin-bottom: 2.5rem;
  }

  .stage-checklist-title {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 1.25rem;
    font-family: var(--font-display);
    margin-bottom: 1rem;
  }

  .stage-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--stage-color);
  }

  .stage-checklist-label {
    color: var(--stage-color);
  }

  .stage-checklist-subtitle {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-weight: 400;
  }

  .checklist-static {
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .checklist-static li {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin-bottom: 0.25rem;
  }

  .action-time {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.0625rem 0.375rem;
    border-radius: 9999px;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  .action-why {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0.25rem 0 0;
    font-style: italic;
  }

  /* Interactive checklist styles (JS rendered) */
  :global(.checklist-group) {
    margin-bottom: 2.5rem;
  }

  :global(.checklist-group-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.checklist-group-title) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--stage-color);
  }

  :global(.checklist-group-count) {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  :global(.checklist-progress-bar) {
    height: 4px;
    background: var(--color-surface);
    border-radius: 2px;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }

  :global(.checklist-progress-fill) {
    height: 100%;
    border-radius: 2px;
    transition: width 0.3s ease-out;
    background: var(--stage-color, var(--color-accent));
  }

  :global(.checklist-items) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.checklist-item) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: border-color 0.2s ease-out, opacity 0.2s ease-out;
    user-select: none;
  }

  :global(.checklist-item:hover) {
    border-color: var(--color-border-hover);
  }

  :global(.checklist-item.checked) {
    opacity: 0.6;
  }

  :global(.checklist-item.checked .checklist-text) {
    text-decoration: line-through;
  }

  :global(.checklist-checkbox) {
    width: 1.25rem;
    height: 1.25rem;
    border: 2px solid var(--color-border-hover);
    border-radius: 0.25rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease-out;
  }

  :global(.checklist-item.checked .checklist-checkbox) {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  :global(.checklist-checkmark) {
    color: var(--color-bg);
    font-size: 0.75rem;
    font-weight: 700;
  }

  :global(.checklist-item-content) {
    flex: 1;
    min-width: 0;
  }

  :global(.checklist-item-header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  :global(.checklist-text) {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  :global(.checklist-time) {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  :global(.checklist-why) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-top: 0.375rem;
    margin-bottom: 0;
    font-style: italic;
  }

  :global(.checklist-item.checked .checklist-why) {
    display: none;
  }

  :global(.checklist-celebration) {
    text-align: center;
    padding: 1rem;
    font-size: 0.875rem;
    color: var(--color-accent);
    font-weight: 500;
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  :global(.overall-progress) {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  :global(.overall-progress-label) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.625rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  :global(.overall-progress-pct) {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 1.125rem;
  }

  :global(.overall-progress-bar) {
    height: 6px;
    background: var(--color-bg);
    border-radius: 3px;
    overflow: hidden;
  }

  :global(.overall-progress-fill) {
    height: 100%;
    background: var(--color-accent);
    border-radius: 3px;
    transition: width 0.8s ease-out;
  }

  :global(.next-step-cta) {
    margin-top: 2rem;
  }

  :global(.next-step-link) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    background: var(--color-accent-subtle);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s;
  }

  :global(.next-step-link:hover) {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  :global(.next-step-label) {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.next-step-text) {
    font-size: 0.9375rem;
    color: var(--color-accent);
    font-weight: 500;
  }
</style>

<style is:global>
  .page-header {
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }

  /* ── Export trigger button (used in both static + JS-rendered headers) ── */
  .checklist-header-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .checklist-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1.25rem;
  }

  .checklist-export-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-body);
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: border-color 0.2s ease-out, color 0.2s ease-out;
  }

  .checklist-export-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Export modal ── */
  .export-modal {
    position: fixed;
    inset: 0;
    /* Above the sticky site header (z-index 100) so the dialog overlays it. */
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .export-modal[hidden] { display: none; }

  .export-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.18s ease-out;
  }

  .export-modal.is-open .export-modal-backdrop { opacity: 1; }

  .export-modal-panel {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.22);
    width: 100%;
    max-width: 34rem;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    transform: translateY(8px);
    opacity: 0;
    transition: opacity 0.18s ease-out, transform 0.18s ease-out;
  }

  .export-modal.is-open .export-modal-panel {
    opacity: 1;
    transform: translateY(0);
  }

  .export-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.25rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
  }

  .export-modal-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0;
    color: var(--color-text-primary);
    letter-spacing: -0.005em;
  }

  .export-modal-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    background: transparent;
    border: 1px solid transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.15s ease-out, color 0.15s ease-out;
    min-height: 0;
  }

  .export-modal-close:hover {
    background: var(--color-surface);
    color: var(--color-text-primary);
  }

  @media (pointer: coarse) {
    .export-modal-close {
      min-width: 44px;
      min-height: 44px;
      width: 44px;
      height: 44px;
    }
  }

  .export-modal-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .export-field-label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .export-format-options {
    display: flex;
    gap: 0.5rem;
  }

  .export-format-option {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-text-primary);
  }

  .export-format-option:has(input:checked) {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  .export-format-option input { accent-color: var(--color-accent); margin: 0; }

  .export-sections {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .export-section-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .export-section-option input { accent-color: var(--color-accent); margin: 0; flex-shrink: 0; }

  .export-section-count { color: var(--color-text-muted); font-size: 0.8125rem; }

  .export-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    cursor: pointer;
    user-select: none;
  }

  .export-toggle input { accent-color: var(--color-accent); margin: 0; }

  .export-preview {
    width: 100%;
    box-sizing: border-box;
    min-height: 9rem;
    max-height: 16rem;
    resize: vertical;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    color: var(--color-text-primary);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .export-actions {
    display: flex;
    gap: 0.5rem;
  }

  .export-action-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background 0.15s ease-out, border-color 0.15s ease-out, color 0.15s ease-out;
    min-height: 0;
  }

  .export-action-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }

  .export-action-primary:hover { background: var(--color-accent-hover); }

  .export-action-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .export-action-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .export-modal-footer {
    padding: 0.75rem 1.25rem 1rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: 0.75rem;
    line-height: 1.5;
  }
</style>

<script>
  import { isAssessmentCompleted, getScores } from '../scripts/context-manager.js';
  import { animateDomainBars } from '../scripts/animate-domain-bars.js';
  import frameworkData from '../data/lean-cs-data.json';

  const stages = frameworkData.maturity_stages.stages;
  const playbooks = frameworkData.playbooks as Record<string, any[]>;
  const stageOrder = ['crawl', 'walk', 'run'];
  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run' };

  const CHECKLIST_KEY = 'distilledcs_checklist';

  interface ChecklistItem { id: string; text: string; estimated_time?: string; why_it_matters?: string; }
  interface ChecklistGroup { title: string; stageId: string; items: ChecklistItem[]; }

  function getChecklist(): Record<string, boolean> {
    try {
      const raw = localStorage.getItem(CHECKLIST_KEY);
      return raw ? JSON.parse(raw) : {};
    } catch { return {}; }
  }

  function saveChecklist(data: Record<string, boolean>) {
    try { localStorage.setItem(CHECKLIST_KEY, JSON.stringify(data)); } catch {}
  }

  function mapActions(stage: any): ChecklistItem[] {
    return stage.priority_actions.map((a: any, i: number) => ({
      id: `${stage.id}_${i}`,
      text: typeof a === 'string' ? a : a.text,
      estimated_time: typeof a === 'object' ? a.estimated_time : undefined,
      why_it_matters: typeof a === 'object' ? a.why_it_matters : undefined,
    }));
  }

  // Assessed grouping: Foundation (previous stage) / Current / Next milestone.
  function buildAssessedGroups(userIdx: number): ChecklistGroup[] {
    const groups: ChecklistGroup[] = [];
    if (userIdx > 0) {
      const prevStage = stages[userIdx - 1];
      groups.push({
        title: `Foundation (${stageLabels[prevStage.id]}, should be done)`,
        stageId: prevStage.id,
        items: mapActions(prevStage),
      });
    }
    const currentStage = stages[userIdx];
    groups.push({
      title: `Current Priorities (${stageLabels[currentStage.id]})`,
      stageId: currentStage.id,
      items: mapActions(currentStage),
    });
    if (userIdx < stages.length - 1) {
      const nextStage = stages[userIdx + 1];
      groups.push({
        title: `Next Milestone (${stageLabels[nextStage.id]})`,
        stageId: nextStage.id,
        items: mapActions(nextStage),
      });
    }
    return groups;
  }

  // Non-assessed: all three stages in order, as a clean template.
  function buildStaticGroups(): ChecklistGroup[] {
    return stages.map((stage: any) => ({
      title: `${stage.label} (${stage.subtitle})`,
      stageId: stage.id,
      items: mapActions(stage),
    }));
  }

  // ── Export ──
  interface ExportItem extends ChecklistItem { checked: boolean; }
  interface ExportSection { title: string; items: ExportItem[]; }
  interface ExportModel { sections: ExportSection[]; assessed: boolean; stageLabel: string | null; }

  // Build the export model for the current state. Assessed users export their
  // grouped list with real checked state; everyone else exports an all-stages
  // template (the static view has no checkboxes to reflect).
  function getExportModel(): ExportModel {
    const checklist = getChecklist();
    const assessed = isAssessmentCompleted();
    let groups: ChecklistGroup[];
    let stageLabel: string | null = null;
    if (assessed) {
      const scores = getScores();
      const idx = stageOrder.indexOf(scores?.stage);
      groups = buildAssessedGroups(idx >= 0 ? idx : 0);
      stageLabel = scores?.stage ? stageLabels[scores.stage] : null;
    } else {
      groups = buildStaticGroups();
    }
    const sections = groups.map(g => ({
      title: g.title,
      items: g.items.map(it => ({ ...it, checked: assessed ? !!checklist[it.id] : false })),
    }));
    return { sections, assessed, stageLabel };
  }

  // Pure serializer: GitHub-style Markdown task list or plain text.
  function buildChecklistExport(model: ExportModel, selected: number[], format: string, includeNotes: boolean): string {
    const isMd = format === 'md';
    const lines: string[] = [];
    lines.push(isMd ? '# Customer Success Execution Checklist' : 'Customer Success Execution Checklist');
    const sub = model.stageLabel ? `Stage: ${model.stageLabel}. From distilledcs.org` : 'From distilledcs.org';
    if (isMd) { lines.push('', `_${sub}_`); } else { lines.push(sub); }

    model.sections.forEach((section, i) => {
      if (!selected.includes(i)) return;
      lines.push('');
      lines.push(isMd ? `## ${section.title}` : section.title);
      if (!isMd) lines.push('');
      section.items.forEach(item => {
        const box = item.checked ? '[x]' : '[ ]';
        const time = item.estimated_time ? ` (est. ${item.estimated_time})` : '';
        lines.push(isMd ? `- ${box} ${item.text}${time}` : `${box} ${item.text}${time}`);
        if (includeNotes && item.why_it_matters) {
          lines.push(isMd ? `  > Why: ${item.why_it_matters}` : `    Why: ${item.why_it_matters}`);
        }
      });
    });
    return lines.join('\n') + '\n';
  }

  // ── Export modal wiring (runs for assessed and non-assessed) ──
  const exportModal = document.getElementById('export-modal');
  const exportPreview = document.getElementById('export-preview') as HTMLTextAreaElement | null;
  const exportSectionsEl = document.getElementById('export-sections');
  const exportNotesToggle = document.getElementById('export-include-notes') as HTMLInputElement | null;
  let exportModel: ExportModel | null = null;

  function getSelectedSectionIndexes(): number[] {
    return Array.from(document.querySelectorAll<HTMLInputElement>('.export-section-cb'))
      .filter(cb => cb.checked)
      .map(cb => parseInt(cb.value, 10));
  }

  function getExportFormat(): string {
    const checked = document.querySelector<HTMLInputElement>('input[name="export-format"]:checked');
    return checked ? checked.value : 'md';
  }

  function renderSectionCheckboxes(model: ExportModel) {
    if (!exportSectionsEl) return;
    exportSectionsEl.innerHTML = model.sections.map((s, i) => `
      <label class="export-section-option">
        <input type="checkbox" class="export-section-cb" value="${i}" checked />
        <span>${s.title} <span class="export-section-count">(${s.items.length})</span></span>
      </label>
    `).join('');
  }

  function refreshExportPreview() {
    if (!exportModel || !exportPreview) return;
    exportPreview.value = buildChecklistExport(
      exportModel,
      getSelectedSectionIndexes(),
      getExportFormat(),
      exportNotesToggle?.checked ?? true,
    );
  }

  function openExportModal() {
    if (!exportModal) return;
    exportModel = getExportModel();
    renderSectionCheckboxes(exportModel);
    refreshExportPreview();
    exportModal.hidden = false;
    requestAnimationFrame(() => exportModal.classList.add('is-open'));
    document.getElementById('export-modal-close')?.focus();
  }

  function closeExportModal() {
    if (!exportModal) return;
    exportModal.classList.remove('is-open');
    setTimeout(() => { exportModal.hidden = true; }, 180);
  }

  document.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('[data-open-export]')) openExportModal();
  });
  document.getElementById('export-modal-backdrop')?.addEventListener('click', closeExportModal);
  document.getElementById('export-modal-close')?.addEventListener('click', closeExportModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && exportModal && !exportModal.hidden) closeExportModal();
  });
  exportSectionsEl?.addEventListener('change', refreshExportPreview);
  exportNotesToggle?.addEventListener('change', refreshExportPreview);
  document.querySelectorAll<HTMLInputElement>('input[name="export-format"]').forEach(r => {
    r.addEventListener('change', refreshExportPreview);
  });

  const exportCopyBtn = document.getElementById('export-copy');
  exportCopyBtn?.addEventListener('click', async () => {
    if (!exportPreview) return;
    try { await navigator.clipboard.writeText(exportPreview.value); }
    catch { exportPreview.select(); document.execCommand?.('copy'); }
    const original = exportCopyBtn.textContent ?? 'Copy';
    exportCopyBtn.textContent = 'Copied';
    setTimeout(() => { exportCopyBtn.textContent = original; }, 1600);
  });

  document.getElementById('export-download')?.addEventListener('click', () => {
    if (!exportPreview) return;
    const format = getExportFormat();
    const ext = format === 'md' ? 'md' : 'txt';
    const mime = format === 'md' ? 'text/markdown' : 'text/plain';
    const blob = new Blob([exportPreview.value], { type: `${mime};charset=utf-8` });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `cs-execution-checklist.${ext}`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // ── Assessed interactive checklist ──
  if (isAssessmentCompleted()) {
    const scores = getScores();
    if (scores && scores.stage) {
      const userIdx = stageOrder.indexOf(scores.stage);

      // Show assessed, hide default
      document.querySelectorAll('[data-show-if-assessed]').forEach(el => (el as HTMLElement).style.display = '');
      document.querySelectorAll('[data-hide-if-assessed]').forEach(el => (el as HTMLElement).style.display = 'none');

      const groups = buildAssessedGroups(userIdx);

      const allItems = groups.flatMap(g => g.items);
      let checklist = getChecklist();
      let isFirstRender = true;

      function render() {
        const container = document.getElementById('checklist-assessed');
        if (!container) return;

        const totalChecked = allItems.filter(item => checklist[item.id]).length;
        const totalItems = allItems.length;
        const overallPct = totalItems > 0 ? Math.round((totalChecked / totalItems) * 100) : 0;

        let html = `
          <div class="page-header">
            <h1 class="page-title">Execution Checklist</h1>
            <p class="page-subtitle">Track your progress on the priority actions from your stage playbooks. Check them off as you go, progress is saved automatically.</p>
          </div>
          <div class="checklist-toolbar">
            <button type="button" class="checklist-export-btn" data-open-export>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 1.5v8M5 6.5l3 3 3-3"/><path d="M2.5 11v2a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-2"/></svg>
              Export checklist
            </button>
          </div>
          <div class="overall-progress">
            <div class="overall-progress-label">
              <span>Overall Progress</span>
              <span class="overall-progress-pct">${overallPct}%</span>
            </div>
            <div class="overall-progress-bar">
              <div class="overall-progress-fill" style="width:${overallPct}%"></div>
            </div>
          </div>
        `;

        groups.forEach(group => {
          const groupChecked = group.items.filter(item => checklist[item.id]).length;
          const groupTotal = group.items.length;
          const groupPct = groupTotal > 0 ? Math.round((groupChecked / groupTotal) * 100) : 0;
          const allDone = groupChecked === groupTotal && groupTotal > 0;

          const groupPlaybooks = playbooks[group.stageId] || [];
          const playbookLinksHtml = groupPlaybooks.length > 0
            ? `<div class="related-playbooks-row"><span class="related-label">Related Playbooks:</span>${groupPlaybooks.map((pb: any) => `<a href="/customer-success-playbooks/${pb.id}/" class="related-playbook-link">${pb.title}</a>`).join('')}</div>`
            : '';

          html += `
            <div class="checklist-group stage-${group.stageId}">
              <div class="checklist-group-header">
                <span class="checklist-group-title">${group.title}</span>
                <span class="checklist-group-count">${groupChecked}/${groupTotal}</span>
              </div>
              ${playbookLinksHtml}
              <div class="checklist-progress-bar">
                <div class="checklist-progress-fill" style="width:${groupPct}%"></div>
              </div>
              <div class="checklist-items">
                ${group.items.map(item => {
                  const isChecked = !!checklist[item.id];
                  return `
                    <div class="checklist-item ${isChecked ? 'checked' : ''}" data-item-id="${item.id}">
                      <div class="checklist-checkbox">
                        ${isChecked ? '<span class="checklist-checkmark">&#10003;</span>' : ''}
                      </div>
                      <div class="checklist-item-content">
                        <div class="checklist-item-header">
                          <span class="checklist-text">${item.text}</span>
                          ${item.estimated_time ? `<span class="checklist-time">${item.estimated_time}</span>` : ''}
                        </div>
                        ${item.why_it_matters ? `<p class="checklist-why">${item.why_it_matters}</p>` : ''}
                      </div>
                    </div>
                  `;
                }).join('')}
              </div>
              ${allDone ? '<div class="checklist-celebration">All done! Great work on this section.</div>' : ''}
            </div>
          `;
        });

        // Show Transform CTA when checklist is mostly complete (>= 70%)
        if (overallPct >= 70) {
          html += `
            <div class="next-step-cta">
              <a href="/transform/" class="next-step-link">
                <span class="next-step-label">Next step</span>
                <span class="next-step-text">Ready to Transform? Measure your progress &rarr;</span>
              </a>
            </div>
          `;
        }

        container.innerHTML = html;

        if (isFirstRender) {
          isFirstRender = false;
          animateDomainBars({
            container,
            rowSelector: '.overall-progress',
            fillSelector: '.overall-progress-fill',
            valueSelector: '.overall-progress-pct',
          });
        }

        // Attach click handlers
        container.querySelectorAll('.checklist-item').forEach(el => {
          el.addEventListener('click', () => {
            const id = el.getAttribute('data-item-id');
            if (id) {
              checklist[id] = !checklist[id];
              saveChecklist(checklist);
              render();
            }
          });
        });
      }

      render();
    }
  }
</script>
