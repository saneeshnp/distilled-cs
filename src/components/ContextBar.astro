---
// ContextBar: a slim persistent bar shown below the header on all pages except homepage.
// Rendered empty; populated at runtime via JS from localStorage.
---

<div class="context-bar" id="context-bar" role="complementary" aria-label="Your CS profile summary">
  <div class="container context-bar-inner" id="context-bar-inner">
    <!-- Populated by JS -->
  </div>
</div>

<style>
  .context-bar {
    display: none;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease-out;
  }

  .context-bar.visible {
    display: block;
    max-height: 4rem;
  }

  .context-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    gap: 1rem;
    font-size: 0.8125rem;
  }

  :global(.context-bar-profile) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text-secondary);
    flex-wrap: wrap;
  }

  :global(.context-bar-separator) {
    color: var(--color-text-muted);
  }

  :global(.context-bar-stage) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 500;
  }

  :global(.context-bar-dot) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  :global(.context-bar-actions) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  :global(.context-bar-link) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease-out;
  }

  :global(.context-bar-link:hover) {
    color: var(--color-accent);
  }

  :global(.context-bar-dismiss) {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 1rem;
    padding: 0;
    line-height: 1;
    transition: color 0.2s ease-out;
  }

  :global(.context-bar-dismiss:hover) {
    color: var(--color-text-primary);
  }

  /* Mobile: show only stage, hide profile details */
  @media (max-width: 639px) {
    :global(.context-bar-detail) {
      display: none;
    }
  }
</style>

<script>
  import { isAssessmentCompleted, getScores, getProfile } from '../scripts/context-manager.js';

  const stageColors: Record<string, string> = { crawl: '#E57373', walk: '#FFB74D', run: '#81C784', fly: '#64B5F6' };
  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run', fly: 'Fly' };

  // Label maps for profile option IDs
  const optionLabels: Record<string, string> = {
    arr_under_5m: 'Under $5M', arr_5m_20m: '$5M–$20M', arr_20m_100m: '$20M–$100M', arr_over_100m: 'Over $100M',
    seg_smb: 'SMB', seg_midmarket: 'Mid-Market', seg_enterprise: 'Enterprise', seg_mixed: 'Mixed',
    size_1_3: '1–3 people', size_4_10: '4–10 people', size_11_25: '11–25 people', size_over_25: '25+ people',
  };

  // Don't show on homepage
  if (window.location.pathname !== '/' && isAssessmentCompleted()) {
    const scores = getScores();
    const profile = getProfile();

    if (scores && scores.stage) {
      const stage = scores.stage;
      const color = stageColors[stage] || '#F5A623';

      const arrLabel = optionLabels[profile?.company_arr] || '';
      const segLabel = optionLabels[profile?.customer_segment] || '';
      const sizeLabel = optionLabels[profile?.cs_team_size] || '';

      const bar = document.getElementById('context-bar');
      const inner = document.getElementById('context-bar-inner');

      if (bar && inner) {
        const profileParts = [arrLabel, segLabel, sizeLabel].filter(Boolean);

        inner.innerHTML = `
          <div class="context-bar-profile">
            ${profileParts.map((part, i) => `<span class="context-bar-detail">${part}</span>${i < profileParts.length - 1 ? '<span class="context-bar-separator context-bar-detail">|</span>' : ''}`).join('')}
            <span class="context-bar-stage" style="color:${color}">
              <span class="context-bar-dot" style="background:${color}"></span>
              Stage: ${stageLabels[stage]}
            </span>
          </div>
          <div class="context-bar-actions">
            <a href="/assess/" class="context-bar-link" aria-label="Edit your assessment answers">Edit Assessment</a>
            <button class="context-bar-dismiss" id="context-bar-dismiss" aria-label="Dismiss context bar" type="button">&times;</button>
          </div>
        `;

        // Animate in
        requestAnimationFrame(() => {
          bar.classList.add('visible');
        });

        // Dismiss handler
        document.getElementById('context-bar-dismiss')?.addEventListener('click', () => {
          bar.classList.remove('visible');
          try { sessionStorage.setItem('distilledcs_bar_dismissed', 'true'); } catch {}
        });

        // Check if dismissed this session
        try {
          if (sessionStorage.getItem('distilledcs_bar_dismissed') === 'true') {
            bar.classList.remove('visible');
          }
        } catch {}
      }
    }
  }
</script>
