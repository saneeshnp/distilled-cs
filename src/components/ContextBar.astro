---
// ContextBar: a slim persistent bar shown below the header on all pages except homepage.
// Rendered empty; populated at runtime via JS from localStorage.
---

<div class="context-bar" id="context-bar" role="complementary" aria-label="Your CS profile summary">
  <div class="container context-bar-inner" id="context-bar-inner">
    <!-- Populated by JS -->
  </div>
</div>

<style>
  .context-bar {
    display: none;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease-out;
  }

  .context-bar.visible {
    display: block;
    max-height: 4rem;
  }

  .context-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    gap: 1rem;
    font-size: 0.8125rem;
  }

  :global(.context-bar-profile) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text-secondary);
    flex-wrap: wrap;
  }

  :global(.context-bar-company) {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  :global(.context-bar-separator) {
    color: var(--color-text-muted);
  }

  :global(.context-bar-stage) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 500;
    color: var(--stage-color);
  }

  :global(.context-bar-dot) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--stage-color);
  }

  :global(.context-bar-actions) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  :global(.context-bar-link) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease-out;
  }

  :global(.context-bar-link:hover) {
    color: var(--color-accent);
  }

  :global(.context-bar-dismiss) {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 1rem;
    padding: 0;
    line-height: 1;
    transition: color 0.2s ease-out;
  }

  :global(.context-bar-dismiss:hover) {
    color: var(--color-text-primary);
  }

  :global(.context-bar-phase) {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    padding: 0.0625rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    border-radius: 9999px;
  }

  /* Mobile: show only stage, hide profile details */
  @media (max-width: 639px) {
    :global(.context-bar-detail) {
      display: none;
    }
  }
</style>

<script>
  import { isAssessmentCompleted, getScores, getProfile } from '../scripts/context-manager.js';

  const stageLabels: Record<string, string> = { crawl: 'Crawl', walk: 'Walk', run: 'Run', fly: 'Fly' };

  // Label maps for profile option IDs
  const optionLabels: Record<string, string> = {
    arr_under_5m: 'Under $5M', arr_5m_20m: '$5M–$20M', arr_20m_100m: '$20M–$100M', arr_over_100m: 'Over $100M',
    seg_smb: 'SMB', seg_midmarket: 'Mid-Market', seg_enterprise: 'Enterprise', seg_mixed: 'Mixed',
    size_1_3: '1–3 people', size_4_10: '4–10 people', size_11_25: '11–25 people', size_over_25: '25+ people',
  };

  function populateContextBar() {
    if (window.location.pathname === '/' || !isAssessmentCompleted()) return;

    const scores = getScores();
    const profile = getProfile();

    if (!scores || !scores.stage) return;

    const stage = scores.stage;

    const companyName = profile?.company_name || '';
    const arrLabel = optionLabels[profile?.company_arr] || '';
    const segLabel = optionLabels[profile?.customer_segment] || '';
    const sizeLabel = optionLabels[profile?.cs_team_size] || '';

    const bar = document.getElementById('context-bar');
    const inner = document.getElementById('context-bar-inner');

    if (!bar || !inner) return;

    const profileParts = [arrLabel, segLabel, sizeLabel].filter(Boolean);

    // Determine current loop phase from URL
    const path = window.location.pathname;
    let loopPhase = '';
    if (path.startsWith('/assess') || path.startsWith('/customer-success-maturity-model')) {
      loopPhase = 'Assess';
    } else if (path.startsWith('/customer-success-playbooks') || path.startsWith('/customer-success-metrics') || path.startsWith('/checklist')) {
      loopPhase = 'Execute';
    } else if (path.startsWith('/transform')) {
      loopPhase = 'Transform';
    }
    const phaseHtml = loopPhase
      ? `<span class="context-bar-separator context-bar-detail">|</span><span class="context-bar-phase">${loopPhase}</span>`
      : '';

    const companyHtml = companyName
      ? `<span class="context-bar-company">${companyName}</span><span class="context-bar-separator context-bar-detail">|</span>`
      : '';

    inner.innerHTML = `
      <div class="context-bar-profile">
        ${companyHtml}
        ${profileParts.map((part, i) => `<span class="context-bar-detail">${part}</span>${i < profileParts.length - 1 ? '<span class="context-bar-separator context-bar-detail">|</span>' : ''}`).join('')}
        <span class="context-bar-stage stage-${stage}">
          <span class="context-bar-dot"></span>
          Stage: ${stageLabels[stage]}
        </span>
        ${phaseHtml}
      </div>
      <div class="context-bar-actions">
        <a href="/assess/" class="context-bar-link" aria-label="Edit your assessment answers">Edit Assessment</a>
        <button class="context-bar-dismiss" id="context-bar-dismiss" aria-label="Dismiss context bar" type="button">&times;</button>
      </div>
    `;

    // Animate in (clear any previous session dismissal on fresh save)
    try { sessionStorage.removeItem('distilledcs_bar_dismissed'); } catch {}
    requestAnimationFrame(() => {
      bar.classList.add('visible');
    });

    // Dismiss handler
    document.getElementById('context-bar-dismiss')?.addEventListener('click', () => {
      bar.classList.remove('visible');
      try { sessionStorage.setItem('distilledcs_bar_dismissed', 'true'); } catch {}
    });
  }

  // Initial population
  populateContextBar();

  // Check if dismissed this session (only on initial load, not after a fresh save)
  try {
    if (sessionStorage.getItem('distilledcs_bar_dismissed') === 'true') {
      document.getElementById('context-bar')?.classList.remove('visible');
    }
  } catch {}

  // Listen for assessment updates (e.g. Save & Finish without page reload)
  window.addEventListener('distilledcs:updated', populateContextBar);
</script>
