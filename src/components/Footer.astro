<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">Distilled<span class="footer-logo-accent">CS</span></span>
        <p class="footer-tagline">The Open Customer Success Framework</p>
      </div>
      <div class="footer-columns">
        <nav class="footer-col" aria-label="Framework">
          <h2 class="footer-col-heading">Framework</h2>
          <a href="/customer-success-principles/">Principles</a>
          <a href="/customer-success-metrics/">Metrics</a>
          <a href="/customer-success-playbooks/">Playbooks</a>
          <a href="/customer-success-maturity-model/">Maturity Model</a>
        </nav>
        <nav class="footer-col" aria-label="Site">
          <h2 class="footer-col-heading">Site</h2>
          <a href="/assess/">Assess</a>
          <a href="/transform/">Transform</a>
          <a href="/checklist/">Checklist</a>
          <a href="/glossary/">Glossary</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="https://github.com/saneeshnp/distilled-cs" target="_blank" rel="noopener noreferrer">GitHub</a>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-license">Licensed under <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-SA 4.0</a></p>
      <p class="footer-credit">An open source project &middot; <a href="/contributors/">Contributors</a> &middot; <a href="/privacy/">Privacy</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text-primary);
  }

  .footer-logo-accent {
    color: var(--color-accent);
  }

  .footer-tagline {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem 2rem;
  }

  @media (min-width: 640px) {
    .footer-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col-heading {
    font-size: 0.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.25rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .footer-col a:hover {
    color: var(--color-text-primary);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-license a {
    color: var(--color-text-secondary);
  }

  .footer-credit a {
    color: var(--color-text-secondary);
  }
</style>
