</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text-primary);
  }

  .footer-logo-accent {
    color: var(--color-accent);
  }

  .footer-tagline {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.875rem;
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .footer-social-link:hover {
    color: var(--color-accent);
  }

  .footer-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem 2rem;
  }

  @media (min-width: 640px) {
    .footer-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col-heading {
    font-size: 0.75rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.25rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .footer-col a:hover {
    color: var(--color-text-primary);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-license a {
    color: var(--color-text-secondary);
  }

  .footer-credit a {
    color: var(--color-text-secondary);
  }
</style>
