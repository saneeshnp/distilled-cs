---
import frameworkData from '../data/lean-cs-data.json';
const version = frameworkData.meta.version;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">Distilled<span class="footer-logo-accent">CS</span></span>
        <p class="footer-tagline">The Open Customer Success Framework</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/assess/">Assess</a>
        <a href="/playbooks/">Execute</a>
        <a href="/transform/">Transform</a>
        <a href="/contributors/">Contributors</a>
        <a href="/about/">About</a>
        <a href="#" target="_blank" rel="noopener noreferrer">GitHub (Coming Soon)</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p class="footer-license">Licensed under <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-SA 4.0</a> &middot; v{version}</p>
      <p class="footer-credit">An open source project &middot; <a href="/contributors/">Contributors</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text-primary);
  }

  .footer-logo-accent {
    color: var(--color-accent);
  }

  .footer-tagline {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem 1.5rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-license a {
    color: var(--color-text-secondary);
  }

  .footer-credit a {
    color: var(--color-text-secondary);
  }
</style>
