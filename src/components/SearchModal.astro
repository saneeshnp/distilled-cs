---
/*
 * SearchModal
 * ───────────
 * Site-wide search modal powered by Pagefind.
 *
 * - Trigger: opened by any element with `data-open-search` (header button)
 *   or the Cmd/Ctrl-K keyboard shortcut.
 * - Native <dialog> for focus trapping + Esc-to-close.
 * - Pagefind runtime (`/pagefind/pagefind.js`) is lazy-imported on first
 *   open so it does not cost anything on initial page load.
 * - Dev mode: `pagefind/` is only generated at build time. The script
 *   gracefully shows a fallback notice when the import fails.
 * - Custom UI (not the bundled `pagefind-ui`) so styling matches the site.
 */
---

<dialog id="search-modal" class="search-modal" aria-label="Search the site">
  <div class="search-modal-inner">
    <form class="search-form" id="search-form" role="search" autocomplete="off">
      <div class="search-field">
        <svg class="search-form-icon" width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="7" cy="7" r="5"></circle>
          <path d="m10.5 10.5 3 3"></path>
        </svg>
        <input
          id="search-input"
          type="search"
          class="search-input"
          placeholder="Search principles, metrics, playbooks…"
          aria-label="Search the site"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
        />
      </div>
      <button
        type="button"
        class="search-close"
        id="search-close"
        aria-label="Close search"
        title="Close (Esc)"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m4 4 8 8"></path>
          <path d="m12 4-8 8"></path>
        </svg>
      </button>
    </form>

    <div class="search-results" id="search-results" aria-live="polite">
      <p class="search-empty-hint">Start typing to search the framework.</p>
    </div>

    <footer class="search-footer">
      <span><kbd>↵</kbd> open</span>
      <span><kbd>↑</kbd> <kbd>↓</kbd> navigate</span>
      <span><kbd>Esc</kbd> close</span>
    </footer>
  </div>
</dialog>

<style is:global>
  /* Global because some children are rendered dynamically via JS innerHTML
     and would otherwise miss Astro's scoped hash. */

  .search-modal {
    width: min(640px, calc(100vw - 2rem));
    max-height: min(720px, calc(100vh - 4rem));
    /* Restore native dialog centering (Tailwind preflight zeroes margins). */
    margin: auto;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-bg);
    color: var(--color-text-primary);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }

  .search-modal::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .search-modal-inner {
    display: flex;
    flex-direction: column;
    max-height: inherit;
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-field {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.875rem;
    background: var(--color-surface);
    /* Border stays subtle in every state — focus is communicated by the soft
       outer halo (box-shadow) rather than by recoloring this inner line.
       That keeps the rounded field looking like a single floating pill instead
       of a halo + accent rectangle. */
    border: 1px solid var(--color-border);
    border-radius: 0.875rem;
    transition: box-shadow 0.15s ease, background-color 0.15s ease;
  }

  .search-field:focus-within {
    background: var(--color-bg);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--color-accent) 16%, transparent);
  }

  .search-form-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-field:focus-within .search-form-icon {
    color: var(--color-accent);
  }

  .search-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.25rem 0;
  }

  /* global.css applies a site-wide `:focus-visible { outline: 2px solid accent }`
     for accessibility. The search field's wrapper already paints a clear focus
     halo around the whole row, so the per-input outline would just double up
     as a hard rectangle inside the rounded pill. Suppress it for this input
     only; keyboard users still see the halo. */
  .search-input:focus,
  .search-input:focus-visible {
    outline: none;
    box-shadow: none;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  /* Hide the browser's default search-input cancel ('×') so we don't double
     up with our own close button on the right of the form. */
  .search-input::-webkit-search-cancel-button {
    display: none;
  }

  .search-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    padding: 0;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .search-close:hover {
    color: var(--color-text-primary);
    background: var(--color-surface);
    border-color: var(--color-border);
  }

  .search-close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (pointer: coarse) {
    .search-close {
      width: 2.5rem;
      height: 2.5rem;
    }
  }

  .search-results {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
    min-height: 4rem;
  }

  .search-empty-hint,
  .search-no-results,
  .search-loading,
  .search-unavailable {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    padding: 1.25rem 1rem;
    text-align: center;
    margin: 0;
  }

  .search-no-results strong {
    color: var(--color-text-primary);
  }

  .search-unavailable {
    text-align: left;
    line-height: 1.5;
  }

  .search-result {
    display: block;
    padding: 0.75rem 0.875rem;
    border-radius: 0.5rem;
    color: var(--color-text-primary);
    transition: background-color 0.15s ease-out;
    border: 1px solid transparent;
  }

  .search-result:hover,
  .search-result.is-active {
    background: var(--color-surface);
    border-color: var(--color-border);
  }

  .search-result-title {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.35;
    margin: 0 0 0.25rem;
    color: var(--color-text-primary);
  }

  .search-result-url {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .search-result-excerpt {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .search-result-excerpt mark {
    background: color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: inherit;
    padding: 0 0.125rem;
    border-radius: 0.125rem;
  }

  .search-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    padding: 0.625rem 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }

  .search-footer kbd {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    border: 1px solid var(--color-border);
    border-radius: 0.1875rem;
    padding: 0 0.25rem;
    background: var(--color-bg);
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .search-modal {
      width: 100vw;
      max-width: 100vw;
      max-height: 100vh;
      height: 100vh;
      border-radius: 0;
      border: none;
    }

    /* Keyboard-only affordances; meaningless on touch. */
    .search-footer {
      display: none;
    }
  }

  /* Belt-and-suspenders: hide on any touch-primary input device, even at
     wide tablet widths where the modal is still its desktop size. */
  @media (pointer: coarse) {
    .search-footer {
      display: none;
    }
  }
</style>

<script>
  (function () {
    const dialog = document.getElementById('search-modal') as HTMLDialogElement | null;
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    const resultsEl = document.getElementById('search-results') as HTMLDivElement | null;
    const form = document.getElementById('search-form') as HTMLFormElement | null;
    if (!dialog || !input || !resultsEl || !form) return;

    type PagefindResult = {
      id: string;
      data: () => Promise<{
        url: string;
        excerpt: string;
        meta: { title?: string };
      }>;
    };
    type PagefindModule = {
      search: (q: string) => Promise<{ results: PagefindResult[] }>;
      preload?: (q: string) => void;
    };

    let pagefind: PagefindModule | null = null;
    let pagefindLoadError = false;
    let activeIndex = -1;
    let lastQuery = '';
    let searchToken = 0;

    async function loadPagefind(): Promise<PagefindModule | null> {
      if (pagefind || pagefindLoadError) return pagefind;
      try {
        // Pagefind is generated post-build (not a Vite module). Build the URL
        // at runtime so Rollup can't try to statically resolve it.
        const url = new URL('/pagefind/pagefind.js', window.location.origin).href;
        const mod = await import(/* @vite-ignore */ url);
        if (mod && typeof mod.search === 'function') {
          pagefind = mod as PagefindModule;
          mod.preload?.('');
        } else {
          pagefindLoadError = true;
        }
      } catch (err) {
        pagefindLoadError = true;
      }
      return pagefind;
    }

    function renderUnavailable() {
      resultsEl!.innerHTML =
        '<p class="search-unavailable">Search is unavailable in dev mode. ' +
        'Run <code>npm run build &amp;&amp; npm run preview</code> to generate the index, ' +
        'or it will work as expected on the deployed site.</p>';
    }

    function renderEmpty() {
      resultsEl!.innerHTML =
        '<p class="search-empty-hint">Start typing to search the framework.</p>';
    }

    function renderNoResults(query: string) {
      const safe = escapeHtml(query);
      resultsEl!.innerHTML =
        `<p class="search-no-results">No results for <strong>${safe}</strong>. ` +
        `Try a different term or browse the <a href="/customer-success-principles/">principles</a> or <a href="/customer-success-metrics/">metrics</a>.</p>`;
    }

    function renderLoading() {
      resultsEl!.innerHTML = '<p class="search-loading">Searching…</p>';
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function runSearch(query: string) {
      const trimmed = query.trim();
      lastQuery = trimmed;
      activeIndex = -1;

      if (!trimmed) {
        renderEmpty();
        return;
      }

      const mod = await loadPagefind();
      if (!mod) {
        renderUnavailable();
        return;
      }

      // Guard against late responses overwriting newer ones.
      const myToken = ++searchToken;
      renderLoading();

      try {
        const { results } = await mod.search(trimmed);
        if (myToken !== searchToken) return;
        if (!results.length) {
          renderNoResults(trimmed);
          return;
        }
        // Load top 8 result payloads in parallel.
        const top = results.slice(0, 8);
        const payloads = await Promise.all(top.map((r) => r.data()));
        if (myToken !== searchToken) return;

        const html = payloads
          .map((p, i) => {
            const title = escapeHtml(p.meta.title || p.url);
            const url = escapeHtml(p.url);
            // Pagefind's excerpt is HTML with <mark> wrapping matches — trust it.
            return (
              `<a class="search-result" href="${url}" data-index="${i}">` +
              `<span class="search-result-title">${title}</span>` +
              `<span class="search-result-url">${url}</span>` +
              `<p class="search-result-excerpt">${p.excerpt}</p>` +
              `</a>`
            );
          })
          .join('');
        resultsEl!.innerHTML = html;
      } catch (err) {
        renderUnavailable();
      }
    }

    function getResultLinks(): HTMLAnchorElement[] {
      return Array.from(resultsEl!.querySelectorAll<HTMLAnchorElement>('.search-result'));
    }

    function setActive(idx: number) {
      const links = getResultLinks();
      if (!links.length) return;
      activeIndex = ((idx % links.length) + links.length) % links.length;
      links.forEach((el, i) => el.classList.toggle('is-active', i === activeIndex));
      links[activeIndex].scrollIntoView({ block: 'nearest' });
    }

    function openModal() {
      if (dialog!.open) return;
      dialog!.showModal();
      // Pre-load Pagefind asap so the first keystroke is responsive.
      loadPagefind();
      // Defer focus to next tick to avoid losing it to a click handler.
      requestAnimationFrame(() => input!.focus());
    }

    function closeModal() {
      if (!dialog!.open) return;
      dialog!.close();
      input!.value = '';
      lastQuery = '';
      activeIndex = -1;
      renderEmpty();
    }

    // Debounced input handler — Pagefind is fast but text-input cadence is faster.
    let debounceId: number | undefined;
    input.addEventListener('input', () => {
      const q = input.value;
      window.clearTimeout(debounceId);
      debounceId = window.setTimeout(() => runSearch(q), 120);
    });

    // Prevent native form submit from closing the dialog.
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const links = getResultLinks();
      const target = activeIndex >= 0 ? links[activeIndex] : links[0];
      if (target) target.click();
    });

    // Arrow-key navigation.
    input.addEventListener('keydown', (e) => {
      const links = getResultLinks();
      if (!links.length) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(activeIndex < 0 ? 0 : activeIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(activeIndex < 0 ? links.length - 1 : activeIndex - 1);
      }
    });

    // Click on backdrop closes (native <dialog> doesn't do this for us).
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeModal();
    });

    // Explicit close button (primary close affordance on touch devices,
    // also clickable on desktop).
    const closeBtn = document.getElementById('search-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        closeModal();
      });
    }

    // Esc is handled by native <dialog>, but reset state on close.
    dialog.addEventListener('close', () => {
      input!.value = '';
      lastQuery = '';
      activeIndex = -1;
      renderEmpty();
    });

    // Global open triggers.
    document.querySelectorAll('[data-open-search]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });

    // Cmd/Ctrl-K shortcut.
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (dialog!.open) closeModal();
        else openModal();
      }
    });
  })();
</script>
