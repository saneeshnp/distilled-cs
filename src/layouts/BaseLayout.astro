---
import Header from '../components/Header.astro';
import ContextBar from '../components/ContextBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Distilled CS',
  description = 'An open, vendor-neutral customer success maturity framework. Assess your CS maturity, get prescriptive guidance, and track the metrics that matter.',
} = Astro.props;

const pageTitle = title === 'Distilled CS' ? title : `${title} | Distilled CS`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Distilled CS" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{pageTitle}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <ContextBar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
