---
import Header from '../components/Header.astro';
import ContextBar from '../components/ContextBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  structuredData?: Record<string, any>[];
}

const {
  title = 'Distilled CS',
  description = 'An open, vendor-neutral customer success maturity framework. Assess your CS maturity, get prescriptive guidance, and track the metrics that matter.',
  noindex = false,
  ogImage = '/og-default.png',
  structuredData = [],
} = Astro.props;

const pageTitle = title === 'Distilled CS' ? title : `${title} | Distilled CS`;
const siteUrl = 'https://distilledcs.org';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Distilled CS',
  url: siteUrl,
  description: 'Open, vendor-neutral CS Strategy & Maturity Framework',
  logo: `${siteUrl}/favicon.svg`,
  sameAs: ['https://github.com/saneeshnp/distilled-cs'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Distilled CS',
  url: siteUrl,
  description: 'Assess your CS maturity, get prescriptive guidance, and track the metrics that matter.',
  inLanguage: 'en-US',
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* FOUC prevention: set data-theme attribute before first paint.
        Runs inline in <head> before any stylesheet to avoid a flash of
        light mode when the user has chosen dark. Light is the default,
        so only explicit "dark" needs to flip the attribute. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('distilledcs_theme');
          if (stored === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Theme color for mobile browser chrome -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FAFAF7" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#121212" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Distilled CS" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {structuredData.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <title>{pageTitle}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Preview banner -->
    <div class="preview-banner" id="preview-banner" role="status">
      <div class="preview-banner-inner">
        <svg class="preview-banner-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p class="preview-banner-text">This site is an early preview and under active development.</p>
        <button class="preview-banner-close" id="preview-banner-close" type="button" aria-label="Dismiss banner">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
    <script>
      try {
        if (sessionStorage.getItem('distilledcs_banner_dismissed') === 'true') {
          document.getElementById('preview-banner')?.classList.add('hidden');
        }
      } catch {}
      document.getElementById('preview-banner-close')?.addEventListener('click', () => {
        const banner = document.getElementById('preview-banner');
        if (banner) {
          banner.classList.add('dismissing');
          try { sessionStorage.setItem('distilledcs_banner_dismissed', 'true'); } catch {}
          setTimeout(() => banner.classList.add('hidden'), 250);
        }
      });
    </script>

    <Header />
    <ContextBar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
