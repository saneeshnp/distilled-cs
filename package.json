{
  "name": "distilled-cs",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT AND CC-BY-4.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node src/scripts/recommendation-engine.test.js && node src/scripts/share-encoder.test.js",
    "check:data": "node scripts/checks/validate-data-references.mjs",
    "check:roadmap": "node scripts/checks/validate-roadmap.mjs",
    "check:links": "node scripts/checks/validate-internal-links.mjs",
    "check:pagefind": "node -e \"const e=require('./dist/pagefind/pagefind-entry.json');const n=e.languages.en.page_count;if(n<60){console.error('\\u2717 Pagefind indexed only '+n+' pages (expected >=60)');process.exit(1)}console.log('\\u2713 Pagefind indexed '+n+' pages')\""
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.0.8",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playform/compress": "0.2.3",
    "pagefind": "^1.5.2"
  }
}
